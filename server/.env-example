# ==========================================
# Database Configuration
# ==========================================
# Use local MongoDB or MongoDB Atlas URI
MONGO_URI=mongodb://localhost:27017/Monitoring
# Example Atlas URI:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/Monitoring?retryWrites=true&w=majority

# ==========================================
# Security & Authentication
# ==========================================
# Secret key for signing JWT Access Tokens
JWT_SECRET_KEY=your_super_secret_jwt_key_here

# Secret key for signing JWT Refresh Tokens 
JWT_REFRESH_SECRET_KEY=your_super_secret_refresh_key_here

# Secret key for HMAC encryption of API Keys
API_KEY_HMAC_SECRET=your_super_secret_api_key_hmac_here

# ==========================================
# Security toggles (default-deny in production)
# ==========================================
# When FLASK_ENV=production these default to: cookies SECURE on, debug surfaces off.
# Only flip these for explicit local-debug needs.
#
# Set True to force httpOnly cookies to require HTTPS (recommended for prod).
# ADMIN_COOKIE_SECURE=False
#
# Set True to register /api/agents/debug/* routes (leaks internal state — do NOT enable in prod).
# ENABLE_DEBUG_ENDPOINTS=False
#
# Set True to accept API key / JWT via ?api_key= / ?access_token= query strings.
# Query-string tokens leak into proxy logs, history, and Referer headers — keep False in prod.
# DEBUG_AUTH_QUERY_TOKEN=False

