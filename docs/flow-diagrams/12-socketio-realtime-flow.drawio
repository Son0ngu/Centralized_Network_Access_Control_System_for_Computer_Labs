        <mxCell id="title" value="&lt;b&gt;Flow 12: SocketIO Realtime Events&lt;/b&gt;&lt;br&gt;Server → Dashboard WebSocket Communication&lt;br&gt;&lt;i&gt;Luồng sự kiện realtime qua WebSocket&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
