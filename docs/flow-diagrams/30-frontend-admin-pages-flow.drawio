        <!-- Page count summary -->
        <mxCell id="summary" value="&lt;b&gt;📊 Frontend Pages Summary&lt;/b&gt;&lt;hr&gt;&lt;div style='text-align:left;font-size:11px;'&gt;• &lt;b&gt;Public&lt;/b&gt;: 1 page (/login)&lt;br&gt;• &lt;b&gt;All users&lt;/b&gt;: 7 pages (Dashboard, Agents, Groups, Group Detail, Whitelist, Logs, Profile)&lt;br&gt;• &lt;b&gt;Admin only&lt;/b&gt;: 3 pages (API Keys, Users, Audit)&lt;br&gt;• &lt;b&gt;Error&lt;/b&gt;: 2 pages (404, 500)&lt;br&gt;• &lt;b&gt;Total&lt;/b&gt;: 13 pages (11 functional + 2 error)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Tech Stack&lt;/b&gt;: Jinja2 + Bootstrap 5.3 + Vanilla JS + Socket.IO&lt;br&gt;• &lt;b&gt;Auth&lt;/b&gt;: httpOnly cookies, sessionStorage cache, 20min refresh&lt;br&gt;• &lt;b&gt;RBAC&lt;/b&gt;: CSS classes (.rbac-admin-only, .rbac-teacher-only)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
