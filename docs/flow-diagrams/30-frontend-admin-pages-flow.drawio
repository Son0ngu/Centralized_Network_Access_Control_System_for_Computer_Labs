        <mxCell id="a_feat" value="&lt;b&gt;Audit Log Features&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Segoe UI;fontSize=12;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="480" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="af1" value="&lt;b&gt;Filters&lt;/b&gt;&lt;br&gt;&lt;i&gt;Username search&lt;br&gt;Action dropdown&lt;br&gt;Resource dropdown&lt;br&gt;Time range&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="a_feat">
