  <diagram id="admin-pages" name="Flow 30: Admin Pages (Users, API Keys, Audit, Profile)">
    <mxGraphModel dx="1600" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Flow 30: Admin Pages - Users, API Keys, Audit &amp;amp; Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Các trang quản trị hệ thống (Admin-only) và Hồ sơ cá nhân&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="1100" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== TOP-LEFT: USER MANAGEMENT ==================== -->
        <mxCell id="sec1" value="&lt;b&gt;A. USER MANAGEMENT (/admin/users) 🔒 Admin Only&lt;/b&gt;&lt;br&gt;&lt;i&gt;Quản lý tài khoản người dùng&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="460" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="u_feat" value="&lt;b&gt;User Management Features&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Segoe UI;fontSize=12;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="480" height="340" as="geometry"/>
        </mxCell>

        <mxCell id="uf1" value="&lt;b&gt;Stats Cards (4)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Total Users | Admins | Teachers | Inactive&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="u_feat">
          <mxGeometry x="10" y="35" width="460" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="uf2" value="&lt;b&gt;Create User&lt;/b&gt;&lt;br&gt;&lt;i&gt;Modal: username, password,&lt;br&gt;role (admin/teacher), email&lt;br&gt;POST /api/admin/users&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="u_feat">
          <mxGeometry x="10" y="80" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="uf3" value="&lt;b&gt;Update User&lt;/b&gt;&lt;br&gt;&lt;i&gt;Edit role, email, status&lt;br&gt;PUT /api/admin/users/:id&lt;br&gt;Activate/Deactivate toggle&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="u_feat">
          <mxGeometry x="250" y="80" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="uf4" value="&lt;b&gt;Delete User&lt;/b&gt;&lt;br&gt;&lt;i&gt;DELETE /api/admin/users/:id&lt;br&gt;Last admin guard&lt;br&gt;Self-delete guard&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="u_feat">
          <mxGeometry x="10" y="165" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="uf5" value="&lt;b&gt;Reset Password&lt;/b&gt;&lt;br&gt;&lt;i&gt;POST /api/admin/users&lt;br&gt;/:id/reset-password&lt;br&gt;Generate new password&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="u_feat">
          <mxGeometry x="250" y="165" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="uf6" value="&lt;b&gt;Filters&lt;/b&gt;: Search (username/email) + Role filter (All/Admin/Teacher) + Status filter (All/Active/Inactive)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=10;" vertex="1" parent="u_feat">
          <mxGeometry x="10" y="250" width="460" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="uf7" value="&lt;b&gt;Table&lt;/b&gt;: Username | Email | Role Badge | Status Toggle | Created | Actions (Edit/Delete/Reset)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=10;" vertex="1" parent="u_feat">
          <mxGeometry x="10" y="295" width="460" height="35" as="geometry"/>
        </mxCell>

        <!-- ==================== TOP-RIGHT: API KEYS ==================== -->
        <mxCell id="sec2" value="&lt;b&gt;B. API KEYS (/api-keys) 🔒 Admin Only&lt;/b&gt;&lt;br&gt;&lt;i&gt;Quản lý khóa API cho tích hợp bên ngoài&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="460" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="k_feat" value="&lt;b&gt;API Key Management Features&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Segoe UI;fontSize=12;html=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="130" width="500" height="340" as="geometry"/>
        </mxCell>

        <mxCell id="kf1" value="&lt;b&gt;Stats Cards (4)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Total Keys | Active 🟢 | Revoked 🔴 | Expired ⚪&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="k_feat">
          <mxGeometry x="10" y="35" width="480" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="kf2" value="&lt;b&gt;Create API Key&lt;/b&gt;&lt;br&gt;&lt;i&gt;Modal: name + permissions checkboxes&lt;br&gt;POST /api/api-keys&lt;br&gt;⚠ Key shown ONCE - copy to clipboard&lt;br&gt;HMAC-SHA256 hashed on server&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="k_feat">
          <mxGeometry x="10" y="80" width="230" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="kf3" value="&lt;b&gt;Key Display&lt;/b&gt;&lt;br&gt;&lt;i&gt;Monospace font (Consolas)&lt;br&gt;📋 Copy-to-clipboard button&lt;br&gt;Status badge (Active/Revoked)&lt;br&gt;Permission tags&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="k_feat">
          <mxGeometry x="260" y="80" width="230" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="kf4" value="&lt;b&gt;Revoke Key&lt;/b&gt;&lt;br&gt;&lt;i&gt;PUT /api/api-keys/:id&lt;br&gt;{status: &quot;revoked&quot;}&lt;br&gt;Irreversible action&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="k_feat">
          <mxGeometry x="10" y="185" width="230" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="kf5" value="&lt;b&gt;Delete Key&lt;/b&gt;&lt;br&gt;&lt;i&gt;DELETE /api/api-keys/:id&lt;br&gt;Confirm modal&lt;br&gt;Permanent removal&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=11;align=left;" vertex="1" parent="k_feat">
          <mxGeometry x="260" y="185" width="230" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="kf6" value="&lt;b&gt;Permissions&lt;/b&gt;: agents.read | agents.write | whitelist.read | whitelist.write | logs.read | groups.read | groups.write" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Segoe UI;fontSize=10;" vertex="1" parent="k_feat">
          <mxGeometry x="10" y="270" width="480" height="35" as="geometry"/>
        </mxCell>

        <!-- ==================== BOTTOM-LEFT: AUDIT LOGS ==================== -->
        <mxCell id="sec3" value="&lt;b&gt;C. AUDIT LOGS (/admin/audit) 🔒 Admin Only&lt;/b&gt;&lt;br&gt;&lt;i&gt;Nhật ký kiểm toán hệ thống&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
