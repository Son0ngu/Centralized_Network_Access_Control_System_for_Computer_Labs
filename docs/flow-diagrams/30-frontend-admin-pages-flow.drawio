        <mxCell id="af3" value="&lt;b&gt;Actions Tracked&lt;/b&gt;&lt;br&gt;&lt;i&gt;auth.login | auth.logout | user.create | user.delete | user.update&lt;br&gt;group.create | group.delete | whitelist.add | whitelist.delete&lt;br&gt;agent.delete | api_key.create | api_key.revoke | profile.update&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Segoe UI;fontSize=10;align=left;" vertex="1" parent="a_feat">
