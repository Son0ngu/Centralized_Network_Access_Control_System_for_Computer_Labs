        <mxCell id="rt2b" value="✅ Full stats" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;align=center;" vertex="1" parent="rt2">
          <mxGeometry x="200" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt2c" value="✅ Filtered" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;align=center;" vertex="1" parent="rt2">
          <mxGeometry x="300" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt2d" value="(always visible)" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;overflow=hidden;fontFamily=Segoe UI;fontSize=10;html=1;" vertex="1" parent="rt2">
          <mxGeometry x="400" width="300" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="rt3" value="" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;fontFamily=Segoe UI;html=1;" vertex="1" parent="rbac_table">
          <mxGeometry y="86" width="700" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt3a" value="/agents" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;" vertex="1" parent="rt3">
          <mxGeometry width="200" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt3b" value="✅ Full CRUD" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;align=center;" vertex="1" parent="rt3">
          <mxGeometry x="200" width="100" height="28" as="geometry"/>
