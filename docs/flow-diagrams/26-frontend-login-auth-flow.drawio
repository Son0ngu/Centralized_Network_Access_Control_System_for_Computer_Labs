        </mxCell>
        <mxCell id="rt1a" value="Page / Route" style="shape=partialRectangle;connectable=0;fillColor=#dae8fc;top=0;left=0;bottom=0;right=0;fontStyle=1;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;" vertex="1" parent="rt1">
          <mxGeometry width="200" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt1b" value="Admin" style="shape=partialRectangle;connectable=0;fillColor=#dae8fc;top=0;left=0;bottom=0;right=0;fontStyle=1;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;align=center;" vertex="1" parent="rt1">
          <mxGeometry x="200" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt1c" value="Teacher" style="shape=partialRectangle;connectable=0;fillColor=#dae8fc;top=0;left=0;bottom=0;right=0;fontStyle=1;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;align=center;" vertex="1" parent="rt1">
          <mxGeometry x="300" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt1d" value="CSS Class" style="shape=partialRectangle;connectable=0;fillColor=#dae8fc;top=0;left=0;bottom=0;right=0;fontStyle=1;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;" vertex="1" parent="rt1">
          <mxGeometry x="400" width="300" height="28" as="geometry"/>
        </mxCell>

        <!-- Rows for each page -->
        <mxCell id="rt2" value="" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;fontFamily=Segoe UI;html=1;" vertex="1" parent="rbac_table">
          <mxGeometry y="58" width="700" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="rt2a" value="/ (Dashboard)" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;overflow=hidden;fontFamily=Segoe UI;fontSize=11;html=1;" vertex="1" parent="rt2">
          <mxGeometry width="200" height="28" as="geometry"/>
