        <!-- Timeline -->
        <mxCell id="tl_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="2090" width="1700" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="tl_1" value="&lt;b&gt;1. CREATE&lt;/b&gt;&lt;br&gt;&lt;i&gt;Admin/Teacher&lt;br&gt;thêm domain&lt;/i&gt;&lt;br&gt;POST /api/whitelist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="60" y="2100" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_2" value="&lt;b&gt;2. STORE&lt;/b&gt;&lt;br&gt;&lt;i&gt;Lưu MongoDB&lt;br&gt;Bump version&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="2100" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_3" value="&lt;b&gt;3. NOTIFY&lt;/b&gt;&lt;br&gt;&lt;i&gt;SocketIO emit&lt;br&gt;Audit log&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="370" y="2100" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_4" value="&lt;b&gt;4. PROFILE&lt;/b&gt;&lt;br&gt;&lt;i&gt;Teacher quản lý&lt;br&gt;profile cho nhóm&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="520" y="2100" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_5" value="&lt;b&gt;5. CASCADE&lt;/b&gt;&lt;br&gt;&lt;i&gt;Active → Default&lt;br&gt;→ Legacy fallback&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="680" y="2100" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_6" value="&lt;b&gt;6. MERGE&lt;/b&gt;&lt;br&gt;&lt;i&gt;Global + Group&lt;br&gt;Group wins dups&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="840" y="2100" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_7" value="&lt;b&gt;7. POLICY&lt;/b&gt;&lt;br&gt;&lt;i&gt;none / isolate&lt;br&gt;/ custom_wl&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="990" y="2100" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_8" value="&lt;b&gt;8. SYNC&lt;/b&gt;&lt;br&gt;&lt;i&gt;Agent mỗi 60s&lt;br&gt;Version compare&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1140" y="2100" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_9" value="&lt;b&gt;9. DNS&lt;/b&gt;&lt;br&gt;&lt;i&gt;Resolve domains&lt;br&gt;→ IP addresses&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1290" y="2100" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tl_10" value="&lt;b&gt;10. FIREWALL&lt;/b&gt;&lt;br&gt;&lt;i&gt;Default Deny&lt;br&gt;+ ALLOW rules&lt;/i&gt;&lt;br&gt;&lt;b&gt;ENFORCED ✅&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
