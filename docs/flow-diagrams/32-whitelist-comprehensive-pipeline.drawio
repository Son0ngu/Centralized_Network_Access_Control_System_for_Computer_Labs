        <mxCell id="s9_header" value="&lt;b&gt;⑨ Key Code References&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tham chiếu code quan trọng&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="2240" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- Server-side code refs -->
        <mxCell id="code_server" value="&lt;b&gt;Server-side Code:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;whitelist_service.py&lt;/b&gt;&lt;br&gt;• get_agent_sync_data() - Profile cascade + merge + policy&lt;br&gt;&lt;br&gt;&lt;b&gt;whitelist_controller.py&lt;/b&gt;&lt;br&gt;• agent_sync - GET /api/whitelist/agent-sync&lt;br&gt;&lt;br&gt;&lt;b&gt;whitelist_profile_service.py&lt;/b&gt;&lt;br&gt;• get_active_profile() / get_default_profile()&lt;br&gt;• activate_profile() - Deactivate others + bump version&lt;br&gt;&lt;br&gt;&lt;b&gt;agent_policy_service.py&lt;/b&gt;&lt;br&gt;• apply_policy_to_sync() - none / isolate / custom_whitelist" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="60" y="2290" width="380" height="240" as="geometry"/>
        </mxCell>

        <!-- Agent-side code refs -->
        <mxCell id="code_agent" value="&lt;b&gt;Agent-side Code:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;whitelist/sync.py&lt;/b&gt;&lt;br&gt;• WhitelistSyncer.sync_with_server() - Retry + fallback&lt;br&gt;&lt;br&gt;&lt;b&gt;whitelist/manager.py&lt;/b&gt;&lt;br&gt;• WhitelistManager - Sync loop 60s, DNS refresh 10s&lt;br&gt;&lt;br&gt;&lt;b&gt;whitelist/state.py&lt;/b&gt;&lt;br&gt;• WhitelistState - domains/patterns/IPs sets, version&lt;br&gt;• is_domain_allowed() / is_ip_allowed()&lt;br&gt;&lt;br&gt;&lt;b&gt;firewall/manager.py&lt;/b&gt;&lt;br&gt;• FirewallManager - Default Deny + ALLOW rules&lt;br&gt;• sync_whitelist_changes() - Diff-based update&lt;br&gt;&lt;br&gt;&lt;b&gt;network/dns_resolver.py&lt;/b&gt;&lt;br&gt;• OptimizedDNSResolver - Parallel, LRUCache, TTL" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="500" y="2290" width="380" height="260" as="geometry"/>
        </mxCell>

        <!-- Related flows -->
        <mxCell id="related_flows" value="&lt;b&gt;Related Flow Diagrams:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Flow 7:&lt;/b&gt; Whitelist Agent Sync - Sync protocol detail&lt;br&gt;&lt;b&gt;Flow 8:&lt;/b&gt; Agent Firewall - Firewall rules detail&lt;br&gt;&lt;b&gt;Flow 9:&lt;/b&gt; DNS Resolution - DNS resolver detail&lt;br&gt;&lt;b&gt;Flow 15:&lt;/b&gt; Group Management - Group CRUD&lt;br&gt;&lt;b&gt;Flow 17:&lt;/b&gt; Whitelist CRUD - Entry management&lt;br&gt;&lt;b&gt;Flow 18:&lt;/b&gt; Import/Export - Bulk operations&lt;br&gt;&lt;b&gt;Flow 19:&lt;/b&gt; Whitelist Profiles - Profile CRUD&lt;br&gt;&lt;b&gt;Flow 20:&lt;/b&gt; Agent Policy - Policy override&lt;br&gt;&lt;b&gt;Flow 28:&lt;/b&gt; Frontend Agent/Group Pages&lt;br&gt;&lt;b&gt;Flow 29:&lt;/b&gt; Frontend Whitelist/Logs Pages" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="940" y="2290" width="340" height="240" as="geometry"/>
        </mxCell>

        <!-- Thread info -->
        <mxCell id="thread_info" value="&lt;b&gt;Agent Daemon Threads Involved:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;WhitelistSync&lt;/b&gt; - 60s interval, sync with server&lt;br&gt;&lt;b&gt;DNSRefresh&lt;/b&gt; - 10s interval, resolve domains→IPs&lt;br&gt;&lt;b&gt;WhitelistMonitor&lt;/b&gt; - Monitor state changes&lt;br&gt;&lt;b&gt;HeartbeatSender&lt;/b&gt; - 20s, keeps agent online&lt;br&gt;&lt;hr&gt;&lt;b&gt;Key Constants:&lt;/b&gt;&lt;br&gt;Sync interval: 60 seconds&lt;br&gt;DNS cache: 2000 entries (LRU)&lt;br&gt;DNS TTL: configurable per-entry&lt;br&gt;Retry: max 3 attempts + fallback&lt;br&gt;Firewall: netsh advfirewall" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1340" y="2290" width="300" height="250" as="geometry"/>
