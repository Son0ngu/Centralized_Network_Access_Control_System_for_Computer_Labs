        <mxCell id="s8_header" value="&lt;b&gt;⑧ Complete Lifecycle Timeline&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tổng quan vòng đời whitelist hoàn chỉnh&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
