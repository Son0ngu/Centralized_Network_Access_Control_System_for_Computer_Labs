  <diagram id="whitelist-comprehensive-pipeline" name="Whitelist Comprehensive Pipeline">
    <mxGraphModel dx="1600" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2200" pageHeight="3200" math="0" shadow="0">
      <root>
