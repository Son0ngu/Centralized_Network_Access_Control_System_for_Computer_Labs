        <mxCell id="s1_header" value="&lt;b&gt;① Admin/Teacher Creates Whitelist Entry&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bước 1: Admin/Giáo viên tạo mục whitelist&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
