        </mxCell>
        <mxCell id="b3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="prof_activate" target="prof_deactivate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="prof_deactivate" target="prof_bump" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SECTION 3: PROFILE PRIORITY CASCADE -->
        <!-- ============================================================ -->
        <mxCell id="s3_header" value="&lt;b&gt;③ Profile Priority Cascade (Server-side)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bước 3: Thứ tự ưu tiên Profile khi Server xử lý sync (get_agent_sync_data)&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="470" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- Priority cascade box -->
        <mxCell id="cascade_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="1500" height="180" as="geometry"/>
        </mxCell>

        <!-- Step: Check Active Profile -->
        <mxCell id="cas_1" value="&lt;b&gt;1. Check Active Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;get_active_profile(group_id)&lt;/i&gt;&lt;br&gt;is_active = True?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="110" y="545" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Active found -->
        <mxCell id="cas_1_yes" value="&lt;b&gt;✅ Use Active Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Dùng profile đang kích hoạt&lt;/i&gt;&lt;br&gt;profile.domains[]&lt;br&gt;&lt;b&gt;HIGHEST PRIORITY&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="370" y="535" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Step: Check Default Profile -->
        <mxCell id="cas_2" value="&lt;b&gt;2. Check Default Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;get_default_profile(group_id)&lt;/i&gt;&lt;br&gt;is_default = True?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="630" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Default found -->
        <mxCell id="cas_2_yes" value="&lt;b&gt;✅ Use Default Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Dùng profile mặc định&lt;/i&gt;&lt;br&gt;profile.domains[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="540" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- Step: Fallback Legacy -->
        <mxCell id="cas_3" value="&lt;b&gt;3. Fallback: Legacy&lt;/b&gt;&lt;br&gt;&lt;i&gt;group.whitelist[]&lt;/i&gt;&lt;br&gt;Whitelist gốc của nhóm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="640" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- Merge box -->
        <mxCell id="merge_box" value="&lt;b&gt;MERGE: Global + Group&lt;/b&gt;&lt;br&gt;&lt;i&gt;Gộp entry Global với Group&lt;/i&gt;&lt;br&gt;&lt;hr&gt;Global entries (scope=global)&lt;br&gt;+ Group entries (from profile/legacy)&lt;br&gt;&lt;hr&gt;&lt;b&gt;Duplicate Rule:&lt;/b&gt;&lt;br&gt;Group scope wins over Global&lt;br&gt;&lt;i&gt;Nếu trùng → ưu tiên Group&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="530" width="230" height="150" as="geometry"/>
        </mxCell>

        <!-- Policy Override -->
        <mxCell id="policy_check" value="&lt;b&gt;Policy Override?&lt;/b&gt;&lt;br&gt;&lt;i&gt;Kiểm tra chính sách nhóm&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1150" y="545" width="160" height="110" as="geometry"/>
        </mxCell>

        <!-- Policy: none -->
        <mxCell id="pol_none" value="&lt;b&gt;none&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bình thường&lt;/i&gt;&lt;br&gt;Use merged list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1350" y="525" width="110" height="55" as="geometry"/>
        </mxCell>

        <!-- Policy: isolate -->
        <mxCell id="pol_isolate" value="&lt;b&gt;isolate&lt;/b&gt;&lt;br&gt;&lt;i&gt;Cô lập hoàn toàn&lt;/i&gt;&lt;br&gt;entries = []&lt;br&gt;Only system IPs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1350" y="590" width="110" height="65" as="geometry"/>
        </mxCell>

        <!-- Policy: custom_whitelist -->
        <mxCell id="pol_custom" value="&lt;b&gt;custom_whitelist&lt;/b&gt;&lt;br&gt;&lt;i&gt;DS tùy chỉnh&lt;/i&gt;&lt;br&gt;policy.custom_whitelist[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1350" y="665" width="130" height="55" as="geometry"/>
        </mxCell>

        <!-- Final sync data -->
        <mxCell id="sync_data" value="&lt;b&gt;Sync Response&lt;/b&gt;&lt;br&gt;&lt;i&gt;Dữ liệu gửi cho Agent&lt;/i&gt;&lt;br&gt;{entries[], versions,&lt;br&gt;global_version, group_version}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1520" y="555" width="190" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows Section 3 -->
        <mxCell id="c1" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#009900;" edge="1" source="cas_1" target="cas_1_yes" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="No" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#cc0000;" edge="1" source="cas_1" target="cas_2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#009900;" edge="1" source="cas_2" target="cas_2_yes" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c4" value="No" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#cc0000;" edge="1" source="cas_2" target="cas_3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cas_1_yes" target="merge_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cas_2_yes" target="merge_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cas_3" target="merge_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="merge_box" target="policy_check" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c9" value="none" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="policy_check" target="pol_none" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c10" value="isolate" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="policy_check" target="pol_isolate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c11" value="custom" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="policy_check" target="pol_custom" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pol_none" target="sync_data" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c12b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pol_isolate" target="sync_data" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c12c" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pol_custom" target="sync_data" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SECTION 4: AGENT SYNC LOOP -->
        <!-- ============================================================ -->
        <mxCell id="s4_header" value="&lt;b&gt;④ Agent Sync Loop (Every 60s)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bước 4: Vòng lặp đồng bộ Agent (mỗi 60 giây) - WhitelistManager.sync_loop()&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="750" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- Agent Timer -->
        <mxCell id="agent_timer" value="&lt;b&gt;⏱ Sync Timer&lt;/b&gt;&lt;br&gt;&lt;i&gt;Mỗi 60 giây&lt;/i&gt;&lt;br&gt;WhitelistManager&lt;br&gt;._sync_interval = 60" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="810" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Send versions -->
        <mxCell id="agent_send" value="&lt;b&gt;GET /api/whitelist/agent-sync&lt;/b&gt;&lt;br&gt;&lt;i&gt;Gửi versions hiện tại&lt;/i&gt;&lt;br&gt;?global_version=X&lt;br&gt;&amp;group_version=Y" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="810" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Server compare -->
        <mxCell id="server_compare" value="&lt;b&gt;Compare Versions&lt;/b&gt;&lt;br&gt;&lt;i&gt;So sánh version&lt;/i&gt;&lt;br&gt;Agent version vs&lt;br&gt;Server version" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="800" width="170" height="110" as="geometry"/>
        </mxCell>

        <!-- Up to date -->
        <mxCell id="up_to_date" value="&lt;b&gt;304 Not Modified&lt;/b&gt;&lt;br&gt;&lt;i&gt;Không cần cập nhật&lt;/i&gt;&lt;br&gt;{&quot;changed&quot;: false}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="740" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Need update -->
        <mxCell id="need_update" value="&lt;b&gt;200 OK + Full Data&lt;/b&gt;&lt;br&gt;&lt;i&gt;Gửi dữ liệu mới&lt;/i&gt;&lt;br&gt;{&quot;changed&quot;: true,&lt;br&gt;&quot;entries&quot;: [...],&lt;br&gt;&quot;versions&quot;: {...}}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="830" width="170" height="90" as="geometry"/>
        </mxCell>

        <!-- Retry logic -->
        <mxCell id="retry_logic" value="&lt;b&gt;Retry Logic&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thử lại khi lỗi&lt;/i&gt;&lt;br&gt;max_retries = 3&lt;br&gt;Fallback servers&lt;br&gt;On fail → use cached" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="940" width="170" height="90" as="geometry"/>
        </mxCell>

        <!-- Arrows Section 4 -->
        <mxCell id="d1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="agent_timer" target="agent_send" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="d2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="agent_send" target="server_compare" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="d3" value="Same" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#009900;" edge="1" source="server_compare" target="up_to_date" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="d4" value="Different" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#cc0000;" edge="1" source="server_compare" target="need_update" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="d5" value="Network Error" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#cc0000;dashed=1;" edge="1" source="agent_send" target="retry_logic" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SECTION 5: AGENT STATE UPDATE -->
        <!-- ============================================================ -->
        <mxCell id="s5_header" value="&lt;b&gt;⑤ Agent State Update &amp; DNS Resolution&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bước 5: Cập nhật state Agent &amp; Phân giải DNS&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1060" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- Agent receives data -->
        <mxCell id="agent_receive" value="&lt;b&gt;WhitelistSyncer&lt;/b&gt;&lt;br&gt;&lt;i&gt;Nhận dữ liệu từ server&lt;/i&gt;&lt;br&gt;Parse entries[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1120" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- Classify entries -->
        <mxCell id="classify" value="&lt;b&gt;Classify Entries&lt;/b&gt;&lt;br&gt;&lt;i&gt;Phân loại entry&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="1125" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- Three sets -->
        <mxCell id="set_domains" value="&lt;b&gt;domains: set()&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tên miền&lt;/i&gt;&lt;br&gt;google.com&lt;br&gt;*.edu.vn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="1100" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="set_ips" value="&lt;b&gt;ip_addresses: set()&lt;/b&gt;&lt;br&gt;&lt;i&gt;Địa chỉ IP&lt;/i&gt;&lt;br&gt;142.250.196.110&lt;br&gt;10.0.0.0/24" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="1100" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="set_patterns" value="&lt;b&gt;patterns: set()&lt;/b&gt;&lt;br&gt;&lt;i&gt;Mẫu URL&lt;/i&gt;&lt;br&gt;*.google.com/*&lt;br&gt;regex patterns" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="1100" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- WhitelistState -->
        <mxCell id="wl_state" value="&lt;b&gt;WhitelistState&lt;/b&gt;&lt;br&gt;&lt;i&gt;Lưu trạng thái whitelist&lt;/i&gt;&lt;br&gt;• domains, ip_addresses, patterns&lt;br&gt;• global_version, group_version&lt;br&gt;• is_domain_allowed(domain)&lt;br&gt;• is_ip_allowed(ip)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="1200" width="250" height="100" as="geometry"/>
        </mxCell>

        <!-- DNS Resolution -->
        <mxCell id="dns_resolve" value="&lt;b&gt;OptimizedDNSResolver&lt;/b&gt;&lt;br&gt;&lt;i&gt;Phân giải DNS song song&lt;/i&gt;&lt;br&gt;• ThreadPoolExecutor&lt;br&gt;• LRUCache (2000 entries)&lt;br&gt;• TTL-based refresh (10s loop)&lt;br&gt;• domain → IP addresses" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1050" y="1100" width="220" height="100" as="geometry"/>
