        <!-- Timeline delay note -->
        <mxCell id="tl_note" value="&lt;b&gt;Timing:&lt;/b&gt; Step 1-3: Instant (ms) | Step 4-7: Server processing (ms) | Step 8: Max 60s delay (sync interval) | Step 9: DNS cache + TTL | Step 10: netsh execution (~1-2s)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
