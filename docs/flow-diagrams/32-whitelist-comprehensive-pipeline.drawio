          <mxGeometry x="180" y="180" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- RBAC Check -->
        <mxCell id="rbac_check" value="&lt;b&gt;RBAC Check&lt;/b&gt;&lt;br&gt;&lt;i&gt;Kiểm tra quyền&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="170" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Admin: Full Access -->
        <mxCell id="admin_access" value="&lt;b&gt;Admin&lt;/b&gt;&lt;br&gt;Global + All Groups&lt;br&gt;&lt;i&gt;Toàn quyền whitelist&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="150" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Teacher: Profile-based -->
        <mxCell id="teacher_access" value="&lt;b&gt;Teacher&lt;/b&gt;&lt;br&gt;Own Groups + Profiles Only&lt;br&gt;&lt;i&gt;Chỉ nhóm mình quản lý&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="215" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- API Call -->
        <mxCell id="api_add" value="&lt;b&gt;POST /api/whitelist&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thêm entry mới&lt;/i&gt;&lt;br&gt;{domain, scope, group_id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="810" y="170" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Server Processing -->
        <mxCell id="server_validate" value="&lt;b&gt;Validate &amp; Save&lt;/b&gt;&lt;br&gt;&lt;i&gt;Xác thực &amp; lưu MongoDB&lt;/i&gt;&lt;br&gt;Check duplicates&lt;br&gt;Validate domain format" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="160" width="170" height="80" as="geometry"/>
        </mxCell>

        <!-- Bump Version -->
        <mxCell id="bump_version" value="&lt;b&gt;Bump Group Version&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tăng version nhóm +1&lt;/i&gt;&lt;br&gt;group.whitelist_version += 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1260" y="160" width="180" height="80" as="geometry"/>
