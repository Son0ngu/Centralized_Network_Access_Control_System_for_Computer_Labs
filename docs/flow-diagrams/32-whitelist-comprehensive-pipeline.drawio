        <!-- ============================================================ -->
        <!-- SECTION 2: WHITELIST PROFILE SYSTEM -->
        <!-- ============================================================ -->
        <mxCell id="s2_header" value="&lt;b&gt;② Whitelist Profile System&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bước 2: Hệ thống Profile Whitelist (Teacher tạo &amp; quản lý)&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="290" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- Teacher creates profile -->
        <mxCell id="prof_create" value="&lt;b&gt;Teacher Creates Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Giáo viên tạo profile mới&lt;/i&gt;&lt;br&gt;POST /api/whitelist-profiles&lt;br&gt;{name, group_id, domains[]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="350" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Profile stored -->
        <mxCell id="prof_stored" value="&lt;b&gt;MongoDB: whitelist_profiles&lt;/b&gt;&lt;br&gt;&lt;i&gt;Lưu trữ profile&lt;/i&gt;&lt;br&gt;group_id, teacher_id&lt;br&gt;domains[], is_default&lt;br&gt;is_active, version" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="340" width="170" height="100" as="geometry"/>
        </mxCell>

        <!-- Activate profile decision -->
        <mxCell id="prof_activate" value="&lt;b&gt;Activate Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Kích hoạt profile&lt;/i&gt;&lt;br&gt;PUT /api/whitelist-profiles/:id/activate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="350" width="210" height="70" as="geometry"/>
        </mxCell>

        <!-- Deactivate others -->
        <mxCell id="prof_deactivate" value="&lt;b&gt;Deactivate Others&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tắt profile cũ cùng nhóm&lt;/i&gt;&lt;br&gt;is_active = False&lt;br&gt;(Only 1 active per group)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="340" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Bump group version -->
        <mxCell id="prof_bump" value="&lt;b&gt;Bump Group Version&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tăng version nhóm&lt;/i&gt;&lt;br&gt;→ Agent sẽ nhận ra&lt;br&gt;cần đồng bộ lại" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="345" width="170" height="75" as="geometry"/>
        </mxCell>

        <!-- Profile note -->
        <mxCell id="prof_note" value="&lt;b&gt;Profile Rules:&lt;/b&gt;&lt;br&gt;• Mỗi group chỉ có 1 active profile&lt;br&gt;• Teacher chỉ quản lý profile nhóm mình&lt;br&gt;• Admin quản lý tất cả profiles&lt;br&gt;• Khi activate → bump version → agent sync" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1310" y="330" width="260" height="100" as="geometry"/>
        </mxCell>

        <!-- Arrows Section 2 -->
        <mxCell id="b1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="prof_create" target="prof_stored" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="prof_stored" target="prof_activate" parent="1">
