        <!-- ============================================================ -->
        <!-- SECTION 6: FIREWALL ENFORCEMENT -->
        <!-- ============================================================ -->
        <mxCell id="s6_header" value="&lt;b&gt;⑥ Firewall Enforcement (Windows)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bước 6: Thực thi luật tường lửa Windows - FirewallManager&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1340" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- System IPs always allowed -->
        <mxCell id="system_ips" value="&lt;b&gt;System IPs (Always Allowed)&lt;/b&gt;&lt;br&gt;&lt;i&gt;IP hệ thống luôn được phép&lt;/i&gt;&lt;br&gt;• DNS: 8.8.8.8, 8.8.4.4, 1.1.1.1&lt;br&gt;• Server host IP&lt;br&gt;• Localhost 127.0.0.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1400" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- Collect all IPs -->
        <mxCell id="collect_ips" value="&lt;b&gt;Collect All Allowed IPs&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tổng hợp tất cả IP được phép&lt;/i&gt;&lt;br&gt;System IPs&lt;br&gt;+ Direct IPs (from whitelist)&lt;br&gt;+ Resolved IPs (from DNS)&lt;br&gt;+ CIDR ranges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="1390" width="210" height="110" as="geometry"/>
        </mxCell>

        <!-- Default Deny -->
        <mxCell id="default_deny" value="&lt;b&gt;DEFAULT DENY&lt;/b&gt;&lt;br&gt;&lt;i&gt;Chặn tất cả mặc định&lt;/i&gt;&lt;br&gt;netsh advfirewall set&lt;br&gt;allprofiles firewallpolicy&lt;br&gt;blockinbound,blockoutbound" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="1390" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Diff calculation -->
        <mxCell id="diff_calc" value="&lt;b&gt;Calculate Diff&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tính toán thay đổi&lt;/i&gt;&lt;br&gt;sync_whitelist_changes()&lt;br&gt;to_add = new - old&lt;br&gt;to_remove = old - new" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="1400" width="180" height="90" as="geometry"/>
        </mxCell>

        <!-- Add ALLOW rules -->
        <mxCell id="add_rules" value="&lt;b&gt;Add ALLOW Rules&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thêm luật cho phép&lt;/i&gt;&lt;br&gt;netsh advfirewall firewall&lt;br&gt;add rule name=&quot;WL_xxx&quot;&lt;br&gt;dir=out action=allow&lt;br&gt;remoteip=&lt;IP&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1380" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- Remove old rules -->
        <mxCell id="remove_rules" value="&lt;b&gt;Remove Old Rules&lt;/b&gt;&lt;br&gt;&lt;i&gt;Xóa luật cũ&lt;/i&gt;&lt;br&gt;netsh advfirewall firewall&lt;br&gt;delete rule name=&quot;WL_xxx&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1500" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Firewall active -->
        <mxCell id="fw_active" value="&lt;b&gt;✅ Firewall Active&lt;/b&gt;&lt;br&gt;&lt;i&gt;Tường lửa hoạt động&lt;/i&gt;&lt;br&gt;Only whitelisted IPs&lt;br&gt;can be accessed&lt;br&gt;&lt;b&gt;Chỉ IP trong whitelist&lt;br&gt;được truy cập&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1400" width="190" height="100" as="geometry"/>
        </mxCell>

