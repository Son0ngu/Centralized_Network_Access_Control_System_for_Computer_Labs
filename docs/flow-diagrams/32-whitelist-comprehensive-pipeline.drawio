        <!-- ============================================================ -->
        <mxCell id="s7_header" value="&lt;b&gt;⑦ Multi-Agent Example: Different Groups → Different Whitelists&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bước 7: Ví dụ thực tế - Agent khác nhóm nhận whitelist khác nhau&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="1">
