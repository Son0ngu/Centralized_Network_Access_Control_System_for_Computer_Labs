        <!-- SocketIO Emit -->
        <mxCell id="socketio_emit" value="&lt;b&gt;SocketIO Emit&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thông báo real-time&lt;/i&gt;&lt;br&gt;agent_group_updated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1490" y="165" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Audit Log -->
        <mxCell id="audit_entry" value="&lt;b&gt;Audit Log&lt;/b&gt;&lt;br&gt;&lt;i&gt;Ghi nhật ký&lt;/i&gt;&lt;br&gt;action: whitelist_add" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
