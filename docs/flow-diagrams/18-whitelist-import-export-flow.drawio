<mxfile host="app.diagrams.net" modified="2026-03-23" agent="Claude" version="24.0.0" type="device">
  <diagram id="import-export" name="Whitelist Import/Export">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Flow 18: Whitelist Import / Export&lt;/b&gt;&lt;br&gt;&lt;i&gt;Nhập / Xuất whitelist&lt;/i&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="440" y="10" width="330" height="45" as="geometry" />
        </mxCell>

        <!-- ===== IMPORT (Left) ===== -->
        <mxCell id="imp_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="520" height="560" as="geometry" />
        </mxCell>
        <mxCell id="imp_title" value="&lt;b&gt;IMPORT DOMAINS&lt;/b&gt; - POST /api/whitelist/import&lt;br&gt;&lt;i&gt;Nhập whitelist từ danh sách&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="78" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="i_s1" value="&lt;b&gt;Request&lt;/b&gt;&lt;br&gt;{domains: [{value, type}, &quot;plain-string&quot;, ...],&lt;br&gt;group_id: &quot;optional&quot;, category: &quot;imported&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="350" height="45" as="geometry" />
        </mxCell>

        <mxCell id="i_mw" value="@inject_current_user (Teacher + Admin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="140" y="180" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ie1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="i_s1" target="i_mw" parent="1" />

        <mxCell id="i_d1" value="&lt;b&gt;Is Teacher?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="220" width="90" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ie2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="i_mw" target="i_d1" parent="1" />

        <mxCell id="i_d2" value="&lt;b&gt;group_id&lt;br&gt;provided?&lt;/b&gt;&lt;br&gt;&lt;i&gt;Có chỉ định nhóm?&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="365" y="215" width="110" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ie3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="i_d1" target="i_d2" parent="1" />

        <mxCell id="i_err1" value="&lt;b&gt;403&lt;/b&gt;&lt;br&gt;Teacher phải chỉ định group" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="375" y="290" width="130" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ie4" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=9;" edge="1" source="i_d2" target="i_err1" parent="1" />

        <mxCell id="i_d3" value="&lt;b&gt;Owns this&lt;br&gt;group?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="375" y="340" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ie4b" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=9;" edge="1" source="i_d2" target="i_d3" parent="1" />

        <mxCell id="i_err2" value="&lt;b&gt;403&lt;/b&gt; Không có quyền" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="390" y="405" width="120" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ie5" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=9;" edge="1" source="i_d3" target="i_err2" parent="1" />

        <!-- Process items -->
        <mxCell id="i_proc" value="&lt;b&gt;Process each item:&lt;/b&gt;&lt;br&gt;• String → auto-detect type (domain/IP)&lt;br&gt;• Object → use {value, type} as-is&lt;br&gt;• Strip, lowercase, validate&lt;br&gt;• Skip duplicates&lt;br&gt;• Set category = &quot;imported&quot; (default)&lt;br&gt;&lt;i&gt;Xử lý từng entry: tự detect loại&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ie6" value="No (Admin)" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="i_d1" target="i_proc" parent="1" />
        <mxCell id="ie6b" value="Yes (owns)" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=8;" edge="1" source="i_d3" target="i_proc" parent="1" />

        <mxCell id="i_bulk" value="&lt;b&gt;service.bulk_add_entries(items)&lt;/b&gt;&lt;br&gt;Split by scope: global vs group&lt;br&gt;bump_global_version() if global added&lt;br&gt;bump group whitelist_version if group added&lt;br&gt;&lt;i&gt;Thêm hàng loạt + tăng version&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="55" y="415" width="260" height="65" as="geometry" />
        </mxCell>
        <mxCell id="ie7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="i_proc" target="i_bulk" parent="1" />

        <mxCell id="i_socket" value="&lt;b&gt;SocketIO.emit(&quot;whitelist_updated&quot;)&lt;/b&gt;&lt;br&gt;{action: &quot;bulk_added&quot;, count}&lt;br&gt;&lt;i&gt;Thông báo realtime&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="75" y="505" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ie8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="i_bulk" target="i_socket" parent="1" />

        <mxCell id="i_resp" value="&lt;b&gt;200 OK&lt;/b&gt;&lt;br&gt;{added_count, skipped_count, failed_count, errors}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="60" y="565" width="280" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ie9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="i_socket" target="i_resp" parent="1" />

        <!-- ===== EXPORT (Right) ===== -->
        <mxCell id="exp_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fff0;strokeColor=#82b366;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="70" width="450" height="400" as="geometry" />
        </mxCell>
        <mxCell id="exp_title" value="&lt;b&gt;EXPORT DOMAINS&lt;/b&gt; - GET /api/whitelist/export&lt;br&gt;&lt;i&gt;Xuất whitelist&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="78" width="330" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e_s1" value="&lt;b&gt;GET /whitelist/export&lt;/b&gt;&lt;br&gt;?format=json|txt&amp;category=optional" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="125" width="280" height="35" as="geometry" />
        </mxCell>

        <mxCell id="e_query" value="&lt;b&gt;Build query&lt;/b&gt;&lt;br&gt;Filter by category (if provided)&lt;br&gt;Filter by scope (Teacher: own groups + global)&lt;br&gt;&lt;i&gt;Lọc theo category + scope&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="660" y="180" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ee1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="e_s1" target="e_query" parent="1" />

        <mxCell id="e_d1" value="&lt;b&gt;format?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="255" width="80" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ee2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="e_query" target="e_d1" parent="1" />

        <!-- JSON format -->
        <mxCell id="e_json" value="&lt;b&gt;JSON Response&lt;/b&gt;&lt;br&gt;{success: true,&lt;br&gt;data: [{value, type, ...}],&lt;br&gt;count, timestamp}&lt;br&gt;&lt;br&gt;Content-Type: application/json&lt;br&gt;&lt;i&gt;Trả JSON trực tiếp&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="610" y="325" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ee3" value="json" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="e_d1" target="e_json" parent="1" />

        <!-- TXT format -->
        <mxCell id="e_txt" value="&lt;b&gt;TXT File Download&lt;/b&gt;&lt;br&gt;One domain per line&lt;br&gt;&lt;br&gt;Content-Type: text/plain&lt;br&gt;Content-Disposition:&lt;br&gt;&amp;nbsp;&amp;nbsp;attachment; filename=&lt;br&gt;&amp;nbsp;&amp;nbsp;&quot;whitelist_export_YYYY...&quot;&lt;br&gt;&lt;i&gt;Tải file text&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="830" y="320" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ee4" value="txt" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="e_d1" target="e_txt" parent="1" />

        <!-- Divider -->
        <mxCell id="divider" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="565" y="70" as="sourcePoint" />
            <mxPoint x="565" y="640" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Data flow diagram -->
        <mxCell id="df_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="500" width="450" height="130" as="geometry" />
        </mxCell>
        <mxCell id="df_title" value="&lt;b&gt;Import Formats Supported / Định dạng import hỗ trợ&lt;/b&gt;" style="text;html=1;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="505" width="290" height="20" as="geometry" />
        </mxCell>
        <mxCell id="df" value="&lt;pre style='font-size:9px;margin:2px'&gt;// Format 1: Array of strings (auto-detect type)&lt;br&gt;{&quot;domains&quot;: [&quot;google.com&quot;, &quot;192.168.1.0/24&quot;, &quot;*.edu.vn&quot;]}&lt;br&gt;&lt;br&gt;// Format 2: Array of objects (explicit type)&lt;br&gt;{&quot;domains&quot;: [{&quot;value&quot;: &quot;google.com&quot;, &quot;type&quot;: &quot;domain&quot;},&lt;br&gt;              {&quot;value&quot;: &quot;10.0.0.0/8&quot;, &quot;type&quot;: &quot;ip&quot;}]}&lt;br&gt;&lt;br&gt;// Format 3: Mixed&lt;br&gt;{&quot;domains&quot;: [&quot;google.com&quot;, {&quot;value&quot;: &quot;*.edu&quot;, &quot;type&quot;: &quot;pattern&quot;}]}&lt;/pre&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="595" y="530" width="420" height="90" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
