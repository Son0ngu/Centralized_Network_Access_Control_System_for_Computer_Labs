<mxfile host="app.diagrams.net" modified="2026-03-23" agent="Claude" version="24.0.0" type="device">
  <diagram id="token-verify" name="Agent Token Verify Flow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Flow 4: Agent Token Verify&lt;/b&gt;&lt;br&gt;POST /api/auth/verify&lt;br&gt;&lt;i&gt;Luồng xác thực token Agent&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="100" width="100" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;Request&lt;/b&gt;&lt;br&gt;{token: &quot;eyJ...&quot;, token_type: &quot;access|refresh&quot;}&lt;br&gt;&lt;i&gt;Gửi token cần kiểm tra&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="180" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="s1" parent="1" />

        <mxCell id="d1" value="&lt;b&gt;token present?&lt;/b&gt;&lt;br&gt;&lt;i&gt;Có token?&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="485" y="275" width="110" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s1" target="d1" parent="1" />

        <mxCell id="err400" value="&lt;b&gt;400&lt;/b&gt; &quot;token is required&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="710" y="285" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;" edge="1" source="d1" target="err400" parent="1" />

        <!-- Token type decision -->
        <mxCell id="d2" value="&lt;b&gt;token_type?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="380" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;" edge="1" source="d1" target="d2" parent="1" />

        <mxCell id="s_access" value="&lt;b&gt;validate_access_token()&lt;/b&gt;&lt;br&gt;Decode with JWT_SECRET_KEY&lt;br&gt;Check type==&quot;access&quot;&lt;br&gt;Check NOT revoked&lt;br&gt;&lt;i&gt;Xác thực access token&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="490" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="access" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=11;" edge="1" source="d2" target="s_access" parent="1" />

        <mxCell id="s_refresh" value="&lt;b&gt;validate_refresh_token()&lt;/b&gt;&lt;br&gt;Decode with JWT_REFRESH_SECRET_KEY&lt;br&gt;Check type==&quot;refresh&quot;&lt;br&gt;Check NOT revoked&lt;br&gt;&lt;i&gt;Xác thực refresh token&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="490" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="refresh" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=11;" edge="1" source="d2" target="s_refresh" parent="1" />

        <!-- Valid decision -->
        <mxCell id="d3" value="&lt;b&gt;Valid?&lt;/b&gt;&lt;br&gt;&lt;i&gt;Hợp lệ?&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="620" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_access" target="d3" parent="1" />
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_refresh" target="d3" parent="1" />

        <!-- Valid response -->
        <mxCell id="resp_valid" value="&lt;b&gt;200 OK&lt;/b&gt; {valid: true}&lt;br&gt;{agent_id, user_id, token_type, expires_at}&lt;br&gt;&lt;i&gt;Token hợp lệ - trả thông tin&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="730" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;" edge="1" source="d3" target="resp_valid" parent="1" />

        <!-- Invalid response -->
        <mxCell id="resp_invalid" value="&lt;b&gt;200 OK&lt;/b&gt; {valid: false}&lt;br&gt;{error: &quot;expired|revoked|invalid&quot;}&lt;br&gt;&lt;i&gt;Token không hợp lệ&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="590" y="730" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;" edge="1" source="d3" target="resp_invalid" parent="1" />

        <mxCell id="end" value="End" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="840" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="resp_valid" target="end" parent="1" />
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="resp_invalid" target="end" parent="1" />

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
