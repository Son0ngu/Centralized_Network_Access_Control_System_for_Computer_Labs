<mxfile host="app.diagrams.net" modified="2026-03-23" agent="Claude" version="24.0.0" type="device">
  <diagram id="heartbeat" name="Agent Heartbeat Flow">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Flow 9: Agent Heartbeat&lt;/b&gt;&lt;br&gt;POST /api/agents/heartbeat (every 20s)&lt;br&gt;&lt;i&gt;Luồng nhịp tim Agent - giữ kết nối sống&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="450" y="15" width="380" height="55" as="geometry" />
        </mxCell>

        <!-- Config -->
        <mxCell id="config_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="config" value="&lt;b&gt;Configuration / Cấu hình&lt;/b&gt;&lt;br&gt;&lt;br&gt;HEARTBEAT_INTERVAL = &lt;b&gt;20s&lt;/b&gt;&lt;br&gt;TIMEOUT = &lt;b&gt;10s&lt;/b&gt;&lt;br&gt;RETRY_INTERVAL = &lt;b&gt;5s&lt;/b&gt;&lt;br&gt;MAX_CONSECUTIVE_FAILURES = &lt;b&gt;3&lt;/b&gt;" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="210" height="100" as="geometry" />
        </mxCell>

        <!-- Swimlanes -->
        <mxCell id="lane_agent" value="&lt;b&gt;🖥️ AGENT&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="210" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lane_server" value="&lt;b&gt;🌐 SERVER&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="210" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lane_dash" value="&lt;b&gt;📊 DASHBOARD&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="210" width="150" height="30" as="geometry" />
        </mxCell>

        <!-- Dividers -->
        <mxCell id="div1" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#ccc;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="210" as="sourcePoint" /><mxPoint x="420" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="div2" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#ccc;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="920" y="210" as="sourcePoint" /><mxPoint x="920" y="1250" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Agent: heartbeat loop start -->
        <mxCell id="a_loop" value="&lt;b&gt;♻️ _heartbeat_loop()&lt;/b&gt;&lt;br&gt;Daemon thread&lt;br&gt;&lt;i&gt;Luồng nền chạy liên tục&lt;/i&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="265" width="160" height="55" as="geometry" />
        </mxCell>

        <!-- Collect metrics -->
        <mxCell id="a_metrics" value="&lt;b&gt;Collect metrics&lt;/b&gt;&lt;br&gt;{agent_id, device_id, timestamp,&lt;br&gt;metrics: {memory%, disk%, uptime},&lt;br&gt;status, platform, os_info, version}&lt;br&gt;&lt;i&gt;Thu thập thông tin hệ thống&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="65" y="350" width="230" height="75" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_loop" target="a_metrics" parent="1" />

        <!-- Send heartbeat -->
        <mxCell id="a_send" value="&lt;b&gt;POST /api/agents/heartbeat&lt;/b&gt;&lt;br&gt;Header: Bearer JWT&lt;br&gt;Timeout: 10s&lt;br&gt;&lt;i&gt;Gửi heartbeat tới server&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="95" y="460" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_metrics" target="a_send" parent="1" />

        <!-- Arrow to server -->
        <mxCell id="e_req" value="JWT + heartbeat data" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=9;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="265" y="490" as="sourcePoint" />
            <mxPoint x="530" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Server: validate -->
        <mxCell id="s_jwt" value="&lt;b&gt;@require_jwt&lt;/b&gt;&lt;br&gt;Validate access_token&lt;br&gt;&lt;i&gt;Xác thực JWT&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="470" width="160" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s_d1" value="&lt;b&gt;Valid?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="545" width="80" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_jwt" target="s_d1" parent="1" />

        <mxCell id="s_err" value="&lt;b&gt;401&lt;/b&gt; Token expired" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="550" width="130" height="35" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=10;" edge="1" source="s_d1" target="s_err" parent="1" />

        <!-- Process heartbeat -->
        <mxCell id="s_process" value="&lt;b&gt;AgentService.process_heartbeat()&lt;/b&gt;&lt;br&gt;1. Find agent by agent_id&lt;br&gt;2. Validate token matches&lt;br&gt;3. Validate device_id consistency&lt;br&gt;4. Parse timestamp → Vietnam TZ&lt;br&gt;&lt;i&gt;Xử lý heartbeat&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="635" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=10;" edge="1" source="s_d1" target="s_process" parent="1" />

        <!-- Update DB -->
        <mxCell id="s_update" value="&lt;b&gt;model.update_heartbeat()&lt;/b&gt;&lt;br&gt;{client_ip, metrics, status: &quot;active&quot;,&lt;br&gt;last_heartbeat, platform, os_info}&lt;br&gt;&lt;i&gt;Cập nhật DB&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="755" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_process" target="s_update" parent="1" />

        <!-- SocketIO emit -->
        <mxCell id="s_socket" value="&lt;b&gt;SocketIO.emit(&quot;agent_heartbeat&quot;)&lt;/b&gt;&lt;br&gt;{agent_id, hostname, status,&lt;br&gt;last_heartbeat, metrics, group_id}&lt;br&gt;&lt;i&gt;Phát sóng realtime&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="850" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_update" target="s_socket" parent="1" />

        <!-- Arrow to dashboard -->
        <mxCell id="e_socket" value="WebSocket event" style="endArrow=classic;html=1;strokeColor=#d6b656;strokeWidth=2;fontSize=9;fontStyle=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="740" y="880" as="sourcePoint" />
            <mxPoint x="1080" y="880" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Dashboard update -->
        <mxCell id="dash" value="&lt;b&gt;Dashboard updates&lt;/b&gt;&lt;br&gt;Agent status → green dot&lt;br&gt;Metrics refresh&lt;br&gt;Last seen timestamp&lt;br&gt;&lt;i&gt;Dashboard cập nhật realtime&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="855" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Server response -->
        <mxCell id="s_resp" value="&lt;b&gt;200 OK&lt;/b&gt;&lt;br&gt;{agent_id, status: &quot;active&quot;,&lt;br&gt;next_heartbeat, server_time}&lt;br&gt;&lt;i&gt;Xác nhận nhận heartbeat&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="945" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_socket" target="s_resp" parent="1" />

        <!-- Response arrow back -->
        <mxCell id="e_resp" value="200 OK" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=9;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="530" y="975" as="sourcePoint" />
            <mxPoint x="265" y="975" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Agent: handle response -->
        <mxCell id="a_d1" value="&lt;b&gt;Success?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="950" width="80" height="55" as="geometry" />
        </mxCell>

        <!-- Success: sleep 20s -->
        <mxCell id="a_ok" value="&lt;b&gt;Reset failure counter&lt;/b&gt;&lt;br&gt;consecutive_failures = 0&lt;br&gt;Sleep &lt;b&gt;20s&lt;/b&gt;&lt;br&gt;&lt;i&gt;Chờ 20 giây rồi gửi lại&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="1040" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=10;" edge="1" source="a_d1" target="a_ok" parent="1" />

        <!-- Failure: retry -->
        <mxCell id="a_fail" value="&lt;b&gt;consecutive_failures++&lt;/b&gt;&lt;br&gt;if ≥ 3: log error&lt;br&gt;Sleep &lt;b&gt;5s&lt;/b&gt; (retry faster)&lt;br&gt;&lt;i&gt;Thử lại nhanh hơn khi lỗi&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="1040" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=10;" edge="1" source="a_d1" target="a_fail" parent="1" />

        <!-- Loop back arrows -->
        <mxCell id="e_loop1" value="♻️ repeat" style="endArrow=classic;html=1;strokeColor=#82b366;curved=1;fontSize=9;" edge="1" source="a_ok" target="a_metrics" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_loop2" value="♻️ retry" style="endArrow=classic;html=1;strokeColor=#b85450;curved=1;fontSize=9;" edge="1" source="a_fail" target="a_metrics" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Status thresholds -->
        <mxCell id="status_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1030" y="260" width="280" height="150" as="geometry" />
        </mxCell>
        <mxCell id="status_title" value="&lt;b&gt;Status Thresholds / Ngưỡng trạng thái&lt;/b&gt;" style="text;html=1;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1055" y="265" width="230" height="25" as="geometry" />
        </mxCell>
        <mxCell id="st_active" value="🟢 &lt;b&gt;ACTIVE&lt;/b&gt;: ≤ 5 min since heartbeat&lt;br&gt;&lt;i&gt;Đang hoạt động&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1045" y="295" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="st_inactive" value="🟡 &lt;b&gt;INACTIVE&lt;/b&gt;: 5-30 min since heartbeat&lt;br&gt;&lt;i&gt;Không hoạt động&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1045" y="335" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="st_offline" value="🔴 &lt;b&gt;OFFLINE&lt;/b&gt;: &gt; 30 min since heartbeat&lt;br&gt;&lt;i&gt;Ngoại tuyến&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1045" y="375" width="250" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
