        <mxCell id="s1_step2" value="&lt;b&gt;Step 2: Cascade&lt;/b&gt;&lt;hr&gt;① Active? → &lt;b style='color:#2e7d32'&gt;YES ✅&lt;/b&gt;&lt;br&gt;&quot;Bài thực hành Python&quot;&lt;br&gt;② ❌ Skip Default&lt;br&gt;③ ❌ Skip Legacy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=6;strokeWidth=2;" vertex="1" parent="1">
