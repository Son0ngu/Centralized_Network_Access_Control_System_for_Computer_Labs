        <mxCell id="s2_policy" value="&lt;b style='font-size:14px'&gt;Step 4: Policy&lt;/b&gt;&lt;hr&gt;A2.policy =&lt;br&gt;&lt;b style='color:#c62828;font-size:16px'&gt;&quot;ISOLATE&quot;&lt;/b&gt;&lt;hr&gt;&lt;b style='color:#c62828'&gt;entries = system_entries ONLY&lt;br&gt;8 merged entries → XÓA HẾT!&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="290" y="1330" width="220" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="s2_result" value="&lt;b&gt;🔒 A2 Firewall (ISOLATED):&lt;/b&gt;&lt;hr&gt;DEFAULT DENY + CHỈ:&lt;br&gt;✅ Server IP (heartbeat+sync)&lt;br&gt;✅ 8.8.8.8, 8.8.4.4, 1.1.1.1 (DNS)&lt;hr&gt;&lt;b style='color:#c62828;font-size:12px'&gt;❌ TẤT CẢ WEBSITE CHẶN&lt;/b&gt;&lt;br&gt;❌ google, python, replit, github...&lt;hr&gt;&lt;i&gt;Cùng Group A nhưng A1=8 entries, A2=0!&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;align=left;spacingLeft=6;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="560" y="1330" width="280" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="s2_explain" value="&lt;b&gt;Isolate dùng khi:&lt;/b&gt;&lt;br&gt;• Thi cử (chặn internet)&lt;br&gt;• PC bị virus/malware&lt;br&gt;• Kỷ luật học sinh&lt;hr&gt;&lt;b&gt;Tại sao giữ system IPs?&lt;/b&gt;&lt;br&gt;→ Để agent vẫn heartbeat&lt;br&gt;→ Nhận lệnh GỠ isolate&lt;br&gt;→ Nếu chặn cả → DEADLOCK!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="880" y="1335" width="220" height="175" as="geometry"/>
        </mxCell>

        <!-- A1 vs A2 comparison -->
        <mxCell id="s2_compare" value="&lt;b&gt;⚡ A1 vs A2 (CÙNG GROUP A!)&lt;/b&gt;&lt;hr&gt;&lt;table style='font-size:10px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;&lt;/th&gt;&lt;th style='background:#e8f5e9;padding:4px;border:1px solid #ccc'&gt;A1 (none)&lt;/th&gt;&lt;th style='background:#ffebee;padding:4px;border:1px solid #ccc'&gt;A2 (isolate)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Group&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;A&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;A (giống!)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Profile&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Active ✅&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Active (giống!)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Merged&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;8&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;8 (giống!)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;After policy&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;&lt;b&gt;8 ✅&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;&lt;b&gt;0 ❌&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;google?&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#616161;fontSize=10;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1140" y="1330" width="320" height="210" as="geometry"/>
