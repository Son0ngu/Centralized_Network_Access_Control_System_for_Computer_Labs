        <mxCell id="s2a2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#c62828;" edge="1" source="s2_policy_detail" target="s2_resp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2a3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#c62828;" edge="1" source="s2_resp" target="s2_fw" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 3: A3 — CUSTOM WHITELIST                            -->
        <!-- ============================================================ -->
        <mxCell id="s3bg" value="" style="rounded=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1220" width="1950" height="450" as="geometry"/>
        </mxCell>
        <mxCell id="s3t" value="&lt;b&gt;SCENARIO 3: Agent A3 (PC-03) — CUNG GROUP A nhung policy=custom_whitelist → CHI 2 trang + system&lt;/b&gt;&lt;br&gt;&lt;i&gt;Teacher cho A3 on thi: chi duoc xem docs.python.org va w3schools.com. Khong het han (go thu cong).&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#e65100;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="1228" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s3_policy_detail" value="&lt;b style='font-size:14px'&gt;Step 7: APPLY POLICY&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px;text-align:left'&gt;effective = get_effective_mode(&quot;agent_a3&quot;)&#10;// Found: {override_mode: &quot;custom_whitelist&quot;,&#10;//  custom_whitelist: [&#10;//    {domain:&quot;docs.python.org&quot;},&#10;//    {domain:&quot;w3schools.com&quot;}&#10;//  ],&#10;//  expires_at: null}  // KHONG het han&#10;&#10;// DISCARD 8 merged entries!&#10;system = _build_system_entries()&#10;custom = policy.custom_whitelist&#10;&#10;return {&#10;  domains: system + custom,  // 4 + 2 = 6&#10;  policy_mode: &quot;custom_whitelist&quot;,&#10;  policy_active: true&#10;}&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=3;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="50" y="1280" width="380" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="s3_fw" value="&lt;b&gt;WINDOWS FIREWALL (A3):&lt;/b&gt;&lt;hr&gt;&lt;b style='color:#2e7d32'&gt;ALLOWED (6 entries):&lt;/b&gt;&lt;br&gt;✅ 192.168.1.100 (server)&lt;br&gt;✅ 8.8.8.8, 8.8.4.4, 1.1.1.1 (DNS)&lt;br&gt;✅ &lt;b&gt;docs.python.org&lt;/b&gt; (custom)&lt;br&gt;✅ &lt;b&gt;w3schools.com&lt;/b&gt; (custom)&lt;hr&gt;&lt;b style='color:#c62828'&gt;BLOCKED — bao gom ca:&lt;/b&gt;&lt;br&gt;❌ google.com (du la global!)&lt;br&gt;❌ replit.com (du profile co!)&lt;br&gt;❌ github.com (du profile co!)&lt;br&gt;❌ stackoverflow.com&lt;br&gt;❌ youtube, facebook..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="470" y="1280" width="280" height="270" as="geometry"/>
        </mxCell>

        <mxCell id="s3_compare" value="&lt;b style='font-size:13px'&gt;A1 vs A2 vs A3 — CUNG GROUP A!&lt;/b&gt;&lt;hr&gt;&lt;table style='font-size:10px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;URL&lt;/th&gt;&lt;th style='background:#c8e6c9;padding:4px;border:1px solid #ccc'&gt;A1 (none)&lt;/th&gt;&lt;th style='background:#ffcdd2;padding:4px;border:1px solid #ccc'&gt;A2 (isolate)&lt;/th&gt;&lt;th style='background:#fff3e0;padding:4px;border:1px solid #ccc'&gt;A3 (custom)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;google.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;docs.python.org&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅ (profile)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅ (custom)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;w3schools.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅ (custom)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;replit.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅ (profile)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;github.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅ (profile)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;youtube.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#e0e0e0'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;Total allowed&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;8&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;0 (+4 sys)&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;2 (+4 sys)&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#616161;fontSize=10;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="790" y="1280" width="420" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="s3_note" value="&lt;b&gt;Key Insight:&lt;/b&gt;&lt;br&gt;• A3 co &lt;b&gt;docs.python&lt;/b&gt; trong CA HAI profile va custom&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Nhung no duoc phep vi nam trong custom list&lt;br&gt;&amp;nbsp;&amp;nbsp;→ KHONG phai vi profile (profile bi discard!)&lt;br&gt;&lt;br&gt;• A1 co &lt;b&gt;w3schools&lt;/b&gt; = BLOCKED&lt;br&gt;&amp;nbsp;&amp;nbsp;(khong co trong profile &quot;Bai thuc hanh&quot;)&lt;br&gt;• A3 co &lt;b&gt;w3schools&lt;/b&gt; = ALLOWED&lt;br&gt;&amp;nbsp;&amp;nbsp;(co trong custom list!)&lt;br&gt;&lt;br&gt;• &lt;b style='color:#e65100'&gt;expires_at = null&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Khong tu het han&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Teacher phai go thu cong:&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;policy_service.reset_agent()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1250" y="1280" width="310" height="260" as="geometry"/>
        </mxCell>

        <!-- S3 arrows -->
        <mxCell id="s3a1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#e65100;" edge="1" source="s3_policy_detail" target="s3_fw" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 4: A4 — UP TO DATE (SKIP)                           -->
        <!-- ============================================================ -->
        <mxCell id="s4bg" value="" style="rounded=1;fillColor=#e8eaf6;strokeColor=#3f51b5;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1700" width="1950" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="s4t" value="&lt;b&gt;SCENARIO 4: Agent A4 (PC-04) — CUNG GROUP A, policy=none, nhung DA CAP NHAT → up_to_date=true → SKIP&lt;/b&gt;&lt;br&gt;&lt;i&gt;A4 da sync thanh cong truoc do (g=5, grp=12 = trung server). Server tra ve response nho, agent khong lam gi.&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#1a237e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="1708" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s4_http" value="&lt;b&gt;HTTP REQUEST:&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:8px'&gt;GET /agent-sync&#10;  ?agent_id=agent_a4&#10;  &amp;amp;global_version=5   ← trung!&#10;  &amp;amp;group_version=12  ← trung!&#10;  &amp;amp;policy_mode=none&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5cae9;strokeColor=#3f51b5;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="1760" width="220" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="s4_server" value="&lt;b&gt;SERVER: Short-circuit!&lt;/b&gt;&lt;hr&gt;1. Policy: &quot;none&quot; (khong doi)&lt;br&gt;2. Version: g=5==5, grp=12==12&lt;br&gt;&lt;b style='color:#3f51b5;font-size:14px'&gt;→ up_to_date = true!&lt;/b&gt;&lt;br&gt;&lt;br&gt;KHONG query DB&lt;br&gt;KHONG load global entries&lt;br&gt;KHONG resolve profile&lt;br&gt;KHONG merge&lt;br&gt;KHONG apply policy&lt;br&gt;&lt;b&gt;→ Tra ve ngay lap tuc!&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5cae9;strokeColor=#3f51b5;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="1760" width="250" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="s4_resp" value="&lt;b&gt;RESPONSE (nho!):&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:8px'&gt;{&#10; &quot;domains&quot;: [],  // RONG!&#10; &quot;up_to_date&quot;: true,&#10; &quot;global_version&quot;: 5,&#10; &quot;group_version&quot;: 12,&#10; &quot;type&quot;: &quot;versioned&quot;&#10;}&lt;/pre&gt;&lt;br&gt;&lt;b&gt;Agent: state.update()&lt;/b&gt;&lt;br&gt;→ up_to_date=true&lt;br&gt;→ return False (no change)&lt;br&gt;→ SKIP firewall update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="600" y="1760" width="250" height="210" as="geometry"/>
        </mxCell>

        <!-- S4 arrows -->
        <mxCell id="s4a1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#3f51b5;" edge="1" source="s4_http" target="s4_server" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s4a2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#3f51b5;" edge="1" source="s4_server" target="s4_resp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- GRAND SUMMARY FOR GROUP A -->
        <mxCell id="ga_sum" value="&lt;b style='font-size:16px'&gt;TONG KET GROUP A: 4 agent, 1 group, 1 profile → 4 ket qua hoan toan khac&lt;/b&gt;&lt;hr&gt;&lt;table style='font-size:11px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;Agent&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;Policy&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;Entries&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;google?&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;docs.python?&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;w3schools?&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;youtube?&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:5px;border:1px solid #ccc'&gt;Ly do&lt;/th&gt;&lt;/tr&gt;&lt;tr style='background:#e8f5e9'&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;A1&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;none&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;8&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Binh thuong, theo profile&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#ffebee'&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;A2&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;isolate&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;0+4sys&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Bi phat vi xem YouTube&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#fff3e0'&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;A3&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;custom&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;2+4sys&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;On thi, chi xem tai lieu&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#e8eaf6'&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;A4&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;none&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;skip&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;❌&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Da sync truoc do, skip&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#616161;fontSize=10;verticalAlign=top;spacingTop=5;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="900" y="1750" width="960" height="230" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ================================================================== -->
  <!-- PAGE 3: CROSS-GROUP + DYNAMIC SCENARIOS                            -->
  <!-- ================================================================== -->
  <diagram id="page3-cross" name="3. Cross-Group + Dynamic Changes">
    <mxGraphModel dx="2200" dy="4800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2200" pageHeight="4800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t3" value="&lt;b style='font-size:20px'&gt;Cross-Group Scenarios + Dynamic Changes&lt;/b&gt;&lt;br&gt;&lt;i&gt;B1 (Default fallback), C1 (Legacy fallback), D1 (Pending/no group), Group Change, Profile Switch&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="1200" height="50" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 5: B1 — DEFAULT PROFILE FALLBACK                    -->
        <!-- ============================================================ -->
        <mxCell id="s5bg" value="" style="rounded=1;fillColor=#fff9c4;strokeColor=#f57f17;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="1950" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="s5t" value="&lt;b&gt;SCENARIO 5: Agent B1 (PC-05) — Group B &quot;Ngoai ngu&quot; — KHONG Active Profile → Fallback sang Default Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Teacher chua activate profile nao. System tim Default Profile (is_default=true) → dung domains cua Default.&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#e65100;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="88" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s5_server" value="&lt;b&gt;SERVER PROCESSING:&lt;/b&gt;&lt;hr&gt;1. Agent B1 → group_id=&quot;grpB&quot;&lt;br&gt;2. Policy: no record → &quot;none&quot;&lt;br&gt;3. Version: g=5==5, &lt;b&gt;grp=6!=8&lt;/b&gt; → CHANGED&lt;br&gt;4. Full sync: 5 global entries&lt;br&gt;5. Profile cascade:&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;a) Active? → &lt;b style='color:#c62828'&gt;NO (khong co is_active=true)&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;b) Default? → &lt;b style='color:#2e7d32'&gt;YES! &quot;Hoc online co ban&quot;&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ domains: duolingo, cambridge,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;merriam-webster, bbc.co.uk/learning&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;c) Legacy? → SKIP (da co Default)&lt;br&gt;6. Merge: 5 global + 4 default = &lt;b&gt;9 entries&lt;/b&gt;&lt;br&gt;7. Policy: &quot;none&quot; → keep 9" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="135" width="380" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="s5_fw" value="&lt;b&gt;B1 FIREWALL (9 entries):&lt;/b&gt;&lt;hr&gt;&lt;b style='color:#2e7d32'&gt;ALLOWED:&lt;/b&gt;&lt;br&gt;✅ google.com (global)&lt;br&gt;✅ wikipedia.org (global)&lt;br&gt;✅ *.edu.vn (global)&lt;br&gt;✅ &lt;b&gt;duolingo.com&lt;/b&gt; (Default profile)&lt;br&gt;✅ &lt;b&gt;cambridge.org&lt;/b&gt; (Default profile)&lt;br&gt;✅ &lt;b&gt;merriam-webster.com&lt;/b&gt;&lt;br&gt;✅ &lt;b&gt;bbc.co.uk/learning&lt;/b&gt;&lt;hr&gt;&lt;b style='color:#c62828'&gt;BLOCKED:&lt;/b&gt;&lt;br&gt;❌ docs.python.org (Group A only!)&lt;br&gt;❌ replit.com (Group A only!)&lt;br&gt;❌ youtube, facebook, tiktok" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="470" y="135" width="280" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="s5_vs" value="&lt;b&gt;A1 (Group A) vs B1 (Group B):&lt;/b&gt;&lt;hr&gt;&lt;table style='font-size:10px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;URL&lt;/th&gt;&lt;th style='background:#e3f2fd;padding:3px;border:1px solid #ccc'&gt;A1&lt;/th&gt;&lt;th style='background:#fff9c4;padding:3px;border:1px solid #ccc'&gt;B1&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;Tai sao?&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;google.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;✅&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Global — ca 2 co&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;docs.python.org&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Chi trong Active Profile A&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;duolingo.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;✅&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Chi trong Default Profile B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;youtube.com&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Khong group nao co&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;Key: Group entries chi anh huong agent TRONG group do.&lt;br&gt;Global entries anh huong TAT CA agent.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#616161;fontSize=10;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="790" y="135" width="430" height="290" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 6: C1 — LEGACY FALLBACK                             -->
        <!-- ============================================================ -->
        <mxCell id="s6bg" value="" style="rounded=1;fillColor=#fce4ec;strokeColor=#880e4f;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="510" width="1950" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="s6t" value="&lt;b&gt;SCENARIO 6: Agent C1 (PC-10) — Group C &quot;Phong may tu do&quot; — KHONG PROFILE NAO → Legacy group.whitelist[]&lt;/b&gt;&lt;br&gt;&lt;i&gt;Group C chua co teacher tao profile. Fallback chain: Active=NO → Default=NO → Legacy=group.whitelist[].&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#880e4f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="518" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s6_server" value="&lt;b&gt;SERVER PROCESSING:&lt;/b&gt;&lt;hr&gt;5. Profile cascade:&lt;br&gt;&amp;nbsp;&amp;nbsp;a) Active? → &lt;b style='color:#c62828'&gt;NO&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;b) Default? → &lt;b style='color:#c62828'&gt;NO (khong co profile nao!)&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;c) Legacy? → &lt;b style='color:#2e7d32'&gt;YES!&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ group.whitelist = [youtube, facebook, tiktok]&lt;br&gt;6. Merge: 5 global + 3 legacy = &lt;b&gt;8 entries&lt;/b&gt;&lt;br&gt;7. Policy: &quot;none&quot; → keep 8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="565" width="380" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="s6_fw" value="&lt;b&gt;C1 FIREWALL (8 entries):&lt;/b&gt;&lt;hr&gt;✅ google, wikipedia, *.edu.vn, 10.0.0.0/24, stackoverflow&lt;br&gt;✅ &lt;b&gt;youtube.com&lt;/b&gt; (legacy!)&lt;br&gt;✅ &lt;b&gt;facebook.com&lt;/b&gt; (legacy!)&lt;br&gt;✅ &lt;b&gt;tiktok.com&lt;/b&gt; (legacy!)&lt;hr&gt;❌ docs.python.org (A only)&lt;br&gt;❌ duolingo.com (B only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="470" y="565" width="280" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="s6_note" value="&lt;b&gt;Tai sao C1 co youtube nhung A1 khong?&lt;/b&gt;&lt;hr&gt;• A1 thuoc Group A (Tin hoc)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Active Profile: KHONG co youtube&lt;br&gt;&amp;nbsp;&amp;nbsp;→ youtube bi BLOCKED&lt;br&gt;&lt;br&gt;• C1 thuoc Group C (Tu do)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Legacy whitelist CO youtube&lt;br&gt;&amp;nbsp;&amp;nbsp;→ youtube duoc ALLOWED&lt;br&gt;&lt;br&gt;&lt;b style='color:#880e4f'&gt;Moi group co whitelist rieng.&lt;br&gt;Agent chi nhan whitelist cua GROUP minh.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#616161;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="790" y="565" width="340" height="220" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 7: D1 — NEW AGENT, NO GROUP                         -->
        <!-- ============================================================ -->
        <mxCell id="s7bg" value="" style="rounded=1;fillColor=#e8eaf6;strokeColor=#283593;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="890" width="1950" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="s7t" value="&lt;b&gt;SCENARIO 7: Agent D1 (PC-NEW) — Moi cai, group_id=None → Tu dong vao Pending Group → Chi co Global&lt;/b&gt;&lt;br&gt;&lt;i&gt;Agent moi chua duoc admin gan group. Server auto-assign vao pending system group (whitelist=[] rong).&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#1a237e;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="898" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s7_server" value="&lt;b&gt;SERVER PROCESSING:&lt;/b&gt;&lt;hr&gt;1. Agent D1 → &lt;b&gt;group_id = None&lt;/b&gt;&lt;br&gt;2. group = find_by_id(None) → null&lt;br&gt;3. &lt;b style='color:#283593'&gt;group = ensure_pending_group()&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;→ find_one_and_update (atomic upsert)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ {name:&quot;pending&quot;, is_system:true, whitelist:[]}&lt;br&gt;4. &lt;b&gt;agent.group_id = pending._id&lt;/b&gt; (save!)&lt;br&gt;5. Profile cascade: NO profiles, whitelist=[]&lt;br&gt;6. Merge: 5 global + 0 = &lt;b&gt;5 entries (global only)&lt;/b&gt;&lt;br&gt;7. Policy: &quot;none&quot; → keep 5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#283593;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="945" width="400" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="s7_fw" value="&lt;b&gt;D1 FIREWALL (5 entries):&lt;/b&gt;&lt;hr&gt;✅ google, wikipedia, *.edu.vn,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;10.0.0.0/24, stackoverflow&lt;br&gt;&lt;br&gt;❌ Khong co group-specific nao&lt;br&gt;❌ youtube, facebook, tiktok&lt;br&gt;❌ docs.python, replit, duolingo&lt;hr&gt;&lt;i&gt;Khi admin gan D1 vao Group A:&lt;br&gt;→ Next sync: group_id change detected!&lt;br&gt;→ Force full sync&lt;br&gt;→ Nhan them 4 profile entries&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#283593;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="490" y="945" width="300" height="230" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 8: GROUP CHANGE                                      -->
        <!-- ============================================================ -->
        <mxCell id="s8bg" value="" style="rounded=1;fillColor=#e0f2f1;strokeColor=#00695c;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1270" width="1950" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="s8t" value="&lt;b&gt;SCENARIO 8: Agent D1 duoc CHUYEN tu Pending → Group A (Group Change Detection)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Admin gan D1 vao Group A. Lan sync tiep theo: state.py detect group_id thay doi → force full sync → nhan profile moi.&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#00695c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="1278" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s8_before" value="&lt;b&gt;D1 STATE BEFORE:&lt;/b&gt;&lt;hr&gt;_domains: {google, wiki, SO}&lt;br&gt;_group_id: &quot;pending&quot;&lt;br&gt;_version: &quot;5&quot;&lt;br&gt;_group_version: &quot;1&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2dfdb;strokeColor=#00695c;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="1330" width="200" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="s8_admin" value="&lt;b&gt;ADMIN ACTION:&lt;/b&gt;&lt;hr&gt;PATCH /api/agents/D1/group&lt;br&gt;{group_id: &quot;grpA&quot;}&lt;br&gt;&lt;br&gt;→ Agent D1.group_id = &quot;grpA&quot;&lt;br&gt;→ SocketIO: agent_group_updated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="290" y="1330" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="s8_sync" value="&lt;b&gt;D1 NEXT SYNC (60s later):&lt;/b&gt;&lt;hr&gt;Server responds:&lt;br&gt;group_id = &quot;grpA&quot; (NEW!)&lt;br&gt;group_version = 12&lt;br&gt;&lt;br&gt;&lt;b&gt;state.py:update():&lt;/b&gt;&lt;br&gt;new_group_id = &quot;grpA&quot;&lt;br&gt;self._group_id = &quot;pending&quot;&lt;br&gt;&lt;b style='color:#00695c;font-size:13px'&gt;GROUP CHANGED!&lt;/b&gt;&lt;br&gt;→ sync_type = &quot;full&quot; (forced)&lt;br&gt;→ bypass up_to_date check&lt;br&gt;→ REPLACE entire state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2f1;strokeColor=#00695c;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="570" y="1330" width="280" height="230" as="geometry"/>
        </mxCell>

        <mxCell id="s8_after" value="&lt;b&gt;D1 STATE AFTER:&lt;/b&gt;&lt;hr&gt;_domains: {google, wiki, SO,&lt;br&gt;&amp;nbsp;&lt;b style='color:#2e7d32'&gt;+ docs.python, replit,&lt;br&gt;&amp;nbsp;+ github&lt;/b&gt;}&lt;br&gt;_group_id: &quot;grpA&quot; (NEW)&lt;br&gt;_version: &quot;5&quot;&lt;br&gt;_group_version: &quot;12&quot;&lt;br&gt;&lt;br&gt;&lt;b&gt;Firewall updated:&lt;/b&gt;&lt;br&gt;+3 new allow rules!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="890" y="1330" width="230" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="s8_code" value="&lt;b&gt;Bug #24 Fix — state.py:72-83&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px;text-align:left'&gt;new_group_id = str(data.get(&quot;group_id&quot;, &quot;&quot;))&#10;group_changed = (&#10;  self._group_id          # has old value&#10;  and new_group_id        # has new value&#10;  and new_group_id != self._group_id&#10;)&#10;&#10;if group_changed:&#10;  sync_type = &quot;full&quot;  # Force REPLACE&#10;  # Don't trust up_to_date!&#10;&#10;if up_to_date and not group_changed:&#10;  return False  # Only skip if NO change&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2f1;strokeColor=#00695c;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1330" width="350" height="230" as="geometry"/>
        </mxCell>

        <!-- S8 arrows -->
        <mxCell id="s8a1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="s8_before" target="s8_admin" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s8a2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="s8_admin" target="s8_sync" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s8a3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2e7d32;" edge="1" source="s8_sync" target="s8_after" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 9: PROFILE SWITCH                                    -->
        <!-- ============================================================ -->
        <mxCell id="s9bg" value="" style="rounded=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1730" width="1950" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="s9t" value="&lt;b&gt;SCENARIO 9: Teacher DEACTIVATE &quot;Bai thuc hanh&quot; → Agents A1,A4 fallback sang Default Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Teacher tat Active Profile. group_version tang. Next sync: agents nhan Default Profile thay vi Active.&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#7b1fa2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="1738" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s9_action" value="&lt;b&gt;TEACHER ACTION:&lt;/b&gt;&lt;hr&gt;POST /groups/grpA/profiles/&lt;id&gt;/deactivate&lt;br&gt;&lt;br&gt;profile_service.deactivate_profile():&lt;br&gt;1. Set is_active = false&lt;br&gt;2. &lt;b style='color:#7b1fa2'&gt;group_model.bump_whitelist_version()&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;→ grpA.whitelist_version: 12 → &lt;b&gt;13&lt;/b&gt;&lt;br&gt;3. SocketIO: whitelist_updated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7b1fa2;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1790" width="340" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="s9_before_agents" value="&lt;b&gt;A1 STATE BEFORE:&lt;/b&gt;&lt;br&gt;_group_version: &quot;12&quot;&lt;br&gt;_domains: {google,wiki,SO,&lt;br&gt;&amp;nbsp;&lt;b&gt;docs.python,replit,github&lt;/b&gt;}&lt;br&gt;(8 entries from Active Profile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="430" y="1790" width="260" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="s9_sync" value="&lt;b&gt;A1 NEXT SYNC:&lt;/b&gt;&lt;hr&gt;group_version: 12 != &lt;b&gt;13&lt;/b&gt; → CHANGED!&lt;br&gt;Full sync:&lt;br&gt;&lt;br&gt;Profile cascade:&lt;br&gt;a) Active? → &lt;b style='color:#c62828'&gt;NO (da deactivate!)&lt;/b&gt;&lt;br&gt;b) Default? → &lt;b style='color:#2e7d32'&gt;YES &quot;Mac dinh 10A&quot;&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;→ domains: python.org, w3schools&lt;br&gt;&lt;br&gt;Merge: 5 global + 2 default = &lt;b&gt;7 entries&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b style='color:#c62828'&gt;MAT: replit, github (Active only)&lt;br&gt;THEM: w3schools (Default only)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="730" y="1790" width="310" height="260" as="geometry"/>
        </mxCell>

        <mxCell id="s9_after" value="&lt;b&gt;A1 STATE AFTER:&lt;/b&gt;&lt;hr&gt;_group_version: &quot;13&quot;&lt;br&gt;_domains: {google, wiki, SO,&lt;br&gt;&amp;nbsp;&lt;b style='color:#c62828'&gt;- docs.python (REMOVED)&lt;br&gt;&amp;nbsp;- replit (REMOVED)&lt;br&gt;&amp;nbsp;- github (REMOVED)&lt;/b&gt;&lt;br&gt;&amp;nbsp;&lt;b style='color:#2e7d32'&gt;+ python.org (NEW)&lt;br&gt;&amp;nbsp;+ w3schools (NEW)&lt;/b&gt;}&lt;br&gt;&lt;br&gt;Firewall: remove 3 rules, add 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1080" y="1790" width="260" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="s9_note" value="&lt;b&gt;QUAN TRONG:&lt;/b&gt;&lt;hr&gt;1. A2 (isolate) khong bi anh huong&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Van bi isolate (policy ghi de profile)&lt;br&gt;&lt;br&gt;2. A3 (custom) khong bi anh huong&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Van chi co 2 custom domains&lt;br&gt;&lt;br&gt;3. CHI A1 va A4 (policy=none) bi anh huong&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Ho la nhung agent dung &quot;normal flow&quot;&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Profile change → version bump&lt;br&gt;&amp;nbsp;&amp;nbsp;→ version mismatch → full sync&lt;br&gt;&amp;nbsp;&amp;nbsp;→ nhan Default thay vi Active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1380" y="1790" width="300" height="250" as="geometry"/>
        </mxCell>

        <!-- S9 arrows -->
        <mxCell id="s9a1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#7b1fa2;" edge="1" source="s9_action" target="s9_before_agents" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s9a2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#7b1fa2;" edge="1" source="s9_before_agents" target="s9_sync" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s9a3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2e7d32;" edge="1" source="s9_sync" target="s9_after" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

