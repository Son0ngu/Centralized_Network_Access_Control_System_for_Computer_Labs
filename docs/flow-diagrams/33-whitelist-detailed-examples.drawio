        <mxCell id="s2_same" value="&lt;b&gt;Step 1-3: GIỐNG A1&lt;/b&gt;&lt;br&gt;Same cascade → Active&lt;br&gt;Same merge → 8 entries&lt;br&gt;&lt;b&gt;Đến đây = giống hệt&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;" vertex="1" parent="1">
