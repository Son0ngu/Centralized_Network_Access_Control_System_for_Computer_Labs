        <mxCell id="dbTitle" value="&lt;b&gt;A. MONGODB STATE — 5 Collections lien quan&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
