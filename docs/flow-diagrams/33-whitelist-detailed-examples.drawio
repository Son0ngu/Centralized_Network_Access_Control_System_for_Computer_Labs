        <!-- ============================================================ -->
        <!-- SCENARIO 2: A2 — ISOLATE (SAME GROUP!)                       -->
        <!-- ============================================================ -->
        <mxCell id="s2bg" value="" style="rounded=1;fillColor=#ffebee;strokeColor=#c62828;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="660" width="1950" height="530" as="geometry"/>
        </mxCell>
        <mxCell id="s2t" value="&lt;b&gt;SCENARIO 2: Agent A2 (PC-02) — CUNG GROUP A nhung policy=ISOLATE → CHAN HET&lt;/b&gt;&lt;br&gt;&lt;i&gt;Step 1-6 GIONG HET A1 (cung group → cung profile → cung merge = 8 entries). KHAC o Step 7: policy DISCARD tat ca!&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#b71c1c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="668" width="1400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s2_same" value="&lt;b&gt;Step 1-6: GIONG A1&lt;/b&gt;&lt;br&gt;Same group A → same cascade&lt;br&gt;Active Profile → 4 domains&lt;br&gt;Merge → 8 entries&lt;br&gt;&lt;b&gt;Den day = giong het A1!&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="720" width="210" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="s2_policy_detail" value="&lt;b style='font-size:14px'&gt;Step 7: APPLY POLICY&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px;text-align:left'&gt;effective = get_effective_mode(&quot;agent_a2&quot;)&#10;// Found: {override_mode: &quot;isolate&quot;,&#10;//         expires_at: &quot;2026-03-26T17:00&quot;}&#10;// now() = 14:00 &amp;lt; 17:00 → NOT expired&#10;// → effective = &quot;isolate&quot;&#10;&#10;// DISCARD all 8 merged entries!&#10;domains = _build_system_entries(&quot;192.168.1.100&quot;)&#10;// → [server_ip, 8.8.8.8, 8.8.4.4, 1.1.1.1]&#10;&#10;return {&#10;  domains: [4 system entries],&#10;  policy_mode: &quot;isolate&quot;,&#10;  policy_active: true&#10;}&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=3;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="300" y="710" width="370" height="260" as="geometry"/>
        </mxCell>

        <mxCell id="s2_resp" value="&lt;b&gt;HTTP RESPONSE:&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:8px'&gt;{&#10; &quot;success&quot;: true,&#10; &quot;type&quot;: &quot;full&quot;,&#10; &quot;count&quot;: 4,  // CHI 4!&#10; &quot;policy_mode&quot;: &quot;isolate&quot;,&#10; &quot;policy_active&quot;: true,&#10; &quot;domains&quot;: [&#10;   {value:&quot;192.168.1.100&quot;,type:&quot;ip&quot;,&#10;    category:&quot;system&quot;},&#10;   {value:&quot;8.8.8.8&quot;,type:&quot;ip&quot;,&#10;    category:&quot;system_dns&quot;},&#10;   {value:&quot;8.8.4.4&quot;,...},&#10;   {value:&quot;1.1.1.1&quot;,...}&#10; ]&#10;}&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="710" y="710" width="280" height="270" as="geometry"/>
        </mxCell>

        <mxCell id="s2_fw" value="&lt;b&gt;WINDOWS FIREWALL (A2):&lt;/b&gt;&lt;hr&gt;&lt;b style='color:#c62828;font-size:14px'&gt;DEFAULT DENY ALL&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b style='color:#2e7d32'&gt;ALLOWED (chi 4 IP):&lt;/b&gt;&lt;br&gt;✅ 192.168.1.100 (server)&lt;br&gt;✅ 8.8.8.8 (DNS)&lt;br&gt;✅ 8.8.4.4 (DNS)&lt;br&gt;✅ 1.1.1.1 (DNS)&lt;hr&gt;&lt;b style='color:#c62828'&gt;BLOCKED — TAT CA:&lt;/b&gt;&lt;br&gt;❌ google.com&lt;br&gt;❌ docs.python.org&lt;br&gt;❌ replit.com, github.com&lt;br&gt;❌ stackoverflow.com&lt;br&gt;❌ youtube, facebook, tiktok...&lt;br&gt;❌ &lt;b&gt;MOI THU ngoai server!&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="1030" y="710" width="260" height="300" as="geometry"/>
        </mxCell>

        <mxCell id="s2_compare" value="&lt;b style='font-size:14px'&gt;A1 vs A2 — CUNG GROUP, KHAC KET QUA!&lt;/b&gt;&lt;hr&gt;&lt;table style='font-size:10px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;&lt;/th&gt;&lt;th style='background:#c8e6c9;padding:4px;border:1px solid #ccc'&gt;A1 (none)&lt;/th&gt;&lt;th style='background:#ffcdd2;padding:4px;border:1px solid #ccc'&gt;A2 (isolate)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Group&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;A&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;A (GIONG)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Profile cascade&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Active&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Active (GIONG)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;After merge&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;8 entries&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;8 entries (GIONG)&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#fff3e0'&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;&lt;b&gt;After policy&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#c8e6c9'&gt;&lt;b&gt;8 entries ✅&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#ffcdd2'&gt;&lt;b&gt;0 + 4 system ❌&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;google.com?&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#c8e6c9'&gt;✅ ALLOWED&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#ffcdd2'&gt;❌ BLOCKED&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;docs.python?&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#c8e6c9'&gt;✅ ALLOWED&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#ffcdd2'&gt;❌ BLOCKED&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;youtube?&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#ffcdd2'&gt;❌ BLOCKED&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;background:#ffcdd2'&gt;❌ BLOCKED&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;Policy la PER-AGENT, khong per-group!&lt;/b&gt;&lt;br&gt;A1 va A2 ngoi canh nhau, cung phong,&lt;br&gt;cung group, cung teacher — nhung A2&lt;br&gt;bi co lap vi &lt;b&gt;xem YouTube trong gio hoc&lt;/b&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#616161;fontSize=10;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1330" y="700" width="330" height="350" as="geometry"/>
        </mxCell>

        <mxCell id="s2_expire" value="&lt;b&gt;TU DONG GO ISOLATE:&lt;/b&gt;&lt;hr&gt;expires_at = 17:00 hom nay&lt;br&gt;&lt;br&gt;Luc 17:01, A2 sync lai:&lt;br&gt;→ get_effective_mode()&lt;br&gt;→ &lt;b&gt;expires_at &amp;lt; now()&lt;/b&gt;&lt;br&gt;→ auto reset to &quot;none&quot;&lt;br&gt;→ A2 nhan lai 8 entries&lt;br&gt;&lt;b style='color:#2e7d32'&gt;→ Tu dong khoi phuc!&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1700" y="710" width="230" height="180" as="geometry"/>
        </mxCell>

        <!-- S2 arrows -->
