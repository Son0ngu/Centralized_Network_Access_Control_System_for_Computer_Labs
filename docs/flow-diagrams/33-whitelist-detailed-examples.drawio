        <!-- COLLECTION 1: whitelist (Global) -->
        <mxCell id="col1_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="110" width="420" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="col1_title" value="&lt;b&gt;Collection: whitelist&lt;/b&gt;&lt;br&gt;&lt;i&gt;scope=&quot;global&quot; | global_version = 5&lt;/i&gt;" style="text;html=1;align=center;fontSize=11;fontColor=#4a148c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="115" width="400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col1_data" value="&lt;pre style='font-size:9px;margin:0;text-align:left'&gt;[&#10;  {_id: &quot;64a1&quot;, value: &quot;google.com&quot;,      type: &quot;domain&quot;,   scope: &quot;global&quot;, is_active: true},&#10;  {_id: &quot;64a2&quot;, value: &quot;wikipedia.org&quot;,   type: &quot;domain&quot;,   scope: &quot;global&quot;, is_active: true},&#10;  {_id: &quot;64a3&quot;, value: &quot;10.0.0.0/24&quot;,    type: &quot;ip_range&quot;, scope: &quot;global&quot;, is_active: true},&#10;  {_id: &quot;64a4&quot;, value: &quot;*.edu.vn&quot;,       type: &quot;pattern&quot;,  scope: &quot;global&quot;, is_active: true},&#10;  {_id: &quot;64a5&quot;, value: &quot;stackoverflow.com&quot;,type:&quot;domain&quot;,   scope: &quot;global&quot;, is_active: true},&#10;  {_id: &quot;64a6&quot;, value: &quot;old-site.com&quot;,   type: &quot;domain&quot;,   scope: &quot;global&quot;, is_active: false},&#10;]&#10;&#10;// get_entries_for_sync(scope=&quot;global&quot;)&#10;// → Returns 5 active entries (skip old-site)&#10;// whitelist_model.py:448-460&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=9;align=left;spacingLeft=5;fontFamily=Courier New;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="400" height="310" as="geometry"/>
        </mxCell>

        <!-- COLLECTION 2: groups -->
        <mxCell id="col2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="470" y="110" width="520" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="col2_title" value="&lt;b&gt;Collection: groups&lt;/b&gt;&lt;br&gt;&lt;i&gt;4 groups: A (IT class), B (English), C (Free), Pending&lt;/i&gt;" style="text;html=1;align=center;fontSize=11;fontColor=#0d47a1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="115" width="500" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col2_data" value="&lt;pre style='font-size:9px;margin:0;text-align:left'&gt;// GROUP A — &quot;Lop 10A Tin hoc&quot;&#10;{&#10;  _id: &quot;grpA&quot;, name: &quot;Lop 10A Tin hoc&quot;,&#10;  whitelist_version: 12, teacher_ids: [&quot;teacher_nguyen&quot;],&#10;  whitelist: [  // LEGACY — bi Active Profile ghi de&#10;    {value: &quot;python.org&quot;, type: &quot;domain&quot;},&#10;    {value: &quot;scratch.mit.edu&quot;, type: &quot;domain&quot;},&#10;    {value: &quot;code.org&quot;, type: &quot;domain&quot;}&#10;  ]&#10;}&#10;&#10;// GROUP B — &quot;Lop 11B Ngoai ngu&quot;&#10;{&#10;  _id: &quot;grpB&quot;, name: &quot;Lop 11B Ngoai ngu&quot;,&#10;  whitelist_version: 8, teacher_ids: [&quot;teacher_tran&quot;],&#10;  whitelist: [{value:&quot;duolingo.com&quot;},{value:&quot;bbc.co.uk&quot;},{value:&quot;cambridge.org&quot;}]&#10;}&#10;&#10;// GROUP C — &quot;Phong may tu do&quot;&#10;{_id:&quot;grpC&quot;, name:&quot;Phong may tu do&quot;, whitelist_version:3,&#10; whitelist:[{value:&quot;youtube.com&quot;},{value:&quot;facebook.com&quot;},{value:&quot;tiktok.com&quot;}]}&#10;&#10;// PENDING — system group&#10;{_id:&quot;pending&quot;, name:&quot;pending&quot;, is_system:true, whitelist_version:1, whitelist:[]}&#10;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565c0;fontSize=9;align=left;spacingLeft=5;fontFamily=Courier New;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="480" y="150" width="500" height="310" as="geometry"/>
        </mxCell>

        <!-- COLLECTION 3: whitelist_profiles -->
        <mxCell id="col3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1010" y="110" width="530" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="col3_title" value="&lt;b&gt;Collection: whitelist_profiles&lt;/b&gt;&lt;br&gt;&lt;i&gt;Fallback: Active Profile → Default Profile → group.whitelist&lt;/i&gt;" style="text;html=1;align=center;fontSize=11;fontColor=#1b5e20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="115" width="510" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col3_data" value="&lt;pre style='font-size:9px;margin:0;text-align:left'&gt;// GROUP A — 2 profiles&#10;{&#10;  group_id: &quot;grpA&quot;, name: &quot;Bai thuc hanh Python&quot;,&#10;  teacher_id: &quot;teacher_nguyen&quot;,&#10;  is_active: true,    // ← ACTIVE! Agent A dung cai nay&#10;  is_default: false,  version: 3,&#10;  domains: [&#10;    {domain: &quot;docs.python.org&quot;, category: &quot;education&quot;},&#10;    {domain: &quot;replit.com&quot;, category: &quot;tool&quot;},&#10;    {domain: &quot;stackoverflow.com&quot;, category: &quot;education&quot;},  // TRUNG global!&#10;    {domain: &quot;github.com&quot;, category: &quot;tool&quot;}&#10;  ]&#10;}&#10;{&#10;  group_id: &quot;grpA&quot;, name: &quot;Mac dinh 10A&quot;,&#10;  is_active: false, is_default: true, version: 1,&#10;  domains: [{domain:&quot;python.org&quot;},{domain:&quot;w3schools.com&quot;}]&#10;}&#10;&#10;// GROUP B — 1 Default profile only (ko co Active)&#10;{&#10;  group_id: &quot;grpB&quot;, name: &quot;Hoc online co ban&quot;,&#10;  is_active: false, is_default: true, version: 2,&#10;  domains: [&#10;    {domain:&quot;duolingo.com&quot;},{domain:&quot;cambridge.org&quot;},&#10;    {domain:&quot;merriam-webster.com&quot;},{domain:&quot;bbc.co.uk/learning&quot;}&#10;  ]&#10;}&#10;&#10;// GROUP C — KHONG CO PROFILE NAO → Legacy fallback!&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2e7d32;fontSize=9;align=left;spacingLeft=5;fontFamily=Courier New;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1020" y="150" width="510" height="310" as="geometry"/>
        </mxCell>

        <!-- COLLECTION 4: agent_policies -->
        <mxCell id="col4_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1560" y="110" width="430" height="360" as="geometry"/>
