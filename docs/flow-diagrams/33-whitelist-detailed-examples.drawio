        <mxCell id="col4_title" value="&lt;b&gt;Collection: agent_policies&lt;/b&gt;&lt;br&gt;&lt;i&gt;Per-AGENT (khong phai per-group!) | 3 modes&lt;/i&gt;" style="text;html=1;align=center;fontSize=11;fontColor=#b71c1c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1570" y="115" width="410" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col4_data" value="&lt;pre style='font-size:9px;margin:0;text-align:left'&gt;// Agent A1 — KHONG CO RECORD → mode = &quot;none&quot;&#10;// (get_effective_mode tra ve &quot;none&quot; khi khong tim thay)&#10;&#10;// Agent A2 — ISOLATE (giao vien phat vi xem YouTube)&#10;{&#10;  agent_id: &quot;agent_a2&quot;,&#10;  override_mode: &quot;isolate&quot;,&#10;  applied_by_username: &quot;teacher_nguyen&quot;,&#10;  reason: &quot;Xem YouTube trong gio hoc&quot;,&#10;  expires_at: &quot;2026-03-26T17:00:00+07:00&quot;,  // Tu het han 5PM&#10;  override_version: 1&#10;}&#10;&#10;// Agent A3 — CUSTOM (on thi cuoi ky)&#10;{&#10;  agent_id: &quot;agent_a3&quot;,&#10;  override_mode: &quot;custom_whitelist&quot;,&#10;  custom_whitelist: [&#10;    {domain: &quot;docs.python.org&quot;, category: &quot;education&quot;},&#10;    {domain: &quot;w3schools.com&quot;, category: &quot;education&quot;}&#10;  ],&#10;  applied_by_username: &quot;teacher_nguyen&quot;,&#10;  reason: &quot;On thi — chi cho xem tai lieu&quot;,&#10;  expires_at: null,  // Khong het han, phai go thu cong&#10;  override_version: 2&#10;}&#10;&#10;// Agent A4, B1, C1, D1 — KHONG CO → &quot;none&quot;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c62828;fontSize=9;align=left;spacingLeft=5;fontFamily=Courier New;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1570" y="150" width="410" height="310" as="geometry"/>
        </mxCell>

        <!-- AGENTS TABLE -->
        <mxCell id="agents_title" value="&lt;b&gt;Collection: agents — 7 Agents, 4 Groups&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;fontStyle=1;" vertex="1" parent="1">
