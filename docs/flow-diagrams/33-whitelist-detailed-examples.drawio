        <mxCell id="s1_label" value="&lt;b&gt;SCENARIO 1: Agent A1 — Active Profile + DUPLICATE MERGE DETAIL (policy=none)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Cascade Level ①: Có Active Profile → dùng ngay. Entry trùng stackoverflow.com: group ghi đè global&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#1b5e20;fontStyle=1;" vertex="1" parent="1">
