        <mxCell id="agents_table" value="&lt;table style='font-size:10px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;Agent&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;Hostname&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;Group&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;Policy&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;Agent State (truoc sync)&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:4px;border:1px solid #ccc'&gt;Scenario&lt;/th&gt;&lt;/tr&gt;&lt;tr style='background:#e8f5e9'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;A1&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;PC-01&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;A (Tin hoc)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#2e7d32'&gt;&lt;b&gt;none&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;font-size:9px'&gt;global_v=4, group_v=10, policy=none&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Active Profile + Merge&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#ffebee'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;A2&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;PC-02&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;A (Tin hoc)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#c62828'&gt;&lt;b&gt;ISOLATE&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;font-size:9px'&gt;global_v=4, group_v=10, policy=none&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Same group, ISOLATED&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#fff3e0'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;A3&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;PC-03&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;A (Tin hoc)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#e65100'&gt;&lt;b&gt;CUSTOM&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;font-size:9px'&gt;global_v=4, group_v=10, policy=none&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Same group, Custom WL&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#e8eaf6'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;A4&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;PC-04&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;A (Tin hoc)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#2e7d32'&gt;&lt;b&gt;none&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;font-size:9px'&gt;&lt;b&gt;global_v=5, group_v=12&lt;/b&gt;, policy=none&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;up_to_date (skip)&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#fff9c4'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;B1&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;PC-05&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;B (Ngoai ngu)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#2e7d32'&gt;&lt;b&gt;none&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;font-size:9px'&gt;global_v=5, group_v=6, policy=none&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Default Profile fallback&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#fce4ec'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;C1&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;PC-10&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;C (Tu do)&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#2e7d32'&gt;&lt;b&gt;none&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;font-size:9px'&gt;global_v=5, group_v=2, policy=none&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;Legacy fallback (no profile)&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#e8eaf6'&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;D1&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;PC-NEW&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;None→Pending&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#2e7d32'&gt;&lt;b&gt;none&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;font-size:9px'&gt;global_v=0, group_v=0, policy=none&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;New agent, auto-pending&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#616161;fontSize=10;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
