        <mxCell id="sum_table" value="&lt;table style='font-size:11px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;#&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;Agent&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;Group&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;Policy&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;Profile Level&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;Global&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;Group&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;After Policy&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;google?&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;docs.py?&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;youtube?&lt;/th&gt;&lt;th style='background:#424242;color:white;padding:6px;border:1px solid #ccc'&gt;duolingo?&lt;/th&gt;&lt;/tr&gt;&lt;tr style='background:#e8f5e9'&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;1&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;A1&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;A (Tin hoc)&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#2e7d32'&gt;none&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#c8e6c9'&gt;Active&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;5&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;4&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;8&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#c8e6c9'&gt;✅&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#c8e6c9'&gt;✅&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#ffebee'&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;2&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;A2&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;A (Tin hoc)&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#c62828'&gt;&lt;b&gt;ISOLATE&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#999'&gt;(discarded)&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#999'&gt;-&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#999'&gt;-&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;0 +4sys&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;background:#ffcdd2'&gt;❌&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#fff3e0'&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;3&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;&lt;b&gt;A3&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc'&gt;A (Tin hoc)&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#e65100'&gt;&lt;b&gt;CUSTOM&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#999'&gt;(discarded)&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#999'&gt;-&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ccc;color:#999'&gt;-&lt