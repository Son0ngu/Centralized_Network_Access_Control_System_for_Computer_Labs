        </mxCell>
        <mxCell id="fb_examples" value="&lt;table style='font-size:10px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;Group&lt;/th&gt;&lt;th style='background:#c8e6c9;padding:3px;border:1px solid #ccc'&gt;Active?&lt;/th&gt;&lt;th style='background:#fff3e0;padding:3px;border:1px solid #ccc'&gt;Default?&lt;/th&gt;&lt;th style='background:#ffcdd2;padding:3px;border:1px solid #ccc'&gt;Legacy?&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;→ Dung&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;A&lt;/b&gt; Tin hoc&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#c8e6c9'&gt;&lt;b&gt;YES&lt;/b&gt; &quot;Bai thuc hanh&quot;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;skip&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;skip&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b style='color:#2e7d32'&gt;Active Profile&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;B&lt;/b&gt; Ngoai ngu&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;NO&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#fff3e0'&gt;&lt;b&gt;YES&lt;/b&gt; &quot;Hoc online&quot;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;skip&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b style='color:#e65100'&gt;Default Profile&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;C&lt;/b&gt; Tu do&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;NO&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;NO&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;background:#ffcdd2'&gt;&lt;b&gt;YES&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b style='color:#c62828'&gt;Legacy (group.wl)&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;Pending&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;NO&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc;color:#999'&gt;NO&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;whitelist=[]&lt;/td&gt;&lt;td style='padding:3px;border:1px solid #ccc'&gt;&lt;b&gt;EMPTY (chi global)&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#616161;fontSize=10;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1020" y="670" width="690" height="140" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SECTION B: SERVER PIPELINE                                    -->
        <!-- ============================================================ -->
        <mxCell id="pipeTitle" value="&lt;b&gt;B. SERVER SYNC PIPELINE — whitelist_service.py:get_agent_sync_data()&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="840" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 1: Agent Request -->
        <mxCell id="pipe_req" value="&lt;b&gt;AGENT REQUEST&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;GET /api/whitelist/agent-sync?&#10;  agent_id=agent_a1&#10;  &amp;amp;global_version=4&#10;  &amp;amp;group_version=10&#10;  &amp;amp;policy_mode=none&#10;&#10;Headers:&#10;  Authorization: Bearer &amp;lt;JWT&amp;gt;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="880" width="250" height="170" as="geometry"/>
        </mxCell>

        <!-- Step 2: Load Agent + Group -->
        <mxCell id="pipe_s2" value="&lt;b&gt;Step 1: Load Agent + Group&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;agent = agent_model.find_by_agent_id()&#10;group_id = agent[&quot;group_id&quot;]  // &quot;grpA&quot;&#10;group = group_model.find_by_id()&#10;&#10;if not group:&#10;  group = ensure_pending_group()&#10;  agent.group_id = pending._id&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="880" width="280" height="140" as="geometry"/>
        </mxCell>

        <!-- Step 3: Policy Check -->
        <mxCell id="pipe_s3" value="&lt;b&gt;Step 2: Policy Changed?&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;effective = get_effective_mode(agent_id)&#10;// Check expires_at &amp;lt; now → auto-reset&#10;&#10;policy_changed = (&#10;  effective != &quot;none&quot; OR&#10;  effective != agent_policy_mode&#10;)&#10;// If changed → skip version cache!&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="620" y="880" width="280" height="140" as="geometry"/>
        </mxCell>

        <!-- Step 4: Version Check -->
        <mxCell id="pipe_s4" value="&lt;b&gt;Step 3: Version Cache&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;if NOT policy_changed&#10;   AND global_v == server_global_v&#10;   AND group_v == server_group_v:&#10;  return {up_to_date: true}&#10;  // → Agent skip update!&#10;&#10;// A4: g=5==5, grp=12==12&#10;//   → up_to_date! STOP HERE.&#10;// A1: g=4!=5 → CONTINUE&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="930" y="880" width="260" height="170" as="geometry"/>
        </mxCell>

        <!-- Step 5: Load Global -->
        <mxCell id="pipe_s5" value="&lt;b&gt;Step 4: Load Global Entries&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;// Full if version changed:&#10;global_entries = get_entries_for_sync(&#10;  scope=&quot;global&quot;&#10;)&#10;// → 5 active entries&#10;// type = &quot;full&quot;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="1080" width="250" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 6: Resolve Group Profile -->
        <mxCell id="pipe_s6" value="&lt;b&gt;Step 5: Profile Resolution (Fallback Chain)&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;active_profile = get_active_profile(group_id)&#10;&#10;if active_profile:            // Group A → YES&#10;  group_entries = normalize(active_profile.domains)&#10;elif default_profile:         // Group B → YES&#10;  group_entries = normalize(default_profile.domains)&#10;else:                         // Group C → LEGACY&#10;  group_entries = normalize(group.whitelist)&#10;&#10;// normalize: them pseudo_id, scope=&quot;group&quot;, group_id, group_name&#10;// pseudo_id = &quot;group::grpA::domain::docs.python.org&quot;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="1070" width="440" height="190" as="geometry"/>
        </mxCell>

        <!-- Step 7: Merge -->
        <mxCell id="pipe_s7" value="&lt;b&gt;Step 6: _merge_whitelists()&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;combined = merge(global, group)&#10;// Key = &quot;{type}:{value}&quot;&#10;// If same key: group wins (more specific)&#10;// stackoverflow.com: global → replaced by group&#10;&#10;// Result: unique entries from both scopes&#10;// Group A: 5 global + 4 profile - 1 dup = 8&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="1080" width="340" height="140" as="geometry"/>
        </mxCell>

        <!-- Step 8: Apply Policy -->
        <mxCell id="pipe_s8" value="&lt;b&gt;Step 7: apply_policy_to_sync()&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;effective = get_effective_mode(agent_id)&#10;&#10;if effective == &quot;none&quot;:&#10;  return combined  // UNCHANGED (A1, B1, C1)&#10;&#10;if effective == &quot;isolate&quot;:&#10;  return system_entries_only()  // A2&#10;  // [server_host, 8.8.8.8, 8.8.4.4, 1.1.1.1]&#10;&#10;if effective == &quot;custom_whitelist&quot;:&#10;  return system + custom_list   // A3&#10;  // [server_host, DNS] + [docs.python, w3schools]&#10;&#10;// CRITICAL: system entries ALWAYS included&#10;// → prevent deadlock (agent can reach server)&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="1150" y="1070" width="350" height="250" as="geometry"/>
        </mxCell>

        <!-- Step 9: Response -->
        <mxCell id="pipe_resp" value="&lt;b&gt;Step 8: HTTP Response&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px'&gt;{&#10;  &quot;success&quot;: true,&#10;  &quot;domains&quot;: [...],        // After policy&#10;  &quot;type&quot;: &quot;full&quot;,&#10;  &quot;global_version&quot;: 5,&#10;  &quot;group_version&quot;: 12,&#10;  &quot;group_id&quot;: &quot;grpA&quot;,&#10;  &quot;policy_mode&quot;: &quot;none&quot;,   // or isolate/custom&#10;  &quot;policy_active&quot;: false, // or true&#10;  &quot;count&quot;: 8,             // varies per agent&#10;  &quot;up_to_date&quot;: false     // only true for A4&#10;}&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1530" y="1070" width="280" height="240" as="geometry"/>
        </mxCell>

        <!-- Pipeline Arrows -->
        <mxCell id="pa1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="pipe_req" target="pipe_s2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="pipe_s2" target="pipe_s3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="pipe_s3" target="pipe_s4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa4" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="pipe_s5" target="pipe_s6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa5" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="pipe_s6" target="pipe_s7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa6" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="pipe_s7" target="pipe_s8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa7" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="pipe_s8" target="pipe_resp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============================================================ -->
        <!-- SECTION C: AGENT-SIDE PROCESSING                              -->
        <!-- ============================================================ -->
        <mxCell id="agentTitle" value="&lt;b&gt;C. AGENT-SIDE PROCESSING — state.py:update() + manager.py:sync_now()&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1350" width="800" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="agent_flow" value="&lt;pre style='font-size:9px;margin:0;text-align:left'&gt;// manager.py:sync_now() — AGENT RECEIVES RESPONSE&#10;&#10;result = sync.sync_with_server(params)   // HTTP GET to server&#10;data = result[&quot;data&quot;]                    // Full JSON response&#10;&#10;// state.py:update(data) — UPDATE LOCAL STATE&#10;&#10;1. sync_type = data[&quot;type&quot;]              // &quot;full&quot; or &quot;incremental&quot;&#10;&#10;2. GROUP CHANGE DETECTION (Bug #24 fix):&#10;   new_group_id = data[&quot;group_id&quot;]&#10;   if self._group_id != new_group_id:&#10;     sync_type = &quot;full&quot;                  // Force full sync!&#10;     // Don't trust up_to_date flag&#10;&#10;3. if data[&quot;up_to_date&quot;] and NOT group_changed:&#10;     return False                        // No update needed (A4)&#10;&#10;4. Parse data[&quot;domains&quot;] → _domains (set), _patterns (set), _ips (set)&#10;   // Each entry: if type==&quot;ip&quot; → _ips, if has wildcard → _patterns, else → _domains&#10;&#10;5. if sync_type == &quot;incremental&quot; and _domains not empty:&#10;     _domains |= new_domains             // MERGE (union)&#10;     _patterns |= new_patterns&#10;     _ips |= new_ips&#10;   else:  // &quot;full&quot; sync&#10;     _domains = new_domains              // REPLACE&#10;     _patterns = new_patterns&#10;     _ips = new_ips&#10;&#10;6. Update metadata:&#10;   _version = data[&quot;global_version&quot;]&#10;   _group_version = data[&quot;group_version&quot;]&#10;   _group_id = data[&quot;group_id&quot;]&#10;   _policy_mode = data[&quot;policy_mode&quot;]    // Store for next sync request&#10;&#10;7. manager: if state changed → _update_firewall_rules()&#10;   // Resolve domains to IPs (DNS cache) → update Windows Firewall&#10;   // netsh: default deny + allow rules per IP&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=9;align=left;spacingLeft=10;fontFamily=Courier New;verticalAlign=top;spacingTop=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="1390" width="700" height="500" as="geometry"/>
        </mxCell>

        <!-- Domain matching -->
        <mxCell id="match_flow" value="&lt;b&gt;D. PACKET SNIFFING — is_domain_allowed() check&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px;text-align:left'&gt;// handlers.py:handle_domain_detection()&#10;// Called for every DNS/HTTP/HTTPS packet captured&#10;&#10;domain = extract_from_packet()  // e.g. &quot;youtube.com&quot;&#10;&#10;allowed = whitelist_state.is_domain_allowed(domain)&#10;  1. Direct match: domain in _domains?  // O(1) set lookup&#10;  2. Pattern match: fnmatch(domain, pattern)?&#10;     // e.g. &quot;hcmut.edu.vn&quot; matches &quot;*.edu.vn&quot;&#10;  3. Parent domain: split(&quot;.&quot;) → check each parent&#10;     // &quot;sub.google.com&quot; → check &quot;google.com&quot; → YES&#10;&#10;ip_allowed = whitelist_state.is_ip_allowed(dest_ip)&#10;  // Direct set lookup&#10;&#10;action:&#10;  if firewall_mode == &quot;whitelist_only&quot;:&#10;    if allowed or ip_allowed → ALLOWED&#10;    else → BLOCKED (Windows Firewall drops packet)&#10;  elif firewall_mode == &quot;monitor&quot;:&#10;    → MONITORED (log only, don't block)&#10;&#10;// Create log record and queue via LogSender&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="1390" width="440" height="420" as="geometry"/>
        </mxCell>

        <!-- System entries explanation -->
        <mxCell id="sys_explain" value="&lt;b&gt;E. SYSTEM ENTRIES — Anti-deadlock&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:9px;text-align:left'&gt;// agent_policy_service.py:_build_system_entries()&#10;// LUON co trong isolate va custom mode&#10;&#10;system_entries = [&#10;  {value: &quot;192.168.1.100&quot;,  // Server IP&#10;   type: &quot;ip&quot;, category: &quot;system&quot;,&#10;   source: &quot;policy_isolate&quot;},&#10;&#10;  {value: &quot;8.8.8.8&quot;,         // Google DNS&#10;   type: &quot;ip&quot;, category: &quot;system_dns&quot;},&#10;&#10;  {value: &quot;8.8.4.4&quot;,         // Google DNS backup&#10;   type: &quot;ip&quot;, category: &quot;system_dns&quot;},&#10;&#10;  {value: &quot;1.1.1.1&quot;,         // Cloudflare DNS&#10;   type: &quot;ip&quot;, category: &quot;system_dns&quot;}&#10;]&#10;&#10;// TAI SAO CAN?&#10;// Agent MUST reach server de:&#10;//   1. Heartbeat (report alive)&#10;//   2. Sync (nhan lenh go policy)&#10;//   3. Token refresh&#10;// Neu chan server → agent mat ket noi&#10;//   → teacher khong go duoc isolate&#10;//   → DEADLOCK vinh vien!&#10;&#10;// DNS IPs needed de resolve server hostname&#10;// (neu server dung domain thay vi IP)&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1250" y="1390" width="380" height="480" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ================================================================== -->
  <!-- PAGE 2: GROUP A — 4 AGENTS, SAME GROUP, 4 DIFFERENT RESULTS       -->
  <!-- ================================================================== -->
  <diagram id="page2-groupA" name="2. Group A — 4 Agents, 4 Ket qua">
    <mxGraphModel dx="2200" dy="5800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2200" pageHeight="5800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t2" value="&lt;b style='font-size:20px'&gt;Group A &quot;Lop 10A Tin hoc&quot; — 4 Agents CUNG GROUP, 4 ket qua KHAC NHAU&lt;/b&gt;&lt;br&gt;&lt;i&gt;Policy la per-AGENT (khong phai per-group). Cung profile, cung merge → khac nhau tai Step 7 (apply_policy)&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1400" height="50" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SCENARIO 1: A1 — NONE (FULL ACCESS)                          -->
        <!-- ============================================================ -->
        <mxCell id="s1bg" value="" style="rounded=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="1950" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="s1t" value="&lt;b&gt;SCENARIO 1: Agent A1 (PC-01) — policy=none → FULL ACCESS theo Active Profile&lt;/b&gt;&lt;br&gt;&lt;i&gt;Agent co version cu (g=4, grp=10). Server co (g=5, grp=12) → version mismatch → full sync&lt;/i&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#1b5e20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="88" width="1200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="s1_before" value="&lt;b&gt;AGENT STATE BEFORE:&lt;/b&gt;&lt;hr&gt;_domains: {google.com, wiki...}&lt;br&gt;_version: &quot;4&quot;&lt;br&gt;_group_version: &quot;10&quot;&lt;br&gt;_group_id: &quot;grpA&quot;&lt;br&gt;_policy_mode: &quot;none&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="135" width="200" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="s1_http" value="&lt;b&gt;HTTP REQUEST:&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:8px'&gt;GET /api/whitelist/agent-sync&#10;  ?agent_id=agent_a1&#10;  &amp;amp;global_version=4&#10;  &amp;amp;group_version=10&#10;  &amp;amp;policy_mode=none&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="280" y="135" width="210" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="s1_server" value="&lt;b&gt;SERVER PROCESSING:&lt;/b&gt;&lt;hr&gt;1. Load agent A1 → group_id=&quot;grpA&quot;&lt;br&gt;2. Policy check: &lt;b style='color:#2e7d32'&gt;no record → &quot;none&quot;&lt;/b&gt;&lt;br&gt;3. Version: g=4!=5, grp=10!=12 → &lt;b&gt;CHANGED&lt;/b&gt;&lt;br&gt;4. Full sync: load 5 global entries&lt;br&gt;5. Profile: &lt;b style='color:#2e7d32'&gt;Active &quot;Bai thuc hanh&quot; FOUND&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ 4 domains (docs.python, replit, SO, github)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ SKIP Default, SKIP Legacy&lt;br&gt;6. Merge: 5 global + 4 profile - 1 dup = &lt;b&gt;8&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;stackoverflow: global→group (group wins)&lt;br&gt;7. Policy: &quot;none&quot; → &lt;b style='color:#2e7d32'&gt;KEEP 8 entries&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="520" y="135" width="340" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="s1_resp" value="&lt;b&gt;HTTP RESPONSE:&lt;/b&gt;&lt;hr&gt;&lt;pre style='font-size:8px'&gt;{&#10; &quot;success&quot;: true,&#10; &quot;type&quot;: &quot;full&quot;,&#10; &quot;count&quot;: 8,&#10; &quot;global_version&quot;: 5,&#10; &quot;group_version&quot;: 12,&#10; &quot;policy_mode&quot;: &quot;none&quot;,&#10; &quot;policy_active&quot;: false,&#10; &quot;domains&quot;: [&#10;   {value:&quot;google.com&quot;, scope:&quot;global&quot;},&#10;   {value:&quot;wikipedia.org&quot;,scope:&quot;global&quot;},&#10;   {value:&quot;10.0.0.0/24&quot;, scope:&quot;global&quot;},&#10;   {value:&quot;*.edu.vn&quot;, scope:&quot;global&quot;},&#10;   {value:&quot;docs.python.org&quot;,scope:&quot;group&quot;},&#10;   {value:&quot;replit.com&quot;, scope:&quot;group&quot;},&#10;   {value:&quot;stackoverflow.com&quot;,scope:&quot;group&quot;},&#10;   {value:&quot;github.com&quot;, scope:&quot;group&quot;}&#10; ]&#10;}&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="890" y="135" width="310" height="340" as="geometry"/>
        </mxCell>

        <mxCell id="s1_after" value="&lt;b&gt;AGENT STATE AFTER:&lt;/b&gt;&lt;hr&gt;_domains: {google.com, wikipedia.org,&lt;br&gt;&amp;nbsp;docs.python.org, replit.com,&lt;br&gt;&amp;nbsp;stackoverflow.com, github.com}&lt;br&gt;_patterns: {*.edu.vn}&lt;br&gt;_ips: {10.0.0.0/24}&lt;br&gt;_version: &quot;5&quot;&lt;br&gt;_group_version: &quot;12&quot;&lt;br&gt;_policy_mode: &quot;none&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1230" y="135" width="250" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="s1_fw" value="&lt;b&gt;WINDOWS FIREWALL:&lt;/b&gt;&lt;hr&gt;&lt;b style='color:#2e7d32'&gt;ALLOWED:&lt;/b&gt;&lt;br&gt;✅ google.com (→ 142.250.x.x)&lt;br&gt;✅ docs.python.org&lt;br&gt;✅ replit.com, github.com&lt;br&gt;✅ stackoverflow.com&lt;br&gt;✅ *.edu.vn (hcmut.edu.vn...)&lt;br&gt;✅ 10.0.0.0/24 range&lt;hr&gt;&lt;b style='color:#c62828'&gt;BLOCKED:&lt;/b&gt;&lt;br&gt;❌ youtube.com&lt;br&gt;❌ facebook.com, tiktok.com&lt;br&gt;❌ netflix.com, spotify.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1510" y="135" width="230" height="250" as="geometry"/>
        </mxCell>

