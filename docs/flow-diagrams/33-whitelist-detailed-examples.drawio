        </mxCell>

        <!-- DUPLICATE MERGE TABLE -->
        <mxCell id="s1_merge" value="&lt;b&gt;Step 3: _merge_whitelists() — DUPLICATE DETAIL&lt;/b&gt;&lt;br&gt;&lt;i&gt;Key = &quot;{type}:{value}&quot; | Duyệt: global_entries + group_entries → group ghi đè&lt;/i&gt;&lt;hr&gt;&lt;table style='font-size:9px;width:100%;border-collapse:collapse'&gt;&lt;tr&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;#&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;Entry&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;Key&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;Source&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;Scope&lt;/th&gt;&lt;th style='background:#e0e0e0;padding:3px;border:1px solid #ccc'&gt;merged[key]&lt;/th&gt;&lt;/tr&gt;&lt;tr style='background:#f3e5f5'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;1&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;google.com&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;domain:google.com&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#f3e5f5'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;2&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;wikipedia.org&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;domain:wikipedia.org&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#f3e5f5'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;3&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;10.0.0.0/24&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;ip_range:10.0.0.0/24&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#f3e5f5'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;4&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;*.edu.vn&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;pattern:*.edu.vn&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#fff3e0'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;&lt;b&gt;5&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;&lt;b&gt;stackoverflow.com&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;&lt;b&gt;domain:stackoverflow.com&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;&lt;b&gt;Global&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;global&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New (lần 1)&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#e8f5e9'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;6&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;docs.python.org&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;domain:docs.python.org&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Profile A&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;group&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#e8f5e9'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;7&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;replit.com&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;domain:replit.com&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Profile A&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;group&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#ffebee;border:2px solid #c62828'&gt;&lt;td style='padding:2px;border:2px solid #c62828'&gt;&lt;b&gt;8&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:2px solid #c62828'&gt;&lt;b&gt;stackoverflow.com&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:2px solid #c62828'&gt;&lt;b&gt;domain:stackoverflow.com&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:2px solid #c62828'&gt;&lt;b&gt;Profile A&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:2px solid #c62828'&gt;&lt;b&gt;group&lt;/b&gt;&lt;/td&gt;&lt;td style='padding:2px;border:2px solid #c62828'&gt;&lt;b style='color:#c62828'&gt;⚠️ OVERWRITE #5!&lt;br&gt;global→group&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#e8f5e9'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;9&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;github.com&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;domain:github.com&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Profile A&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;group&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;✅ New&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;b&gt;Result: 8 unique (9 input, 1 dup overwritten)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#616161;fontSize=10;verticalAlign=top;spacingTop=3;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="450" y="878" width="570" height="360" as="geometry"/>
