        <mxCell id="s1_step1" value="&lt;b&gt;Step 1: Sync&lt;/b&gt;&lt;br&gt;g=4,grp=10&lt;br&gt;Server: g=5,grp=12&lt;br&gt;&lt;b style='color:#c62828'&gt;→ CHANGED&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=10;" vertex="1" parent="1">
