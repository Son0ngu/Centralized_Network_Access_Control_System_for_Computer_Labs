        <!-- ============================================================ -->
        <!-- SCENARIO 3: A3 — CUSTOM_WHITELIST -->
        <!-- ============================================================ -->
        <mxCell id="s3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=2;dashed=1;" vertex="1" parent="1">
