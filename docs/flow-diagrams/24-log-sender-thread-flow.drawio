          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- S6: Build payload -->
        <mxCell id="s6" value="&lt;b&gt;Build Payload&lt;/b&gt;&lt;br&gt;&lt;i&gt;{&quot;logs&quot;: [serialized_logs]}&lt;br&gt;json.dumps(payload)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
