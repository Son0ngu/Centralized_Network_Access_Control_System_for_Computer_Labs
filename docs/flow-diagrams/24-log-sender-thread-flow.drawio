  <diagram id="log-sender-thread" name="Flow 24: Log Sender Thread">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Flow 24: Log Sender Thread&lt;/b&gt;&lt;br&gt;&lt;i&gt;Luồng gửi log từ Agent lên Server theo batch&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="700" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== LEFT: Producer (queue_log) ==================== -->
        <mxCell id="left_header" value="&lt;b&gt;PRODUCER: queue_log()&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thêm log vào hàng đợi&lt;/i&gt;" style="text;html=1;align=center;fontSize=14;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="300" height="40" as="geometry"/>
        </mxCell>

        <!-- P1: Log Event -->
        <mxCell id="p1" value="&lt;b&gt;Log Event Created&lt;/b&gt;&lt;br&gt;&lt;i&gt;PacketSniffer / DomainExtractor&lt;br&gt;tạo log event mới&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- P2: Serialize -->
        <mxCell id="p2" value="&lt;b&gt;_serialize_log(log_data)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Chuyển đổi datetime → ISO format&lt;br&gt;dict/list → JSON, None → loại bỏ&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ep1p2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- P3: Check queue full -->
        <mxCell id="p3" value="&lt;b&gt;Queue full?&lt;/b&gt;&lt;br&gt;&lt;i&gt;queue.qsize() ≥ 1000?&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="340" width="200" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ep2p3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- P3 Yes: Drop log -->
        <mxCell id="p3_drop" value="&lt;b&gt;Log Dropped&lt;/b&gt;&lt;br&gt;&lt;i&gt;Queue đầy, log bị bỏ&lt;br&gt;queue.Full exception&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="355" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ep3drop" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontFamily=Segoe UI;fontSize=11;fontStyle=1;" edge="1" parent="1" source="p3" target="p3_drop"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- P4: put_nowait -->
        <mxCell id="p4" value="&lt;b&gt;queue.put_nowait(log)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thêm log vào Queue&lt;br&gt;(non-blocking)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="480" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ep3p4" value="No" style="edgeStyle=orthogonalEdgeStyle;fontFamily=Segoe UI;fontSize=11;fontStyle=1;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Queue visualization -->
        <mxCell id="queue_box" value="&lt;b&gt;📦 Queue (Thread-Safe)&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;i&gt;maxsize = 1000&lt;br&gt;queue.Queue (FIFO)&lt;br&gt;Thread-safe put/get&lt;/i&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="140" y="580" width="200" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ep4q" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p4" target="queue_box"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== RIGHT: Consumer (_sender_loop) ==================== -->
        <mxCell id="right_header" value="&lt;b&gt;CONSUMER: _sender_loop() [Daemon Thread]&lt;/b&gt;&lt;br&gt;&lt;i&gt;Vòng lặp gửi log lên server (thread: LogSender)&lt;/i&gt;" style="text;html=1;align=center;fontSize=14;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="600" y="90" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- S1: Sleep 1s -->
        <mxCell id="s1" value="&lt;b&gt;Sleep 1 second&lt;/b&gt;&lt;br&gt;&lt;i&gt;Chờ 1 giây mỗi vòng lặp&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="150" width="240" height="50" as="geometry"/>
        </mxCell>

        <!-- S2: Check running -->
        <mxCell id="s2" value="&lt;b&gt;self.running?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
