        <mxCell id="es2exit" value="No" style="edgeStyle=orthogonalEdgeStyle;fontFamily=Segoe UI;fontSize=11;fontStyle=1;" edge="1" parent="1" source="s2" target="s2_exit"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- S3: Check trigger conditions -->
        <mxCell id="s3" value="&lt;b&gt;Send trigger?&lt;/b&gt;&lt;br&gt;&lt;i&gt;queue ≥ 100 (batch_size)&lt;br&gt;HOẶC queue &gt; 0 AND&lt;br&gt;elapsed ≥ 2s (send_interval)&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="340" width="240" height="120" as="geometry"/>
        </mxCell>
