        <!-- S4: Acquire lock -->
        <mxCell id="s4" value="&lt;b&gt;Acquire _send_lock&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thread-safe lock&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="710" y="500" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="es3s4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontFamily=Segoe UI;fontSize=11;fontStyle=1;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- S5: Drain queue -->
        <mxCell id="s5" value="&lt;b&gt;Drain Queue (max 100)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Lấy tối đa batch_size log&lt;br&gt;bằng get_nowait() + task_done()&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
