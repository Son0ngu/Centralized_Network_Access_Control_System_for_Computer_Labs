        <mxCell id="es4s5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Arrow from queue to drain -->
