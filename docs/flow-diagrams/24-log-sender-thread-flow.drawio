        <!-- S7: POST request -->
        <mxCell id="s7" value="&lt;b&gt;POST /api/logs&lt;/b&gt;&lt;br&gt;&lt;i&gt;requests.post(url, data=payload,&lt;br&gt;headers=auth_headers, timeout=15)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=12;" vertex="1" parent="1">
