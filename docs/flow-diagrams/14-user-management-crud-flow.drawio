<mxfile host="app.diagrams.net" modified="2026-03-23" agent="Claude" version="24.0.0" type="device">
  <diagram id="user-crud" name="User Management CRUD">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Flow 14: User Management CRUD&lt;/b&gt;&lt;br&gt;/api/admin/users - Admin Only&lt;br&gt;&lt;i&gt;Quản lý tài khoản Admin/Teacher&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="500" y="10" width="350" height="50" as="geometry" />
        </mxCell>

        <!-- ===== CREATE USER (Top Left) ===== -->
        <mxCell id="create_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="460" height="580" as="geometry" />
        </mxCell>
        <mxCell id="create_title" value="&lt;b&gt;CREATE USER&lt;/b&gt; - POST /api/admin/users&lt;br&gt;&lt;i&gt;Tạo tài khoản mới (Admin only)&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="90" width="380" height="35" as="geometry" />
        </mxCell>

        <mxCell id="c_start" value="&lt;b&gt;Request&lt;/b&gt;&lt;br&gt;{username, password, role, email}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="130" y="140" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="c_mw" value="@require_login + @require_admin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="130" y="195" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ce1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c_start" target="c_mw" parent="1" />

        <mxCell id="c_v1" value="&lt;b&gt;Validate username&lt;/b&gt;&lt;br&gt;3-50 chars, alphanumeric+dash&lt;br&gt;Check duplicate (case-insensitive)&lt;br&gt;&lt;i&gt;Kiểm tra tên đăng nhập&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="100" y="235" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ce2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c_mw" target="c_v1" parent="1" />

        <mxCell id="c_v2" value="&lt;b&gt;Validate email&lt;/b&gt; (if provided)&lt;br&gt;Check duplicate&lt;br&gt;&lt;b&gt;Validate role&lt;/b&gt; ∈ {admin, teacher}&lt;br&gt;&lt;b&gt;Validate password&lt;/b&gt; 8-128 chars&lt;br&gt;&lt;i&gt;Kiểm tra email, role, mật khẩu&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="85" y="305" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ce3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c_v1" target="c_v2" parent="1" />

        <mxCell id="c_err" value="&lt;b&gt;400&lt;/b&gt; Validation error&lt;br&gt;&lt;i&gt;Dữ liệu không hợp lệ&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="350" y="260" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ce_err" value="Fail" style="edgeStyle=orthogonalEdgeStyle;fontColor=#b85450;fontStyle=1;fontSize=9;" edge="1" source="c_v1" target="c_err" parent="1" />

        <mxCell id="c_hash" value="&lt;b&gt;bcrypt.hashpw(password, rounds=12)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Mã hoá mật khẩu&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="110" y="395" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ce4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c_v2" target="c_hash" parent="1" />

        <mxCell id="c_db" value="&lt;b&gt;user_model.create(user_data)&lt;/b&gt;&lt;br&gt;Insert into MongoDB&lt;br&gt;&lt;i&gt;Lưu vào DB&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="120" y="450" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ce5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c_hash" target="c_db" parent="1" />

        <mxCell id="c_audit" value="&lt;b&gt;AuditService.log(&quot;user.create&quot;)&lt;/b&gt;&lt;br&gt;SocketIO.emit(&quot;user_created&quot;)&lt;br&gt;&lt;i&gt;Ghi audit + thông báo&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="110" y="510" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ce6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c_db" target="c_audit" parent="1" />

        <mxCell id="c_resp" value="&lt;b&gt;201 Created&lt;/b&gt;&lt;br&gt;{user: sanitized (no password_hash)}&lt;br&gt;&lt;i&gt;Tạo thành công&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="110" y="570" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ce7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c_audit" target="c_resp" parent="1" />

        <!-- ===== UPDATE USER (Top Right) ===== -->
        <mxCell id="update_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fff0;strokeColor=#82b366;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="80" width="440" height="400" as="geometry" />
        </mxCell>
        <mxCell id="update_title" value="&lt;b&gt;UPDATE USER&lt;/b&gt; - PATCH /api/admin/users/:id&lt;br&gt;&lt;i&gt;Cập nhật tài khoản&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="90" width="360" height="35" as="geometry" />
        </mxCell>

        <mxCell id="u_start" value="&lt;b&gt;Request&lt;/b&gt;&lt;br&gt;{role?, email?, is_active?}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="140" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="u_d1" value="&lt;b&gt;Only is_active&lt;br&gt;field?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="660" y="200" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ue1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_start" target="u_d1" parent="1" />

        <mxCell id="u_toggle" value="&lt;b&gt;toggle_active()&lt;/b&gt;&lt;br&gt;is_active = !current&lt;br&gt;&lt;i&gt;Bật/tắt tài khoản&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="205" width="130" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ue2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=9;" edge="1" source="u_d1" target="u_toggle" parent="1" />

        <mxCell id="u_validate" value="&lt;b&gt;Validate allowed fields&lt;/b&gt;&lt;br&gt;Only: {email, role, is_active}&lt;br&gt;Check email unique&lt;br&gt;Check role ∈ valid_roles&lt;br&gt;&lt;i&gt;Kiểm tra dữ liệu cập nhật&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="605" y="285" width="210" height="65" as="geometry" />
        </mxCell>
        <mxCell id="ue3" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="u_d1" target="u_validate" parent="1" />

        <mxCell id="u_db" value="&lt;b&gt;UserModel.update(user_id, data)&lt;/b&gt;&lt;br&gt;AuditService.log(&quot;user.update&quot;)&lt;br&gt;&lt;i&gt;Cập nhật DB + ghi log&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="610" y="375" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ue4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_validate" target="u_db" parent="1" />
        <mxCell id="ue5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_toggle" target="u_db" parent="1" />

        <mxCell id="u_resp" value="&lt;b&gt;200 OK&lt;/b&gt; {updated user}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="440" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ue6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_db" target="u_resp" parent="1" />

        <!-- ===== DELETE USER (Bottom Left) ===== -->
        <mxCell id="delete_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="690" width="460" height="380" as="geometry" />
        </mxCell>
        <mxCell id="delete_title" value="&lt;b&gt;DELETE USER&lt;/b&gt; - DELETE /api/admin/users/:id&lt;br&gt;&lt;i&gt;Xoá tài khoản&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="700" width="380" height="35" as="geometry" />
        </mxCell>

        <mxCell id="del_start" value="&lt;b&gt;DELETE /admin/users/:id&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="160" y="750" width="180" height="30" as="geometry" />
        </mxCell>

        <mxCell id="del_d1" value="&lt;b&gt;Self-delete?&lt;/b&gt;&lt;br&gt;current_id == user_id?&lt;br&gt;&lt;i&gt;Xoá chính mình?&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="180" y="800" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="de1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="del_start" target="del_d1" parent="1" />

        <mxCell id="del_err1" value="&lt;b&gt;400&lt;/b&gt;&lt;br&gt;Không thể xoá chính mình" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="370" y="810" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="de2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=9;" edge="1" source="del_d1" target="del_err1" parent="1" />

        <mxCell id="del_d2" value="&lt;b&gt;Last admin?&lt;/b&gt;&lt;br&gt;role==admin &amp;&amp;&lt;br&gt;active_admins ≤ 1&lt;br&gt;&lt;i&gt;Admin cuối cùng?&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="175" y="895" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="de3" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=9;" edge="1" source="del_d1" target="del_d2" parent="1" />

        <mxCell id="del_err2" value="&lt;b&gt;400&lt;/b&gt;&lt;br&gt;Không thể xoá admin cuối" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="370" y="905" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="de4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=9;" edge="1" source="del_d2" target="del_err2" parent="1" />

        <mxCell id="del_ok" value="&lt;b&gt;user_model.delete(user_id)&lt;/b&gt;&lt;br&gt;AuditService.log(&quot;user.delete&quot;)&lt;br&gt;&lt;i&gt;Xoá user + ghi audit&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="140" y="1000" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="de5" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=9;" edge="1" source="del_d2" target="del_ok" parent="1" />

        <mxCell id="del_resp" value="&lt;b&gt;200 OK&lt;/b&gt; Xoá thành công" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="170" y="1055" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="de6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="del_ok" target="del_resp" parent="1" />

        <!-- ===== RESET PASSWORD (Bottom Right) ===== -->
        <mxCell id="reset_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8f0;strokeColor=#d6b656;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="520" width="440" height="300" as="geometry" />
        </mxCell>
        <mxCell id="reset_title" value="&lt;b&gt;RESET PASSWORD&lt;/b&gt; - POST /api/admin/users/:id/reset-password&lt;br&gt;&lt;i&gt;Admin đặt lại mật khẩu cho user&lt;/i&gt;" style="text;html=1;align=center;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="530" width="400" height="35" as="geometry" />
        </mxCell>

        <mxCell id="r_start" value="&lt;b&gt;Request&lt;/b&gt; {new_password}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="580" width="160" height="30" as="geometry" />
        </mxCell>

        <mxCell id="r_d1" value="&lt;b&gt;Length&lt;br&gt;8-128?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="675" y="625" width="90" height="55" as="geometry" />
        </mxCell>
        <mxCell id="re1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="r_start" target="r_d1" parent="1" />

        <mxCell id="r_err" value="&lt;b&gt;400&lt;/b&gt; Too short/long" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="820" y="635" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="re2" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=9;" edge="1" source="r_d1" target="r_err" parent="1" />

        <mxCell id="r_hash" value="&lt;b&gt;bcrypt.hashpw(new_pw, rounds=12)&lt;/b&gt;&lt;br&gt;Update DB + reset failed_attempts&lt;br&gt;&lt;i&gt;Mã hoá MK mới + reset khoá&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="600" y="700" width="240" height="45" as="geometry" />
        </mxCell>
        <mxCell id="re3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=9;" edge="1" source="r_d1" target="r_hash" parent="1" />

        <mxCell id="r_audit" value="&lt;b&gt;AuditService.log(&quot;user.reset_password&quot;)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Ghi audit log&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="620" y="765" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="re4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="r_hash" target="r_audit" parent="1" />

        <!-- ===== LIST USERS (Far Right) ===== -->
        <mxCell id="list_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="80" width="350" height="260" as="geometry" />
        </mxCell>
        <mxCell id="list_title" value="&lt;b&gt;LIST USERS&lt;/b&gt; - GET /api/admin/users&lt;br&gt;&lt;i&gt;Danh sách tài khoản&lt;/i&gt;" style="text;html=1;align=center;fontSize=11;fillColor=#f5f5f5;strokeColor=#666;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="90" width="290" height="30" as="geometry" />
        </mxCell>

        <mxCell id="l_params" value="&lt;b&gt;Query Params:&lt;/b&gt;&lt;br&gt;?role=teacher&amp;search=john&lt;br&gt;&amp;limit=50&amp;offset=0&lt;br&gt;&lt;i&gt;Lọc theo role, tìm kiếm&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1050" y="130" width="230" height="55" as="geometry" />
        </mxCell>

        <mxCell id="l_process" value="&lt;b&gt;Build MongoDB query&lt;/b&gt;&lt;br&gt;$regex search on username/email&lt;br&gt;Case-insensitive&lt;br&gt;Max limit: 500&lt;br&gt;&lt;i&gt;Tìm kiếm regex, max 500&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1050" y="200" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="le1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="l_params" target="l_process" parent="1" />

        <mxCell id="l_resp" value="&lt;b&gt;200 OK&lt;/b&gt; {users: [sanitized], total, limit, offset}&lt;br&gt;&lt;i&gt;Trả danh sách (ẩn password_hash)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1040" y="275" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="le2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="l_process" target="l_resp" parent="1" />

        <!-- DB Schema box -->
        <mxCell id="schema_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="370" width="350" height="200" as="geometry" />
        </mxCell>
        <mxCell id="schema_title" value="&lt;b&gt;User Document Schema / Cấu trúc DB&lt;/b&gt;" style="text;html=1;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1040" y="375" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="schema" value="&lt;pre style='font-size:9px;margin:2px'&gt;{&lt;br&gt;  _id: ObjectId,&lt;br&gt;  username: String (unique, lowercase),&lt;br&gt;  password_hash: String (bcrypt r=12),&lt;br&gt;  email: String (unique, optional),&lt;br&gt;  role: &quot;admin&quot; | &quot;teacher&quot;,&lt;br&gt;  is_active: Boolean (default: true),&lt;br&gt;  failed_login_attempts: Int (0-5),&lt;br&gt;  locked_until: DateTime | null,&lt;br&gt;  last_login: DateTime,&lt;br&gt;  created_at: DateTime,&lt;br&gt;  updated_at: DateTime&lt;br&gt;}&lt;/pre&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="1005" y="400" width="320" height="160" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
