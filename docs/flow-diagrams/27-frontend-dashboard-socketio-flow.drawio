        <mxCell id="sec3" value="&lt;b&gt;C. DATA UPDATE FLOW&lt;/b&gt;&lt;br&gt;&lt;i&gt;Luồng cập nhật dữ liệu real-time&lt;/i&gt;" style="text;html=1;align=left;fontSize=14;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="460" y="550" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- Data flow: Agent → Server → SocketIO → Frontend -->
        <mxCell id="df1" value="&lt;b&gt;Agent&lt;/b&gt;&lt;br&gt;&lt;i&gt;Heartbeat / Log&lt;br&gt;POST /api/...&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="610" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="df2" value="&lt;b&gt;Server&lt;/b&gt;&lt;br&gt;&lt;i&gt;Process &amp;amp; Save&lt;br&gt;to MongoDB&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="610" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="edf1df2" value="HTTP" style="edgeStyle=orthogonalEdgeStyle;fontFamily=Segoe UI;fontSize=10;" edge="1" parent="1" source="df1" target="df2"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="df3" value="&lt;b&gt;SocketIO emit()&lt;/b&gt;&lt;br&gt;&lt;i&gt;Broadcast event&lt;br&gt;to all clients&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="610" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="edf2df3" value="emit()" style="edgeStyle=orthogonalEdgeStyle;fontFamily=Segoe UI;fontSize=10;" edge="1" parent="1" source="df2" target="df3"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="df4" value="&lt;b&gt;Frontend&lt;/b&gt;&lt;br&gt;&lt;i&gt;Update UI&lt;br&gt;(no page reload)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1060" y="610" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="edf3df4" value="WebSocket" style="edgeStyle=orthogonalEdgeStyle;fontFamily=Segoe UI;fontSize=10;" edge="1" parent="1" source="df3" target="df4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Shared UI Components -->
        <mxCell id="ui_comp" value="&lt;b&gt;🎨 Shared UI Components (base.js)&lt;/b&gt;&lt;hr&gt;&lt;div style='text-align:left;font-size:11px;'&gt;• &lt;b&gt;showNotification(type, msg, 5000ms)&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;Types: success, danger, warning, info&lt;br&gt;&amp;nbsp;&amp;nbsp;Toast popup (bottom-right)&lt;br&gt;&lt;br&gt;• &lt;b&gt;showLoading(btn) / hideLoading(btn)&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;Button spinner during API calls&lt;br&gt;&lt;br&gt;• &lt;b&gt;initCustomSelect(selectId)&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;Native → custom styled dropdown&lt;br&gt;&lt;br&gt;• &lt;b&gt;Fade-in Animation&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;Page load opacity transition&lt;br&gt;&lt;br&gt;• &lt;b&gt;Vietnam Timezone&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;parseTimestampCorrectly()&lt;br&gt;&amp;nbsp;&amp;nbsp;formatTimestamp()&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="720" width="350" height="260" as="geometry"/>
        </mxCell>

        <!-- Tech Stack -->
        <mxCell id="tech" value="&lt;b&gt;🛠 Frontend Tech Stack&lt;/b&gt;&lt;hr&gt;&lt;div style='text-align:left;font-size:11px;'&gt;• &lt;b&gt;HTML&lt;/b&gt;: Jinja2 templates (base.html)&lt;br&gt;• &lt;b&gt;CSS&lt;/b&gt;: Bootstrap 5.3.0&lt;br&gt;• &lt;b&gt;Icons&lt;/b&gt;: Font Awesome 6.4.0&lt;br&gt;• &lt;b&gt;JS&lt;/b&gt;: Vanilla JavaScript (ES6+)&lt;br&gt;• &lt;b&gt;Real-time&lt;/b&gt;: Socket.IO client&lt;br&gt;• &lt;b&gt;HTTP&lt;/b&gt;: fetch() API with interceptor&lt;br&gt;• &lt;b&gt;State&lt;/b&gt;: sessionStorage cache&lt;br&gt;• &lt;b&gt;Auth&lt;/b&gt;: httpOnly cookies (JWT)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Segoe UI;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="720" width="300" height="200" as="geometry"/>
