<mxfile host="app.diagrams.net" modified="2026-03-23" agent="Claude" version="24.0.0" type="device">
  <diagram id="logout-flow" name="Admin Logout Flow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Flow 2: Admin/Teacher Logout&lt;/b&gt;&lt;br&gt;POST /api/admin/auth/logout&lt;br&gt;&lt;i&gt;Luồng đăng xuất Admin/Giáo viên&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="100" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- Middleware check -->
        <mxCell id="mw" value="&lt;b&gt;@require_login&lt;/b&gt;&lt;br&gt;Validate JWT from cookie/header&lt;br&gt;&lt;i&gt;Kiểm tra đã đăng nhập&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="180" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="mw" parent="1" />

        <mxCell id="d1" value="&lt;b&gt;Authenticated?&lt;/b&gt;&lt;br&gt;&lt;i&gt;Đã xác thực?&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="475" y="270" width="130" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mw" target="d1" parent="1" />

        <mxCell id="err401" value="&lt;b&gt;401&lt;/b&gt; Redirect /login&lt;br&gt;&lt;i&gt;Chuyển hướng đăng nhập&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="710" y="280" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;" edge="1" source="d1" target="err401" parent="1" />

        <!-- Extract tokens -->
        <mxCell id="s2" value="&lt;b&gt;Extract tokens&lt;/b&gt;&lt;br&gt;access_token from cookie&lt;br&gt;refresh_token from body/cookie&lt;br&gt;&lt;i&gt;Lấy token từ cookie/body&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="440" y="385" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;" edge="1" source="d1" target="s2" parent="1" />

        <!-- Revoke access -->
        <mxCell id="s3" value="&lt;b&gt;Revoke access_token&lt;/b&gt;&lt;br&gt;Extract JTI → SessionModel.revoke(jti)&lt;br&gt;JWTService.revoke_token(token)&lt;br&gt;&lt;i&gt;Thu hồi access token&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="490" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s2" target="s3" parent="1" />

        <!-- Revoke refresh -->
        <mxCell id="s4" value="&lt;b&gt;Revoke refresh_token&lt;/b&gt;&lt;br&gt;Same flow → add to revoked_tokens&lt;br&gt;TTL auto-cleanup in MongoDB&lt;br&gt;&lt;i&gt;Thu hồi refresh token&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="595" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s3" target="s4" parent="1" />

        <!-- Clear cookies -->
        <mxCell id="s5" value="&lt;b&gt;Clear httpOnly Cookies&lt;/b&gt;&lt;br&gt;delete_cookie(&quot;access_token&quot;)&lt;br&gt;delete_cookie(&quot;refresh_token&quot;)&lt;br&gt;&lt;i&gt;Xoá cookie trên trình duyệt&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="435" y="700" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s4" target="s5" parent="1" />

        <!-- Response -->
        <mxCell id="resp" value="&lt;b&gt;200 OK&lt;/b&gt;&lt;br&gt;{success: true, message: &quot;Dang xuat thanh cong&quot;}&lt;br&gt;&lt;i&gt;Đăng xuất thành công&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="425" y="805" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s5" target="resp" parent="1" />

        <!-- End -->
        <mxCell id="end" value="End" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="890" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="resp" target="end" parent="1" />

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
