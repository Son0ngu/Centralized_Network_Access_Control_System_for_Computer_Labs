        <mxCell id="ta5" value="" style="endArrow=classic;html=1;strokeColor=#999;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="890" as="sourcePoint" />
            <mxPoint x="820" y="890" as="targetPoint" />
          </mxGeometry>
