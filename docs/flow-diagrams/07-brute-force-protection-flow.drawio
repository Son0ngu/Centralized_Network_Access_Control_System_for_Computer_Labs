        <!-- DB fields note -->
        <mxCell id="db_note" value="&lt;b&gt;DB Fields / Trường trong MongoDB:&lt;/b&gt;&lt;br&gt;• &lt;code&gt;failed_login_attempts&lt;/code&gt;: int (0 → 5)&lt;br&gt;• &lt;code&gt;locked_until&lt;/code&gt;: datetime | null" style="text;html=1;align=left;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;" vertex="1" parent="1">
