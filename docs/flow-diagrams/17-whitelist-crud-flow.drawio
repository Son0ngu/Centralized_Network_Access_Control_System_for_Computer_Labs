<mxfile host="app.diagrams.net" modified="2026-03-23" agent="Claude" version="24.0.0" type="device">
  <diagram id="whitelist-crud" name="Whitelist CRUD">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Flow 17: Whitelist CRUD&lt;/b&gt;&lt;br&gt;/api/whitelist - Admin + Teacher (scoped)&lt;br&gt;&lt;i&gt;Quản lý whitelist domain/IP/pattern&lt;/i&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="480" y="10" width="370" height="50" as="geometry" />
        </mxCell>

        <!-- ===== ADD ENTRY (Left) ===== -->
        <mxCell id="add_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="480" height="650" as="geometry" />
        </mxCell>
        <mxCell id="add_title" value="&lt;b&gt;ADD ENTRY&lt;/b&gt; - POST /api/whitelist&lt;br&gt;&lt;i&gt;Thêm entry vào whitelist&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="88" width="340" height="30" as="geometry" />
        </mxCell>

        <mxCell id="a_s1" value="&lt;b&gt;Request&lt;/b&gt;&lt;br&gt;{value, type, scope, group_id, category, notes}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="120" y="130" width="280" height="35" as="geometry" />
        </mxCell>

        <!-- RBAC -->
        <mxCell id="a_d1" value="&lt;b&gt;Is Teacher?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="210" y="185" width="90" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ae1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_s1" target="a_d1" parent="1" />

        <mxCell id="a_d2" value="&lt;b&gt;scope==global&lt;br&gt;&amp;&amp; no group_id?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="350" y="185" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ae2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="a_d1" target="a_d2" parent="1" />

        <mxCell id="a_err1" value="&lt;b&gt;403&lt;/b&gt;&lt;br&gt;Teacher không thêm global" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="370" y="255" width="130" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ae3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=9;" edge="1" source="a_d2" target="a_err1" parent="1" />

        <!-- Validate -->
        <mxCell id="a_v1" value="&lt;b&gt;1. Validate value&lt;/b&gt; (required, strip, lowercase)&lt;br&gt;&lt;b&gt;2. Validate type&lt;/b&gt; (domain/ip/pattern)&lt;br&gt;&lt;b&gt;3. Check duplicate&lt;/b&gt; (global scope, active)&lt;br&gt;&lt;i&gt;Kiểm tra giá trị, loại, trùng lặp&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ae4" value="No (Admin) / group ok" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=8;" edge="1" source="a_d1" target="a_v1" parent="1" />

        <mxCell id="a_v2" value="&lt;b&gt;4. Validate expiry&lt;/b&gt; (optional, Vietnam TZ)&lt;br&gt;is_temporary=true → +24h auto&lt;br&gt;&lt;b&gt;5. DNS verify&lt;/b&gt; (optional)&lt;br&gt;&lt;i&gt;Kiểm tra hết hạn + DNS&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ae5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_v1" target="a_v2" parent="1" />

        <!-- Build entry -->
        <mxCell id="a_build" value="&lt;b&gt;Build entry document&lt;/b&gt;&lt;br&gt;{type, value, category, priority,&lt;br&gt;scope, group_id, is_active: true,&lt;br&gt;added_date: now_vietnam(), expiry_date}&lt;br&gt;&lt;i&gt;Tạo document whitelist&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="70" y="420" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ae6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_v2" target="a_build" parent="1" />

        <mxCell id="a_db" value="&lt;b&gt;model.add_entry(entry)&lt;/b&gt;&lt;br&gt;+ bump_global_version()&lt;br&gt;&lt;i&gt;Lưu DB + tăng version&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="90" y="505" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ae7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_build" target="a_db" parent="1" />

        <mxCell id="a_socket" value="&lt;b&gt;SocketIO.emit(&quot;whitelist_updated&quot;)&lt;/b&gt;&lt;br&gt;{action: &quot;added&quot;, type, value}&lt;br&gt;&lt;i&gt;Thông báo realtime&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="75" y="570" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ae8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_db" target="a_socket" parent="1" />

        <mxCell id="a_resp" value="&lt;b&gt;201 Created&lt;/b&gt; {id, message}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="635" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ae9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_socket" target="a_resp" parent="1" />

        <!-- ===== DELETE ENTRY (Right Top) ===== -->
        <mxCell id="del_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="480" height="330" as="geometry" />
        </mxCell>
        <mxCell id="del_title" value="&lt;b&gt;DELETE ENTRY&lt;/b&gt; - DELETE /api/whitelist/:id&lt;br&gt;&lt;i&gt;Xoá entry khỏi whitelist&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="88" width="360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="d_s1" value="&lt;b&gt;DELETE /whitelist/:domain_id&lt;/b&gt;&lt;br&gt;ID len ≥ 10 validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="660" y="135" width="200" height="35" as="geometry" />
        </mxCell>

        <mxCell id="d_d1" value="&lt;b&gt;Is Teacher?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="715" y="190" width="90" height="40" as="geometry" />
        </mxCell>
        <mxCell id="de1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_s1" target="d_d1" parent="1" />

        <mxCell id="d_check" value="&lt;b&gt;Lookup entry in DB&lt;/b&gt;&lt;br&gt;Check scope + group ownership&lt;br&gt;&lt;i&gt;Tìm entry + kiểm tra quyền&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="860" y="190" width="150" height="45" as="geometry" />
        </mxCell>
        <mxCell id="de2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="d_d1" target="d_check" parent="1" />

        <mxCell id="d_d2" value="&lt;b&gt;Global entry&lt;br&gt;without group?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="870" y="260" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="de3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_check" target="d_d2" parent="1" />

        <mxCell id="d_err" value="&lt;b&gt;403&lt;/b&gt;&lt;br&gt;Teacher không xoá global" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="870" y="330" width="130" height="35" as="geometry" />
        </mxCell>
        <mxCell id="de4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#b85450;fontSize=9;" edge="1" source="d_d2" target="d_err" parent="1" />

        <mxCell id="d_ok" value="&lt;b&gt;service.delete_domain(id)&lt;/b&gt;&lt;br&gt;SocketIO.emit(&quot;whitelist_updated&quot;)&lt;br&gt;&lt;b&gt;200 OK&lt;/b&gt;&lt;br&gt;&lt;i&gt;Xoá thành công&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="630" y="260" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="de5" value="No (Admin)" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=9;" edge="1" source="d_d1" target="d_ok" parent="1" />
        <mxCell id="de6" value="No (group entry)" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontColor=#82b366;fontSize=9;" edge="1" source="d_d2" target="d_ok" parent="1" />

        <!-- ===== BULK OPERATIONS (Right Bottom) ===== -->
        <mxCell id="bulk_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="440" width="480" height="290" as="geometry" />
        </mxCell>
        <mxCell id="bulk_title" value="&lt;b&gt;BULK OPERATIONS&lt;/b&gt;&lt;br&gt;&lt;i&gt;Thao tác hàng loạt&lt;/i&gt;" style="text;html=1;align=center;fontSize=12;fillColor=#f5f5f5;strokeColor=#666;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="448" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Bulk Add -->
        <mxCell id="ba" value="&lt;b&gt;BULK ADD&lt;/b&gt; POST /whitelist/bulk&lt;br&gt;{items: [...]} (max 1000)&lt;br&gt;&lt;br&gt;Teacher: chỉ thêm vào group mình&lt;br&gt;Admin: thêm global + group&lt;br&gt;&lt;br&gt;Return: {added_count, failed_count, errors}&lt;br&gt;&lt;i&gt;Thêm hàng loạt (tối đa 1000)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="555" y="490" width="220" height="105" as="geometry" />
        </mxCell>

        <!-- Bulk Update -->
        <mxCell id="bu" value="&lt;b&gt;BULK UPDATE&lt;/b&gt; POST /whitelist/bulk-update&lt;br&gt;{item_ids: [...], active: bool}&lt;br&gt;&lt;br&gt;Supports pseudo-IDs:&lt;br&gt;group::gid::type::value&lt;br&gt;&lt;br&gt;Return: {updated_count, error_count}&lt;br&gt;&lt;i&gt;Cập nhật hàng loạt&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="790" y="490" width="220" height="105" as="geometry" />
        </mxCell>

        <!-- Bulk Delete -->
        <mxCell id="bd" value="&lt;b&gt;BULK DELETE&lt;/b&gt; POST /whitelist/bulk-delete&lt;br&gt;{item_ids: [&quot;id1&quot;, &quot;id2&quot;, ...]}&lt;br&gt;Same RBAC checks as bulk-update&lt;br&gt;&lt;i&gt;Xoá hàng loạt&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="615" width="320" height="55" as="geometry" />
        </mxCell>

        <!-- Entry types -->
        <mxCell id="types_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="760" width="480" height="180" as="geometry" />
        </mxCell>
        <mxCell id="types_title" value="&lt;b&gt;Entry Document Structure / Cấu trúc entry&lt;/b&gt;" style="text;html=1;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="130" y="765" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="types" value="&lt;pre style='font-size:9px;margin:2px'&gt;{&lt;br&gt;  _id: ObjectId,&lt;br&gt;  type: &quot;domain&quot; | &quot;ip&quot; | &quot;pattern&quot;,&lt;br&gt;  value: &quot;google.com&quot; | &quot;192.168.1.0/24&quot; | &quot;*.example.com&quot;,&lt;br&gt;  scope: &quot;global&quot; | &quot;group&quot;,&lt;br&gt;  group_id: String | null,&lt;br&gt;  category: &quot;general&quot; | &quot;education&quot; | &quot;imported&quot; | ...,&lt;br&gt;  priority: &quot;normal&quot; | &quot;high&quot; | &quot;low&quot;,&lt;br&gt;  is_active: Boolean,&lt;br&gt;  added_by: String (IP),&lt;br&gt;  added_date: DateTime (Vietnam TZ),&lt;br&gt;  expiry_date: DateTime | null,&lt;br&gt;  notes: String | null,&lt;br&gt;  max_requests_per_hour: Int | null&lt;br&gt;}&lt;/pre&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="45" y="790" width="450" height="140" as="geometry" />
        </mxCell>

        <!-- Scope RBAC -->
        <mxCell id="scope_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="760" width="480" height="120" as="geometry" />
        </mxCell>
        <mxCell id="scope_title" value="&lt;b&gt;Scope RBAC Rules / Quy tắc phân quyền theo scope&lt;/b&gt;" style="text;html=1;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="765" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="scope" value="&lt;table style='font-size:9px;border-collapse:collapse;width:100%'&gt;&lt;tr style='background:#6c8ebf;color:white'&gt;&lt;th style='padding:3px;border:1px solid #999'&gt;Action&lt;/th&gt;&lt;th style='padding:3px;border:1px solid #999'&gt;Admin&lt;/th&gt;&lt;th style='padding:3px;border:1px solid #999'&gt;Teacher&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Add global entry&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;❌ 403&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#f9f9f9'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Add group entry (own group)&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Add group entry (other group)&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;❌ 403&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#f9f9f9'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Delete global entry&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;❌ 403&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;Delete group entry (own)&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#f9f9f9'&gt;&lt;td style='padding:2px;border:1px solid #ccc'&gt;View all entries&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅ all&lt;/td&gt;&lt;td style='padding:2px;border:1px solid #ccc;text-align:center'&gt;✅ global + own groups&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="555" y="790" width="450" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
