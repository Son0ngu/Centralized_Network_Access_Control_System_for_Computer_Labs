        <mxCell id="540" value="&lt;b&gt;SocketIO Events (Real-time)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="260" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="541" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Server → Client Events:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;&lt;b&gt;agent_heartbeat&lt;/b&gt;&lt;/font&gt; - Real-time agent status update (CPU/RAM/disk)&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;&lt;b&gt;agent_registered&lt;/b&gt;&lt;/font&gt; - New agent connected&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;&lt;b&gt;agent_deleted&lt;/b&gt;&lt;/font&gt; - Agent removed&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;&lt;b&gt;agent_group_updated&lt;/b&gt;&lt;/font&gt; - Agent moved to different group&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;&lt;b&gt;agent_policy_changed&lt;/b&gt;&lt;/font&gt; - Agent firewall policy updated&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;whitelist_updated&lt;/b&gt;&lt;/font&gt; - Whitelist entry added/deleted/imported&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;whitelist_added&lt;/b&gt;&lt;/font&gt; - Single entry added&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;whitelist_deleted&lt;/b&gt;&lt;/font&gt; - Entry removed&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;whitelist_bulk_added&lt;/b&gt;&lt;/font&gt; - Bulk import completed&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;new_log&lt;/b&gt;&lt;/font&gt; - New log entry from agent&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;logs_cleared&lt;/b&gt;&lt;/font&gt; - Logs cleared by admin&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#996600&quot;&gt;&lt;b&gt;token_refreshed&lt;/b&gt;&lt;/font&gt; - Agent token refreshed&lt;br&gt;&lt;font color=&quot;#996600&quot;&gt;&lt;b&gt;agent_logout&lt;/b&gt;&lt;/font&gt; - Agent logged out&lt;br&gt;&lt;font color=&quot;#996600&quot;&gt;&lt;b&gt;user_created&lt;/b&gt;&lt;/font&gt; - New admin/teacher user created&lt;br&gt;&lt;font color=&quot;#996600&quot;&gt;&lt;b&gt;api_key_created&lt;/b&gt;&lt;/font&gt; - New API key created&lt;br&gt;&lt;font color=&quot;#996600&quot;&gt;&lt;b&gt;api_key_revoked&lt;/b&gt;&lt;/font&gt; - API key revoked&lt;br&gt;&lt;font color=&quot;#996600&quot;&gt;&lt;b&gt;admin_login&lt;/b&gt;&lt;/font&gt; - Admin/teacher logged in&lt;br&gt;&lt;br&gt;&lt;b&gt;Client → Server:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;&lt;b&gt;connect&lt;/b&gt;&lt;/font&gt; - Initial WebSocket connection&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;&lt;b&gt;ping&lt;/b&gt;&lt;/font&gt; → &lt;font color=&quot;#666666&quot;&gt;&lt;b&gt;pong&lt;/b&gt;&lt;/font&gt; - Keep-alive&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;&lt;b&gt;disconnect&lt;/b&gt;&lt;/font&gt; - Connection closed&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=1;points=[];autosize=0;strokeColor=#666666;fillColor=#f5f5f5;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="100" width="460" height="530" as="geometry"/>
        </mxCell>
        <mxCell id="550" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Shared JS (loaded on all pages via base.html):&lt;/b&gt;&lt;br&gt;&lt;b&gt;base.js&lt;/b&gt; - Notifications, custom select, user session&lt;br&gt;&lt;b&gt;auth.js&lt;/b&gt; - RBAC, token refresh, auto-logout on 401, fetch interceptor&lt;br&gt;&lt;br&gt;&lt;b&gt;Color Legend:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6c8ebf&quot;&gt;■&lt;/font&gt; Admin + Teacher access&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;■&lt;/font&gt; Admin only access&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;■&lt;/font&gt; Public access (Login)&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;■&lt;/font&gt; API endpoints called by page&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=1;points=[];autosize=0;strokeColor=#666666;fillColor=#f5f5f5;rounded=1;fontSize=11;" vertex="1" parent="1">
