          </mxGeometry>
        </mxCell>
        <mxCell id="E410" value="resolve → IPs" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="413" target="422">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="E411" value="signals (100ms)" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;strokeWidth=1.5;fontSize=10;strokeColor=#6c8ebf;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="402" target="401">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="440" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Thread Legend:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;① Token Manager&lt;/b&gt; - Background daemon, checks every 60s, refreshes JWT 5 min before expiry, triggers re-registration on 3 failures&lt;br&gt;&lt;b&gt;② Heartbeat&lt;/b&gt; - Daemon thread every 20s, sends system metrics (CPU/RAM/disk/uptime) to server&lt;br&gt;&lt;b&gt;③ Whitelist Sync&lt;/b&gt; - Periodic sync every 60s with version check, incremental merge, 3 retries with exponential backoff&lt;br&gt;&lt;b&gt;④ DNS Refresh&lt;/b&gt; - Resolves whitelist domains to IPs using dnspython, respects TTL, updates firewall rules dynamically&lt;br&gt;&lt;b&gt;⑤ Packet Sniffer&lt;/b&gt; - Scapy capture on TCP 80/443 + UDP 53, extracts HTTP Host / TLS SNI / DNS queries&lt;br&gt;&lt;b&gt;⑥ Domain Detection&lt;/b&gt; - Callback from sniffer, matches against WhitelistState, determines ALLOW/BLOCK/MONITOR action&lt;br&gt;&lt;b&gt;⑦ Firewall Manager&lt;/b&gt; - Windows Firewall via netsh: default-deny policy + per-IP allow rules, backup/restore&lt;br&gt;&lt;b&gt;⑧ Log Sender&lt;/b&gt; - Queue-based batching (max 1000 entries), sends every 2s or when batch_size=100 reached, flushes on shutdown&lt;br&gt;&lt;br&gt;&lt;b&gt;Startup sequence:&lt;/b&gt; Config → Register → Token Manager → Whitelist Sync → Firewall → Log Sender → Heartbeat → Sniffer&lt;br&gt;&lt;b&gt;Shutdown:&lt;/b&gt; Stop token → Stop sniffer → Stop whitelist → Stop heartbeat → Send shutdown log → Stop log sender → Restore firewall&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=1;points=[];autosize=0;strokeColor=#666666;fillColor=#f5f5f5;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="1060" height="290" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

