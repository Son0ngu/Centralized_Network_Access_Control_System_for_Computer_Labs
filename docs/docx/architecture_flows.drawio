        <mxCell id="340" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Flow Legend:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;① User Management (Admin only)&lt;/b&gt;&lt;/font&gt; - CRUD /api/admin/users + reset-password + statistics (7 endpoints)&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;② API Key Management (Admin only)&lt;/b&gt;&lt;/font&gt; - CRUD /api/api-keys + revoke + stats + validate (8 endpoints)&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;③ Audit Log Viewing (Admin only)&lt;/b&gt;&lt;/font&gt; - GET /api/admin/audit + /user/&amp;lt;id&amp;gt; (2 endpoints)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;&lt;b&gt;④ Group Management (Admin + Teacher)&lt;/b&gt;&lt;/font&gt; - CRUD /api/groups + POST set_teachers (6 endpoints)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Teachers: only see/edit their assigned groups. Admins: all groups.&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;⑤ Whitelist CRUD (Admin + Teacher)&lt;/b&gt;&lt;/font&gt; - GET/POST/DELETE /api/whitelist + bulk-add/update/delete + import/export + statistics (10 endpoints)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Teachers: scoped to their groups. Broadcasts: whitelist_updated, whitelist_added, whitelist_deleted&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;⑥ Whitelist Profiles (per-group)&lt;/b&gt;&lt;/font&gt; - CRUD /api/groups/&amp;lt;id&amp;gt;/profiles + activate/deactivate (8 endpoints)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Each group can have multiple whitelist profiles, only one active at a time&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=1;points=[];autosize=0;strokeColor=#666666;fillColor=#f5f5f5;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="940" height="280" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="agent-threads" name="4. Agent Internal Architecture">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="400" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;4. Agent Internal Architecture (8+ Threads)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="370" y="10" width="460" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="401" value="&lt;b&gt;GUI Main Thread&lt;/b&gt;&lt;br&gt;CustomTkinter (1200x800)&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Dashboard | Firewall | Logs | Whitelist | Settings&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="380" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="402" value="&lt;b&gt;Agent Controller&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Singleton orchestrator&lt;br&gt;States: STOPPED → STARTING → RUNNING → STOPPING&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="280" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="403" value="&lt;b&gt;Server&lt;/b&gt;&lt;br&gt;(Flask API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1100" y="300" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="410" value="&lt;b&gt;① Token Manager Thread&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Check every 60s&lt;br&gt;Refresh 5min before expiry&lt;br&gt;3 failures → re-register&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="411" value="&lt;b&gt;② Heartbeat Thread&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Every 20s → POST /heartbeat&lt;br&gt;CPU, RAM, disk, uptime&lt;br&gt;3 failures → callback&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="200" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="412" value="&lt;b&gt;③ Whitelist Sync Thread&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Every 60s → GET /agent-sync&lt;br&gt;Incremental merge + version check&lt;br&gt;3 retries with exp backoff&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="220" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="413" value="&lt;b&gt;④ DNS Refresh Thread&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Resolve domains → IPs&lt;br&gt;Respect DNS TTL&lt;br&gt;Update firewall rules&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="200" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="420" value="&lt;b&gt;⑤ Packet Sniffer Thread&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Scapy + WinPcap/Npcap&lt;br&gt;Filter: TCP 80,443 + UDP 53&lt;br&gt;Extract: DNS query, HTTP Host, TLS SNI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="230" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="421" value="&lt;b&gt;⑥ Domain Detection Handler&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Match domain/IP vs whitelist&lt;br&gt;Action: ALLOWED / BLOCKED / MONITORED&lt;br&gt;Create enhanced log record&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="350" width="240" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="422" value="&lt;b&gt;⑦ Firewall Manager&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Windows Firewall netsh commands&lt;br&gt;Default Deny + Allow rules per IP&lt;br&gt;Backup/restore policy&lt;br&gt;Sync whitelist changes dynamically&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="340" width="230" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="423" value="&lt;b&gt;⑧ Log Sender Thread&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Queue (max 1000) → batch POST /logs&lt;br&gt;Send interval: 2s, batch size: 100&lt;br&gt;Flush on shutdown&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="424" value="&lt;b&gt;Whitelist State&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Thread-safe (RLock)&lt;br&gt;Sets: domains, patterns, IPs&lt;br&gt;is_allowed() / is_ip_allowed()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="490" width="200" height="80" as="geometry"/>
