        <mxCell id="425" value="&lt;b&gt;Config Loader&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;agent_config.json&lt;br&gt;Defaults → File → Env vars&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="490" width="170" height="70" as="geometry"/>
