' ============================================================
' GUI controllers and PySide6 GUI package
' ============================================================
package "agent.controllers" {

  enum AgentStatus <<enum>> {
    STOPPED
    STARTING
    RUNNING
    DEGRADED
    STOPPING
    ERROR
  }

  class AgentEvent <<dataclass>> {
    + event_type: str
    + data: Dict[str,Any]
    + timestamp: float
  }

  class AgentSignals {
    - _callbacks: Dict[str,List[Callable]]
    - _event_queue: Queue
    - _lock: Lock
    --
    + connect(signal_name, callback): bool
    + disconnect(signal_name, callback): bool
    + emit(signal_name, data)
  }
  note right of AgentSignals : Tk-style ``process_events(root)``\nremoved. Qt frontends drain queue\nvia ``QtSignalBridge``.

  class AgentController <<singleton>> {
    - _instance: AgentController
    - _initialized: bool
    - _runtime: AgentRuntime
    - signals: AgentSignals
    - _status: AgentStatus
    - _agent: Optional[AgentRuntime]
    - _config: Optional[Dict]
    - _worker_thread: Optional[Thread]
    - _stop_event: Event
    - _stats_lock: Lock
    - _stats: Dict
    --
    + __new__(): AgentController
    + __init__(runtime=None)
    + reset_for_test() <<classmethod>>
    + status: AgentStatus <<property>>
    + is_running: bool <<property>>
    + stats: Dict <<property>>
    + start_agent(): bool
    + stop_agent(): bool
    + get_agent_info(): Dict
    + get_stats(): Dict
    + force_whitelist_sync(): bool
  }
  note right of AgentController : Singleton wrapper but accepts\ninjected AgentRuntime for tests.\n``set_root(root)`` removed.

  class WhitelistController <<singleton>> {
    --
    + set_whitelist_manager(manager)
    + on_data_changed(callback)
    + on_error(callback)
    + on_success(callback)
    + remove_ip(ip): bool
    + get_all_ips(): List[Dict]
    + refresh()
    + get_stats(): Dict
  }
}

package "agent.gui_qt" {
  class "app" as gui_qt_app <<module>> {
    + run()
  }

  class QtSignalBridge {
    - agent_signals: AgentSignals
    - _timer: QTimer
    + status_changed: Signal(dict)
    + stats_updated: Signal(dict)
    + packet_captured: Signal(dict)
    + log_received: Signal(dict)
    + error_occurred: Signal(dict)
    + whitelist_synced: Signal(dict)
    --
    + stop()
    + _drain()
    + _dispatch(event)
  }

  class MainWindow {
    - controller: AgentController
    - bridge: QtSignalBridge
    - stack: QStackedWidget
    - nav_buttons: Dict[str,QPushButton]
    --
    + _build_ui()
    + _on_status_changed(data)
    + _on_whitelist_synced(data)
    + _show_view(view_id)
    + closeEvent(event)
  }

  package "agent.gui_qt.views" {
    class DashboardView
    class FirewallView
    class WhitelistView
    class LogsView
    class SettingsView
  }

  package "agent.gui_qt.components" {
    class DataTable
    class SearchableDataTable
    class LogConsole
    class StatusCard
    class Sparkline
  }
}

' ============================================================
' Relationships
' ============================================================

' --- Core composition (set inside Agent.__init__ via lifecycle) ---
Agent *-- FirewallManager
Agent *-- WhitelistManager
Agent *-- LogSender
Agent *-- HeartbeatSender
Agent *-- PacketSniffer

' --- Core modules orchestrate lifecycle ---
core_lifecycle ..> Agent : init/cleanup
core_lifecycle ..> core_registry : step 1
core_lifecycle ..> core_tm_module : step 2 (init_token_manager)
core_lifecycle ..> WhitelistManager : step 3
core_lifecycle ..> FirewallManager : step 4
core_lifecycle ..> LogSender : step 5
core_lifecycle ..> HeartbeatSender : step 6
core_lifecycle ..> PacketSniffer : step 7
core_lifecycle ..> core_handlers : domain callback
core_handlers ..> WhitelistManager : is_allowed
core_handlers ..> LogSender : queue_log
core_tm_module ..> TokenManager : factory
core_agent_module ..> Agent : factory

' --- Firewall composition ---
FirewallManager *-- PolicyManager
FirewallManager *-- RulesManager
FirewallManager ..> FirewallUtils : netsh / validation
FirewallManager ..> OptimizedDNSResolver : _resolve_domains_to_ips

' --- Whitelist composition ---
WhitelistManager *-- WhitelistState
WhitelistManager *-- WhitelistSyncer
WhitelistManager *-- LRUCache : dns_cache
WhitelistManager *-- OptimizedDNSResolver : resolver
WhitelistManager o-- FirewallManager : set_firewall_manager()
WhitelistMonitor ..> WhitelistManager : sync_callback

' --- Capture composition ---
PacketSniffer *-- DomainExtractor
PacketSniffer ..> cap_scapy : configure
cap_scapy ..> cap_winpcap : ensure driver

' --- Network/Cache composition ---
OptimizedDNSResolver ..> DNSRecord : returns

' --- Services use TokenManager for auth headers ---
HeartbeatSender ..> core_tm_module : get_auth_headers()
LogSender ..> core_tm_module : get_auth_headers()
HeartbeatSender ..> WhitelistManager : on_force_sync callback

' --- Config wired into Agent at load ---
cfg_loader ..> cfg_crypto : encrypted file
cfg_loader ..> cfg_validator : validate
cfg_loader ..> cfg_defaults : merge defaults

' --- Utils ---
utils_ip_mod ..> IPDetector : factory
core_registry ..> CriticalErrorHandler : @critical_operation
core_registry ..> utils_ip_mod : device info

' --- GUI composition ---
gui_qt_app ..> MainWindow : creates
gui_qt_app ..> AgentController : creates
AgentController *-- AgentSignals
AgentSignals ..> AgentEvent : queues
AgentController ..> Agent : creates / drives
AgentController ..> core_lifecycle : initialize_components()
AgentController -- AgentStatus
WhitelistController ..> WhitelistManager : remove_ip

' --- Views ---
MainWindow *-- QtSignalBridge
QtSignalBridge ..> AgentSignals : drains queue
MainWindow ..> AgentController : start/stop/sync
MainWindow *-- DashboardView : lazy
MainWindow *-- FirewallView : lazy
MainWindow *-- WhitelistView : lazy
MainWindow *-- LogsView : lazy
MainWindow *-- SettingsView : lazy
DashboardView ..> StatusCard
DashboardView ..> LogConsole
FirewallView ..> DataTable
WhitelistView ..> SearchableDataTable
WhitelistView ..> WhitelistController
LogsView ..> LogConsole

note bottom of cfg_loader
  No ConfigLoader class exists.
  Config is loaded via module-level functions
  using DEFAULTS + file (encrypted/plain) + FC_* env vars.
end note

note right of core_lifecycle
  lifecycle.py / registry.py / handlers.py
  are module-level functions, NOT classes.
end note

@enduml
