title Class Diagram - SAINT Agent

' ============================================================
' Core package
' ============================================================
package "agent.core" {

  class AgentRuntime {
    - config: Dict
    - firewall: FirewallManager
    - whitelist: WhitelistManager
    - log_sender: LogSender
    - sniffer: PacketSniffer
    - heartbeat: HeartbeatSender
    - running: bool
    - _state: Dict
    --
    + __init__(state=None)
    + hostname: str <<property>>
    + device_id: str <<property>>
    + state: Dict <<property>>
    + update_state(**kwargs)
    + get_agent_id(): Optional[str]
    + get_agent_token(): Optional[str]
    + is_registered(): bool
    + is_running(): bool
    + stop()
  }
  note right of AgentRuntime : Injectable runtime container.\nNew code accepts AgentRuntime\nvia constructor injection.

  class Agent <<singleton>> {
    - _instance: Agent
    - _initialized: bool
    --
    + __new__(): Agent
    + reset_for_test() <<classmethod>>
  }
  Agent --|> AgentRuntime
  note right of Agent : Singleton wrapper kept for\nlegacy ``get_agent()`` callers.\nAlias state to agent_state dict.

  class DeviceIdentityProvider {
    - _cached_device_id: Optional[str]
    - _cached_hostname: Optional[str]
    - _lock: Lock
    --
    + get_device_id(): str <<classmethod>>
    + get_hostname(): str <<classmethod>>
    + reset() <<classmethod>>
  }
  note right of DeviceIdentityProvider : Lazy hardware id probe.\nReplaces import-time\n``AGENT_DEVICE_ID = generate_device_id()``.

  class TokenManager {
    - config: Dict
    - _access_token: Optional[str]
    - _refresh_token: Optional[str]
    - _access_expires_at: Optional[datetime]
    - _refresh_expires_at: Optional[datetime]
    - _refresh_thread: Optional[Thread]
    - _running: bool
    - _lock: Lock
    - _consecutive_refresh_failures: int
    - _needs_reregistration: bool
    --
    + set_tokens(access, refresh, access_exp, refresh_exp)
    + access_token: Optional[str] <<property>>
    + refresh_token: Optional[str] <<property>>
    + has_valid_token: bool <<property>>
    + is_expired: bool <<property>>
    + get_auth_header(): Dict[str,str]
    + refresh_now(): bool
    + start_auto_refresh(on_refreshed, on_expired)
    + stop_auto_refresh()
    + on_token_refreshed(callback)
    + on_token_expired(callback)
    + on_reregistration_needed(callback)
    + needs_reregistration: bool <<property>>
    + reset_reregistration_flag()
    + get_token_status(): Dict
  }

  class "lifecycle" as core_lifecycle <<module>> {
    + initialize_components(config): bool
    + cleanup(config)
    + build_lifecycle_log(config, event_type, action, message): Dict
  }

  class "registry" as core_registry <<module>> {
    + register_agent(config): bool
    + try_register_with_server(server_url, agent_info, config): bool
  }

  class "handlers" as core_handlers <<module>> {
    + create_domain_handler(config, agent): Callable
    + handle_domain_detection(record, config, whitelist, log_sender)
  }

  class "agent (module)" as core_agent_module <<module>> {
    + generate_device_id(): str
    + get_agent(): Agent
  }

  class "token_manager (module)" as core_tm_module <<module>> {
    + init_token_manager(config): TokenManager
    + get_token_manager(): Optional[TokenManager]
    + get_auth_headers(config): Dict[str,str]
  }
}

' ============================================================
' Firewall package
' ============================================================
package "agent.firewall" {

  class FirewallManager {
    - rule_prefix: str
    - policy_manager: PolicyManager
    - rules_manager: RulesManager
    - essential_ips: Set[str]
    - whitelist_mode_active: bool
    --
    + setup_whitelist_firewall(whitelisted_ips, essential_ips): bool
    + add_ip_to_whitelist(ip, reason): bool
    + remove_ip_from_whitelist(ip): bool
    + sync_whitelist_changes(old_ips, new_ips): bool
    + cleanup_whitelist_firewall(): bool
    + clear_all_rules(): bool
    + cleanup_all_rules(): bool
    + allowed_ips: Set[str] <<property>>
    + default_deny_enabled: bool <<property>>
    + get_whitelist_status(): Dict
    + get_firewall_policy_status(): Dict
    + validate_firewall_state(): Dict
    + test_whitelist_connectivity(sample_ips): Dict[str,bool]
    + is_blocked(ip): bool
    + get_blocked_ips(): List[str]
    + block_ip(ip, domain): bool
    + unblock_ip(ip): bool
    + update_whitelist(domains, ips): bool
    + enable_whitelist_mode(server_urls, whitelist_ips, whitelist_domains): bool
    + save_snapshot(path, force): bool
    + restore_snapshot(path): bool
  }

  class PolicyManager {
    - _original_policies: Dict[str,str]
    - default_deny_enabled: bool
    --
    + get_current_policy(): Dict[str,str]
    + backup_current_policy()
    + enable_default_deny(): bool
    + verify_default_deny(): bool
    + restore_original_policy(): bool
    + restore_default_policy(): bool
  }

  class RulesManager {
    - rule_prefix: str
    - allowed_ips: Set[str]
    - _rule_lock: Lock
    --
    + create_self_allow_rules(program_path): bool
    + create_allow_rule(ip): bool
    + remove_allow_rule(ip): bool
    + create_allow_rules_batch(ips): bool
    + clear_all_rules(): bool
    + load_existing_rules()
    + get_rule_count(): int
  }

  class FirewallUtils <<static>> {
    + {static} is_valid_ipv4(ip): bool
    + {static} is_valid_ip(ip): bool
    + {static} get_essential_ips(): Set[str]
    + {static} has_admin_privileges(): bool
    + {static} run_netsh_command(args): tuple
    + {static} test_ip_connectivity(ip): bool
  }
}

' ============================================================
' Whitelist package
' ============================================================
package "agent.whitelist" {

  class WhitelistManager {
    - config: Dict
    - _state: WhitelistState
    - _sync: WhitelistSyncer
    - _firewall_manager: Optional[FirewallManager]
    - _on_sync_callbacks: List[Callable]
    - _lock: RLock
    - _sync_thread: Optional[Thread]
    - _dns_refresh_thread: Optional[Thread]
    - _running: bool
    - _sync_interval: int
    - _cache_ttl: int
    - dns_cache: LRUCache
    - resolver: OptimizedDNSResolver
    - _stats: Dict
    --
    + on_sync_complete(callback)
    + set_firewall_manager(firewall_manager)
    + start_sync()
    + stop_sync()
    + sync_now(): bool
    + is_allowed(domain, ip): bool
    + is_ip_allowed(ip): bool
    + remove_ip(ip): bool
    + get_stats(): Dict
    + get_cache_info(): Dict
    + force_refresh(): bool
    + cleanup()
  }

  class WhitelistState {
    - _lock: RLock
    - _domains: Set[str]
    - _patterns: Set[str]
    - _ips: Set[str]
    - _last_updated: Optional[float]
    - _version: str
    - _group_version: str
    - _group_id: str
    - _policy_mode: str
    - _checksum: str
    - _metadata: Dict
    --
    + update(data): bool
    + is_domain_allowed(domain): bool
    + is_ip_allowed(ip): bool
    + get_stats(): Dict
    + get_all_domains(): Set[str]
    + get_all_patterns(): Set[str]
    + get_all_ips(): Set[str]
    + remove_ip(ip): bool
    + clear()
  }

  class WhitelistSyncer {
    - server_urls: List[str]
    - agent_id: str
    - config: Dict
    - connect_timeout: int
    - read_timeout: int
    - max_retries: int
    - current_server_index: int
    --
    + current_url: str <<property>>
    + sync_with_server(params): Dict
    + extract_domain_value(domain_data): Optional[str]
  }

  class WhitelistMonitor {
    - _sync_callback: Callable
    - _interval: float
    - _running: bool
    - _thread: Optional[Thread]
    - _last_sync: Optional[float]
    - _sync_count: int
    - _error_count: int
    --
    + start()
    + stop()
    + get_status(): dict
  }
}

