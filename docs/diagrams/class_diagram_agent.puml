  }

  class CacheValue <<dataclass>> {
    + value: Any
    + created_at: float
    + ttl: float
  }

  class LRUCache {
    - _cache: OrderedDict
    - _timestamps: Dict[str,float]
    - _ttls: Dict[str,float]
    - _max_size: int
    - _default_ttl: float
    - _lock: RLock
    - _hits: int
    - _misses: int
    --
    + get(key): Optional[Any]
    + set(key, value, ttl)
    + delete(key): bool
    + clear()
    + cleanup_expired(): int
    + get_expiring_keys(threshold_seconds): list[str]
    + get_stats(): Dict
    + __len__(): int
    + __contains__(key): bool
  }
}

