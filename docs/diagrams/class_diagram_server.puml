' ============================================================
' Services - business logic, inject models + socketio
' ============================================================
package "server.services" {

  class UserService {
    - user_model: UserModel
    - audit_service: AuditService
    - socketio: SocketIO
    --
    + create_user(username, password, role, email, created_by_user): Tuple
    + get_user_by_id(user_id): Optional[Dict]
    + get_all_users(query, limit, skip): List[Dict]
    + update_user(user_id, update_data, updated_by_user): Tuple
    + toggle_active(user_id, is_active, updated_by_user): Tuple
    + reset_password(user_id, new_password, reset_by_user): Tuple
    + delete_user(user_id, deleted_by_user): Tuple
    + ensure_default_admin(username, password): Optional[Dict]
  }

  class JWTService {
    - db: Optional[Database]
    --
    + generate_tokens(agent_id, user_id, additional_claims): Dict
    + validate_access_token(token): Tuple
    + validate_refresh_token(token): Tuple
    + refresh_access_token(refresh_token): Tuple
    + refresh_tokens_with_rotation(refresh_token): Tuple
    + revoke_token(token, token_type): bool
    + revoke_all_agent_tokens(agent_id): int
    + decode_token_without_verification(token): Optional[Dict]
    + get_token_info(token): Dict
  }

  class AdminAuthService {
    - user_model: UserModel
    - jwt_service: JWTService
    - session_model: SessionModel
    - audit_service: AuditService
    - socketio: SocketIO
    --
    + login(username, password, ip_address, user_agent): Tuple
    + logout(access_token, refresh_token): Tuple
    + refresh_token(refresh_token): Tuple
    + change_password(user_id, old_password, new_password): Tuple
  }

  class AuditService {
    - audit_model: AuditModel
    --
    + log_action(user, action, resource_type, resource_id, details, ip_address)
    + get_logs(query, limit, skip): List[Dict]
    + get_user_activity(user_id, limit): List[Dict]
    + count_logs(query): int
  }

  class RBACService {
    - group_model: Optional[GroupModel]
    - agent_model: Optional[AgentModel]
    --
    + check_permission(user_role, permission): bool
    + get_permissions(role): List[str]
    + is_admin(role): bool
    + is_owner(user_id, resource): bool
    + can_access_group(user, group): bool
    + filter_groups_for_user(user, groups): List[Dict]
    + get_teacher_group_ids(user): Optional[List[str]]
    + get_group_query_filter(user): Optional[Dict]
    + get_agent_query_filter(user): Optional[Dict]
    + get_log_query_filter(user): Optional[Dict]
    + get_whitelist_query_filter(user): Optional[Dict]
    + validate_group_ids_ownership(user, group_ids): tuple
    + can_teacher_access_agent(user, agent): bool
  }

  class AgentService {
    - agent_model: AgentModel
    - group_model: GroupModel
    - socketio: SocketIO
    - jwt_service: Optional[JWTService]
    - policy_model: Optional[AgentPolicyModel]
    --
    + set_jwt_service(jwt_service)
    + register_agent(agent_data, client_ip): Dict
    + update_heartbeat(agent_id, payload): Dict
    + list_agents(filters): List[Dict]
    + get_statistics(): Dict
    + calculate_status(last_heartbeat): str
    + delete_agent(agent_id): bool
    + update_agent(agent_id, data): Dict
  }

  class GroupService {
    - group_model: GroupModel
    - agent_model: AgentModel
    - user_model: Optional[UserModel]
    --
    + list_groups(query_filter): List[Dict]
    + create_group(name, description, whitelist, created_by): Dict
    + update_group(group_id, payload): Dict
    + delete_group(group_id): bool
    + bump_group_whitelist_version(group_id): Dict
    + get_pending_group_id(): str
    + get_group(group_id): Dict
    + get_default_metadata(): Dict
  }

  class WhitelistService {
    - whitelist_model: WhitelistModel
    - agent_model: AgentModel
    - group_model: GroupModel
    - socketio: SocketIO
    - policy_service: Optional[AgentPolicyService]
    - profile_service: Optional[WhitelistProfileService]
    --
    + get_all_entries(filters): Dict
    + add_entry(entry_data, client_ip): Dict
    + delete_entry(entry_id): bool
    + update_entry(entry_id, data): Dict
    + import_entries(entries): int
    + export_entries(filters): List[Dict]
    + get_entries_by_group(group_id): List[Dict]
    + agent_sync(agent_id, version, checksum): Dict
  }

  class LogService {
    - log_model: LogModel
    - agent_model: Optional[AgentModel]
    - socketio: SocketIO
    --
    + receive_logs(logs_data, agent_id): Dict
    + list_logs(query, limit, skip): Dict
    + get_statistics(): Dict
    + clear_logs(filters): int
  }

  class APIKeyService {
    - api_key_model: APIKeyModel
    - socketio: SocketIO
    --
    + create_api_key(name, description, expires_in_days, permissions, created_by): Dict
    + validate_api_key(api_key, required_permission): Dict
    + revoke_api_key(key_id, revoked_by): Dict
    + list_api_keys(include_revoked, page, limit): Dict
  }

  class WhitelistProfileService {
    - profile_model: WhitelistProfileModel
    - group_model: GroupModel
    - socketio: SocketIO
    --
    + create_profile(data): Dict
    + update_profile(profile_id, data): Dict
    + delete_profile(profile_id): bool
    + activate_profile(profile_id): Dict
    + deactivate_profile(profile_id): Dict
    + list_profiles(filters): List[Dict]
    + get_active_profile(group_id): Optional[Dict]
  }

  class AgentPolicyService {
    - policy_model: AgentPolicyModel
    - socketio: SocketIO
    --
    + get_policy(agent_id): Dict
    + set_policy(agent_id, mode, applied_by_user, reason, custom_whitelist, expires_at): Dict
    + reset_policy(agent_id, applied_by_user): Dict
    + get_effective_mode(agent_id): str
  }

  class "jwt_service (module)" as svc_jwt_mod <<module>> {
    + init_jwt_service(db): JWTService
    + get_jwt_service(): Optional[JWTService]
  }
}

