package "server.controllers" {

  class WebAuthController <<C>> {
    - admin_auth_service: AdminAuthService
    - jwt_service: JWTService
    - socketio: SocketIO
    - blueprint: Blueprint
    --
    + login()
    + get_profile()
    + refresh_token()
    + logout()
    + change_password()
    + update_profile()
  }
  note right of WebAuthController : Renamed from AdminAuthController.\nAlias kept for backwards-compat.

  class AgentAuthController <<C>> {
    - jwt_service: JWTService
    - blueprint: Blueprint
    --
    + refresh_token()
    + logout()
    + verify_token()
    + token_info()
  }
  note right of AgentAuthController : Renamed from AuthController.\nAlias kept for backwards-compat.

  class UserController <<C>> {
    - user_service: UserService
    - socketio: SocketIO
    - blueprint: Blueprint
    --
    + list_users()
