  class WhitelistController <<C>> {
    - whitelist_service: WhitelistService
    - rbac_service: RBACService
    - socketio: SocketIO
    - blueprint: Blueprint
    --
    + agent_sync()
    + list_domains()
    + add_domain()
    + delete_domain(entry_id)
    + update_entry(entry_id)
    + import_domains()
    + export_domains()
    + bulk_add_entries()
    + bulk_update_entries()
    + bulk_delete_entries()
  }

  class WhitelistProfileController <<C>> {
    - profile_service: WhitelistProfileService
    - rbac_service: RBACService
    - blueprint: Blueprint
    --
    + my_profiles()
    + list_profiles(group_id)
    + create_profile(group_id)
    + update_profile(profile_id)
    + delete_profile(profile_id)
