' ============================================================
' Middleware - module functions + 1 class (APIKeyMiddleware)
' ============================================================
package "server.middleware" {

  class "auth" as mw_auth <<module>> {
    + init_auth_middleware(api_key_service, jwt_service)
    + get_api_key_from_request(): Optional[str]
    + get_jwt_from_request(): Optional[str]
    + require_api_key(permission) <<decorator>>
    + optional_api_key(f) <<decorator>>
    + require_jwt(f) <<decorator>>
    + optional_jwt(f) <<decorator>>
    + require_jwt_or_api_key(permission) <<decorator>>
  }

  class APIKeyMiddleware <<M>> {
    - api_key_service: APIKeyService
    - protected_prefixes: List[str]
    --
    + before_request()
  }

  class "rbac" as mw_rbac <<module>> {
    + init_rbac_middleware(admin_auth_service, rbac_service, jwt_service, user_model)
    + get_rbac_service(): RBACService
    + require_login(f) <<decorator>>
    + require_admin(f) <<decorator>>
    + require_permission(permission) <<decorator>>
    + inject_current_user(f) <<decorator>>
    + require_group_ownership(group_id_param) <<decorator>>
  }
}

' ============================================================
' Config - RBAC role/permission map
' ============================================================
package "server.config" {
  class "rbac_config" as rbac_config <<module>> {
    + VALID_ROLES: List[str]
    + ROLE_HIERARCHY: Dict
    + PERMISSIONS: Dict
    + check_permission(role, permission): bool
    + get_all_permissions(role): List[str]
    + is_admin(role): bool
  }
}

' ============================================================
' App factory
' ============================================================
class "app (factory)" as app_factory <<module>> {
  + create_app(): (Flask, SocketIO)
  + initialize_database_indexes(app, db)
  + register_controllers(app, socketio, db)
  + register_main_routes(app, log_service, agent_service)
  + register_error_handlers(app)
  + register_socketio_events(socketio)
}

