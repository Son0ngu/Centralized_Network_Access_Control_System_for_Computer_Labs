  class LogController <<C>> {
    - log_model: LogModel
    - log_service: LogService
    - rbac_service: Optional[RBACService]
    - socketio: SocketIO
    - blueprint: Blueprint
    --
    + receive_logs()
    + list_logs()
    + clear_logs()
    + export_logs()
    + get_log_statistics()
    + get_statistics()
