@startuml SAINT_Server_Class_Diagram
' Generated from source audit of server/ - verified against report/server/*.md
' Stereotypes:
'   <<module>>     : Python module exposing only module-level functions (no class)
'   <<decorator>>  : function returning a decorator
'   <<C>>          : Flask Blueprint-bound controller
'   <<M>>          : Middleware class
' Controllers inject services via __init__; services inject models the same way.
' RBAC and Auth are decorators, not classes - only APIKeyMiddleware is a class.

skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #FEFECE
  BorderColor #A80036
  ArrowColor #A80036
}
skinparam package {
  BackgroundColor #F0F0F0
  BorderColor #888888
}

title Class Diagram - SAINT Server

' ============================================================
' Database config
' ============================================================
package "server.database" {

  class Config {
    + SECRET_KEY: str
    + DEBUG: bool
    + TESTING: bool
    + MONGO_URI: str
    + MONGO_DBNAME: str
    + MONGO_MAX_POOL_SIZE: int
  }

  class DevelopmentConfig extends Config
  class ProductionConfig extends Config
  class TestingConfig extends Config

  class "config (module)" as db_cfg_module <<module>> {
    + get_env(key, default): Any
    + get_mongo_client(config): MongoClient
    + get_database(config): Database
    + validate_config(config): bool
    + close_mongo_client()
    + get_config(): Config
  }
}

' ============================================================
' Models - one per MongoDB collection
' ============================================================
package "server.models" {

