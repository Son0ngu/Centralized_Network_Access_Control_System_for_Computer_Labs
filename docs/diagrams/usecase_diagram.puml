@startuml SAINT_UseCase_Diagram
' Generated from source audit + report/agent/*.md + report/server/*.md
' Actors:
'   Admin   : full access (server/config/rbac_config.py admin role)
'   Teacher : ownership-based RBAC, group-scoped only
'   Agent   : automated Windows client, uses API Key + JWT
' Use cases mirror real controller endpoints and Agent flows.

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
  ArrowColor #A80036
}
skinparam actor {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

title Use Case Diagram - SAINT System

actor "Admin" as Admin
actor "Teacher" as Teacher
actor "Agent\n(Windows PC)" as Agent <<machine>>

rectangle "SAINT System" {

  package "Authentication" {
    usecase "Login\n(JWT)" as UC_Login
    usecase "Logout\n(revoke session)" as UC_Logout
    usecase "Change Password" as UC_ChangePass
    usecase "Update Profile" as UC_UpdateProfile
    usecase "Refresh JWT" as UC_RefreshJWT
    usecase "Register Agent\n(API Key -> JWT)" as UC_RegAgent
    usecase "Verify Token" as UC_VerifyToken
  }

  package "User Management" {
    usecase "List Users" as UC_ListUsers
    usecase "Create User" as UC_CreateUser
    usecase "Update User" as UC_UpdateUser
    usecase "Delete User" as UC_DeleteUser
    usecase "Reset User Password" as UC_ResetPass
    usecase "Toggle User Active" as UC_ToggleUser
    usecase "User Statistics" as UC_UserStats
  }

  package "Group Management" {
    usecase "List Groups\n(RBAC filtered)" as UC_ListGroups
    usecase "Create Group" as UC_CreateGroup
    usecase "Update Group" as UC_UpdateGroup
    usecase "Delete Group" as UC_DeleteGroup
    usecase "Set Teachers\nof Group" as UC_SetTeachers
    usecase "Move Agent\nto Group" as UC_MoveAgent
  }

  package "Whitelist Management" {
    usecase "List Domains/IPs\n(RBAC filtered)" as UC_ListWL
    usecase "Add Domain/IP" as UC_AddDomain
    usecase "Update Entry" as UC_UpdateEntry
    usecase "Delete Domain/IP" as UC_DelDomain
    usecase "Bulk Add Entries" as UC_BulkAdd
    usecase "Bulk Update Entries" as UC_BulkUpdate
    usecase "Bulk Delete Entries" as UC_BulkDelete
    usecase "Import Whitelist" as UC_ImportWL
    usecase "Export Whitelist" as UC_ExportWL
    usecase "Agent Sync Whitelist\n(version + checksum)" as UC_SyncWL
  }

  package "Whitelist Profiles" {
    usecase "List My Profiles" as UC_MyProfiles
    usecase "List Group Profiles" as UC_ListProfiles
    usecase "Create Profile" as UC_CreateProfile
    usecase "Update Profile" as UC_UpdateProfile2
    usecase "Activate Profile" as UC_ActivateProfile
    usecase "Deactivate Profile" as UC_DeactivateProfile
    usecase "Delete Profile" as UC_DeleteProfile
  }

  package "Network Monitoring" {
    usecase "Capture Packets\n(Scapy)" as UC_Capture
    usecase "Extract Domain\n(DNS / HTTP Host / TLS SNI)" as UC_Extract
    usecase "Check Domain\nagainst Whitelist" as UC_CheckDomain
    usecase "Send Log Batch\n(/api/logs)" as UC_SendLogs
    usecase "Receive Logs" as UC_ReceiveLogs
    usecase "List Logs\n(RBAC filtered)" as UC_ViewLogs
    usecase "Clear Logs" as UC_ClearLogs
    usecase "Export Logs" as UC_ExportLogs
    usecase "Log Statistics" as UC_LogStats
  }

  package "Firewall Control" {
    usecase "Enable\nWhitelist-Only Mode\n(Default Deny)" as UC_EnableWL
    usecase "Apply Allow Rules\n(netsh)" as UC_ApplyFW
    usecase "Save Snapshot" as UC_SaveSnap
    usecase "Restore Snapshot" as UC_RestoreSnap
    usecase "Send Heartbeat\n+ metrics" as UC_Heartbeat
  }

  package "Agent Policy" {
    usecase "Get Agent Policy" as UC_GetPolicy
    usecase "Set Policy\n(whitelist_only / isolate /\nreset / custom_whitelist)" as UC_SetPolicy
    usecase "List Agents\n(RBAC filtered)" as UC_ListAgents
    usecase "Get Agent Detail" as UC_GetAgent
    usecase "Delete Agent" as UC_DelAgent
    usecase "Update Display Name" as UC_UpdateDisplay
    usecase "Update Position" as UC_UpdatePos
    usecase "Agent Statistics" as UC_AgentStats
  }

  package "API Key Management" {
    usecase "List API Keys" as UC_ListKeys
    usecase "Create API Key" as UC_CreateKey
    usecase "Update API Key" as UC_UpdateKey
    usecase "Revoke API Key" as UC_RevokeKey
    usecase "Delete API Key" as UC_DeleteKey
  }

  package "Audit" {
    usecase "List Audit Logs" as UC_ViewAudit
    usecase "View User Activity" as UC_ViewActivity
  }
}

